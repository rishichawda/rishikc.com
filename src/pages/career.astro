---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/base_layout.astro";
import { buildWebPageEntity, personRef } from "../utils/jsonLd";
import { Image } from "astro:assets";
import favicon from "../../content/assets/logo/logo.png";
import profilePhoto from "../../content/assets/me-profesh.jpg";
import { fetchMetadata, type WebsiteMeta } from "../utils/metadataFetcher";
import LinkCard from "../components/LinkCard.astro";
import Breadcrumbs from "../components/common/breadcrumbs.astro";

interface Language { name: string; level: string; }
interface Social { platform: string; url: string; }

interface Position {
  title: string;
  period: string;
  start_date: string;
  end_date: string | null;
  duration: string;
  location?: string;
  description?: string;
  responsibilities?: string[];
  links?: string[];
  linksMeta?: WebsiteMeta[];
}

interface ClubPosition {
  title: string;
  period: string;
  start_date: string;
  end_date: string | null;
  duration: string;
  location?: string;
  description?: string;
  responsibilities?: string[];
}

interface ExtraCurricular { club: string; positions: ClubPosition[]; }

interface Experience {
  company: string;
  duration: string;
  positions: Position[];
  website?: string[];
  websitesMeta?: WebsiteMeta[];
}

interface Education {
  university: string;
  institution: string;
  degree: string;
  period: string;
  start_date?: string;
  end_date?: string;
  extra_curriculars?: ExtraCurricular[];
}

interface Certification { institution: string; title: string; }

interface ProfileData {
  name: string;
  title: string;
  location: string;
  summary: string;
  bio: string | string[];
  contact: { linkedin: string; };
  skills: string[];
  languages: Language[];
  certifications: Certification[];
  experience: Experience[];
  education: Education[];
  interests: string[];
  socials: Social[];
}

const profileEntry = await getCollection("profile");
const profileData = profileEntry[0].data as ProfileData;
const profile = profileData;

const experiencesWithMeta = await Promise.all(
  profile.experience.map(async (exp): Promise<Experience> => {
    let companyWebsitesMeta: WebsiteMeta[] = [];
    if (exp.website && exp.website.length > 0) {
      companyWebsitesMeta = await Promise.all(
        exp.website.map((url) => fetchMetadata(url)),
      );
    }
    const positionsWithMeta = await Promise.all(
      exp.positions.map(async (pos): Promise<Position> => {
        if (pos.links && pos.links.length > 0) {
          const linksMeta = await Promise.all(
            pos.links.map((url) => fetchMetadata(url)),
          );
          return { ...pos, linksMeta };
        }
        return pos;
      }),
    );
    return { ...exp, websitesMeta: companyWebsitesMeta, positions: positionsWithMeta };
  }),
);

const currentRole = experiencesWithMeta[0];
const pastExperiences = experiencesWithMeta.slice(1);

const page_info = {
  title: `Career | ${profile.name}`,
  description: `Explore ${profile.name}'s professional journey as a ${profile.title}. Learn about work experience, skills, and career achievements.`,
  keywords: `${profile.name}, Career, Software Engineer, Experience, Skills, ${profile.skills.join(', ')}`,
};

const siteUrl = new URL(
  Astro.url.pathname,
  Astro.site || "https://rishikc.com",
).toString();

const pageSchemaEntities = [
  buildWebPageEntity({
    type: "ProfilePage",
    url: siteUrl,
    name: page_info.title,
    description: page_info.description,
    mainEntity: personRef,
  }),
];
---

<BaseLayout page_info={page_info} activeRoute="/career/" pageSchemaEntities={pageSchemaEntities}>

  <main class="career-page">
    <Breadcrumbs items={[{ label: "Career" }]} />

    <!-- Page Header -->
    <section class="page-header" data-reveal>
      <div class="header-photo">
        <Image
          src={profilePhoto}
          alt={`${profile.name} — professional headshot`}
          width={120}
          height={120}
          class="headshot"
        />
      </div>
      <span class="overline">PROFESSIONAL JOURNEY</span>
      <h1 class="page-title">Career</h1>
      <p class="page-subtitle">A timeline of building, learning, and growing.</p>
    </section>

    <!-- Skills Snapshot -->
    <section class="skills-section skills-top" data-reveal>
      <h2 class="skills-heading">Skills &amp; Expertise</h2>
      <ul class="skills-pills" role="list">
        {profile.skills.map((skill) => (
          <li class="skill-pill">{skill}</li>
        ))}
      </ul>
    </section>

    <!-- Current Role Spotlight -->
    {currentRole && (
      <section class="current-role" data-reveal aria-current="true">
        <div class="role-accent" aria-hidden="true"></div>
        <div class="role-content">
          <div class="role-header">
            <span class="current-badge">Current</span>
            <h2 class="role-title">{currentRole.positions[0]?.title}</h2>
            <h3 class="role-company">{currentRole.company}</h3>
            <span class="role-duration company-duration" data-positions={JSON.stringify(currentRole.positions)}>
              {currentRole.positions[0]?.period}
            </span>
          </div>

          {currentRole.positions[0]?.description && (
            <p class="role-desc">{currentRole.positions[0].description}</p>
          )}

          {currentRole.websitesMeta && currentRole.websitesMeta.length > 0 && (
            <div class="role-links">
              {currentRole.websitesMeta.map((site) => (
                <LinkCard
                  {...site}
                  altText={`${site.title || currentRole.company} preview`}
                  errorTitle={`Visit ${currentRole.company} website`}
                />
              ))}
            </div>
          )}

          {currentRole.positions.length > 1 && (
            <div class="past-positions">
              <h4 class="past-positions-title">Previous Positions</h4>
              {currentRole.positions.slice(1).map((pos) => (
                <div class="past-position">
                  <span class="past-pos-title">{pos.title}</span>
                  <span class="past-pos-period">
                    {pos.period}
                    <span class="position-duration" data-start-date={pos.start_date} data-end-date={pos.end_date}></span>
                  </span>
                  {pos.description && (
                    <p class="past-pos-desc">{pos.description}</p>
                  )}
                  {pos.linksMeta && pos.linksMeta.length > 0 && (
                    <div class="past-pos-links">
                      <span class="pos-link-label">Related Projects</span>
                      {pos.linksMeta.map((site) => (
                        <LinkCard {...site} />
                      ))}
                    </div>
                  )}
                </div>
              ))}
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Work Experience Timeline -->
    {pastExperiences.length > 0 && (
      <section class="timeline-section">
        <div class="section-header" data-reveal>
          <h2 class="section-title">Work Experience</h2>
        </div>

        <ol class="timeline" role="list">
          {pastExperiences.map((exp, index) => (
            <li class="timeline-entry" data-reveal>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-card">
                <h3 class="entry-company">{exp.company}</h3>
                <span class="entry-duration company-duration" data-positions={JSON.stringify(exp.positions)}>
                </span>

                {exp.websitesMeta && exp.websitesMeta.length > 0 && (
                  <div class="entry-link-cards">
                    {exp.websitesMeta.map((site) => (
                      <LinkCard
                        {...site}
                        altText={`${site.title || exp.company} preview`}
                        errorTitle={`Visit ${exp.company} website`}
                      />
                    ))}
                  </div>
                )}

                <div class="positions-list">
                  {exp.positions.map((position, posIndex) => (
                    <div class={`position ${posIndex > 0 ? 'position-border' : ''}`}>
                      <h4 class="pos-title">{position.title}</h4>
                      <div class="pos-meta">
                        <span>{position.period}<span class="position-duration" data-start-date={position.start_date} data-end-date={position.end_date}></span></span>
                        {position.location && <span>{position.location}</span>}
                      </div>
                      {position.description && (
                        <p class="pos-desc">{position.description}</p>
                      )}
                      {position.linksMeta && position.linksMeta.length > 0 && (
                        <div class="pos-link-cards">
                          <span class="pos-link-label">Related Projects</span>
                          {position.linksMeta.map((site) => (
                            <LinkCard {...site} />
                          ))}
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            </li>
          ))}
        </ol>
      </section>
    )}

    <!-- Education -->
    <section class="education-section">
      <div class="section-header" data-reveal>
        <h2 class="section-title">Education</h2>
      </div>

      <div class="edu-list">
        {profile.education.map((edu) => (
          <div class="edu-card" data-reveal>
            <div class="edu-accent" aria-hidden="true"></div>
            <div class="edu-body">
              <h3 class="edu-university">{edu.university}</h3>
              <p class="edu-institution">{edu.institution}</p>
              <p class="edu-degree">{edu.degree}</p>
              <span class="edu-period">{edu.period}</span>

              {edu.extra_curriculars && edu.extra_curriculars.length > 0 && (
                <div class="edu-extras">
                  <h4 class="extras-title">Extra-Curricular Activities</h4>
                  {edu.extra_curriculars.map((activity) => (
                    <div class="extra-activity">
                      <h5 class="activity-club">{activity.club}</h5>
                      {activity.positions.map((pos) => (
                        <div class="activity-position">
                          <span class="activity-pos-title">{pos.title}</span>
                          <span class="activity-pos-period">
                            {pos.period}
                            <span class="position-duration" data-start-date={pos.start_date} data-end-date={pos.end_date}></span>
                          </span>
                          {pos.description && <p class="activity-desc">{pos.description}</p>}
                        </div>
                      ))}
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>



    <!-- CTA -->
    <section class="cta-section" data-reveal>
      <h2 class="cta-title">Interested in collaborating?</h2>
      <p class="cta-desc">Let's build something meaningful together.</p>
      <div class="cta-links">
        <a href="/contact/" class="btn-primary">Let's Connect</a>
        <a href="/projects/" class="btn-ghost">View Projects</a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .career-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  /* Page Header */
  .page-header {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-20) 0 var(--space-12);
    text-align: center;
  }
  .overline {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }
  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-4);
    line-height: 1.1;
    letter-spacing: -0.025em;
  }
  .page-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  /* Current Role */
  .current-role {
    display: flex;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 40px;
    box-shadow: var(--shadow-elevated);
    margin-bottom: var(--space-16);
    overflow: hidden;
  }
  .role-accent {
    width: 4px;
    flex-shrink: 0;
    background: var(--color-brand);
    border-radius: 2px;
    margin-right: 32px;
  }
  .role-content { flex: 1; min-width: 0; }
  .role-header { margin-bottom: var(--space-5); }
  .current-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 4px 12px;
    background: var(--btn-bg);
    color: white;
    border-radius: 8px;
    margin-bottom: var(--space-3);
  }
  .role-title {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
    line-height: 1.2;
  }
  .role-company {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--color-brand);
    margin: 0 0 var(--space-2);
  }
  .role-duration {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-tertiary);
  }
  .role-desc {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0 0 var(--space-5);
  }
  .role-links {
    margin-top: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  @media (min-width: 768px) {
    .role-links {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }
  .past-positions {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }
  .past-positions-title {
    font-family: var(--font-ui);
    font-size: var(--text-body-sm);
    font-weight: 600;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-3);
  }
  .past-position {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3) 0;
    border-top: 1px solid var(--color-border);
  }
  .past-position:first-child {
    border-top: none;
  }
  .past-pos-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .past-pos-title {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text);
    font-weight: 500;
  }
  .past-pos-period {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-tertiary);
  }
  .past-pos-desc {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: var(--space-1) 0 0;
  }
  .past-pos-links {
    margin-top: var(--space-2);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  @media (min-width: 768px) {
    .past-pos-links {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  /* Timeline Section */
  .timeline-section {
    padding-bottom: var(--space-16);
  }
  .section-header {
    text-align: center;
    margin-bottom: var(--space-10);
  }
  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin: 0;
  }

  /* Timeline */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    padding-left: 32px;
  }
  .timeline::before {
    content: "";
    position: absolute;
    left: 5px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-border);
  }
  .timeline-entry {
    position: relative;
    padding-bottom: var(--space-10);
  }
  .timeline-entry:last-child { padding-bottom: 0; }
  .timeline-dot {
    position: absolute;
    left: -32px;
    top: 4px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-border);
    border: 2px solid var(--color-bg);
    z-index: 1;
    transition: background 200ms;
  }
  .timeline-entry:hover .timeline-dot {
    background: var(--color-brand);
  }
  .timeline-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 24px;
    box-shadow: var(--shadow-subtle);
    transition: transform 250ms, box-shadow 250ms;
  }
  .timeline-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-raised);
  }
  .entry-company {
    font-family: var(--font-display);
    font-size: var(--text-h4);
    font-weight: 600;
    letter-spacing: -0.005em;
    line-height: 1.35;
    color: var(--color-text);
    margin: 0 0 var(--space-1);
  }
  .entry-duration {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-tertiary);
    display: block;
    margin-bottom: var(--space-4);
  }
  .entry-link-cards {
    margin-bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  @media (min-width: 768px) {
    .entry-link-cards {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }

  /* Positions */
  .positions-list {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-4);
  }
  .position { padding: var(--space-3) 0; }
  .position-border {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-3);
    padding-top: var(--space-4);
  }
  .pos-title {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 500;
    color: var(--color-brand);
    margin: 0 0 var(--space-1);
  }
  .pos-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-2);
  }
  .pos-desc {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    font-style: italic;
    margin: 0;
  }
  .pos-link-cards {
    margin-top: var(--space-4);
    padding: var(--space-4);
    background: var(--color-bg-alt);
    border-radius: 12px;
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  @media (min-width: 768px) {
    .pos-link-cards {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }
  .pos-link-label {
    display: block;
    width: 100%;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-3);
  }

  /* Education */
  .education-section {
    padding-bottom: var(--space-16);
  }
  .edu-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 880px;
    margin: 0 auto;
  }
  .edu-card {
    display: flex;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 32px;
    overflow: hidden;
  }
  .edu-accent {
    width: 3px;
    flex-shrink: 0;
    background: var(--color-brand);
    border-radius: 2px;
    margin-right: 24px;
  }
  .edu-body { flex: 1; min-width: 0; }
  .edu-university {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--color-text);
    margin: 0 0 var(--space-1);
  }
  .edu-institution {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-2);
  }
  .edu-degree {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
  }
  .edu-period {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-tertiary);
  }

  /* Extra-curriculars */
  .edu-extras {
    margin-top: var(--space-6);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }
  .extras-title {
    font-family: var(--font-ui);
    font-size: var(--text-body-sm);
    font-weight: 600;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-4);
  }
  .extra-activity { margin-bottom: var(--space-4); }
  .extra-activity:last-child { margin-bottom: 0; }
  .activity-club {
    font-family: var(--font-display);
    font-size: var(--text-body-lg);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
  }
  .activity-position {
    padding-left: 16px;
    border-left: 2px solid var(--color-brand-lighter);
    margin-bottom: var(--space-3);
  }
  .activity-pos-title {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: 500;
    color: var(--color-text);
    display: block;
  }
  .activity-pos-period {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-tertiary);
    display: block;
    margin-bottom: var(--space-1);
  }
  .activity-desc {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    font-style: italic;
    margin: var(--space-1) 0 0;
    line-height: 1.5;
  }

  /* Headshot */
  .header-photo {
    margin-bottom: var(--space-6);
    display: flex;
    justify-content: center;
  }
  .headshot {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--color-brand-lighter);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  /* Skills Section (top) */
  .skills-top {
    max-width: 720px;
    margin: 0 auto var(--space-12);
    text-align: center;
  }
  .skills-heading {
    font-family: var(--font-display);
    font-size: var(--text-body-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
    margin: 0 0 var(--space-4);
  }
