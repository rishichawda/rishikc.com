---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/base_layout.astro";

const page_info = {
    title: "Page Not Found - Rishi Chawda",
    description: "The page you're looking for doesn't exist or has been moved.",
    keywords: "404, page not found, error, Rishi Chawda",
    noindex: true,
};

const allArticles = await getCollection("articles");
const latestArticle = allArticles.sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)[0];

function formatDate(date: Date): string {
    return new Date(date).toLocaleDateString("en-US", {
        day: "numeric",
        month: "long",
        year: "numeric",
    });
}
---

<BaseLayout page_info={page_info}>
    <main class="not-found">
        <div class="content" data-reveal>
                <!-- Mini-game prompt (appears after 5s idle) -->
                <div id="game-prompt" class="game-prompt" aria-hidden="true">
                    <p class="game-prompt-text">Bored? Try pressing the arrow keys...</p>
                </div>
                <!-- Catch the Dot game area -->
                <div id="game-area" class="game-area" aria-hidden="true">
                    <div id="game-player" class="game-player"></div>
                    <div id="game-dot" class="game-dot"></div>
                    <div id="game-score" class="game-score">Score: <span id="game-score-value">0</span>/5</div>
                    <button id="game-dismiss" class="game-dismiss">I'd rather search</button>
                </div>
                <div id="game-win" class="game-win pb-4" aria-hidden="true">
                    <p>Nice reflexes! Now go read an article 😄</p>
                    <a href={latestArticle?.data.path || "/articles/"} class="pill">Read it →</a>
                </div>

            <span class="watermark">404</span>
            <h1 class="heading">Page not found</h1>
            <p class="subtext">The page you're looking for doesn't exist or has been moved. Try searching or explore one of the sections below.</p>

            <nav class="quick-links" aria-label="Quick navigation">
                <a href="/" class="pill">Home</a>
                <a href="/articles/" class="pill">Articles</a>
                <a href="/gallery/" class="pill">Gallery</a>
                <a href="/projects/" class="pill">Projects</a>
                <a href="/contact/" class="pill">Contact</a>
            </nav>

            <form class="search-form" action="/search/" method="get">
                <input
                    type="text"
                    name="q"
                    placeholder="Search for something..."
                    class="search-input"
                    aria-label="Search"
                />
            </form>

            {latestArticle && (
                <div class="latest-article">
                    <span class="latest-label">Latest from the blog:</span>
                    <a href={latestArticle.data.path} class="latest-link">{latestArticle.data.title}</a>
                    <span class="latest-meta">
                        {formatDate(latestArticle.data.date)}
                        {latestArticle.data.minutesRead && ` · ${latestArticle.data.minutesRead}`}
                    </span>
                </div>
            )}
        </div>
    </main>
</BaseLayout>

<style>
    .not-found {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - var(--nav-height, 72px) - 200px);
        padding: var(--space-10) var(--space-6);
    }
    .content {
        max-width: 560px;
        text-align: center;
        position: relative;
    }
    .watermark {
        font-family: var(--font-display);
        font-size: 96px;
        font-weight: 700;
        color: var(--color-brand);
        line-height: 1;
        display: block;
        margin-bottom: var(--space-4);
    }
    .heading {
        font-family: var(--font-display);
        font-size: var(--text-display);
        font-weight: 700;
        letter-spacing: -0.025em;
        color: var(--color-text);
        margin: 0 0 var(--space-4);
    }
    .subtext {
        font-family: var(--font-body);
        font-size: var(--text-body-lg);
        color: var(--color-text-secondary);
        margin: 0 0 var(--space-8);
        line-height: 1.6;
    }
    .quick-links {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3);
        justify-content: center;
        margin-bottom: var(--space-8);
    }
    .pill {
        font-family: var(--font-ui);
        font-size: 14px;
        padding: 8px 16px;
        border-radius: 9999px;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        color: var(--color-text);
        text-decoration: none;
        font-weight: 500;
        transition: background 200ms, color 200ms;
    }
    .pill:hover {
        background: var(--color-brand-lighter);
        color: var(--color-brand);
    }
    .search-form {
        margin-bottom: var(--space-8);
    }
    .search-input {
        width: 100%;
        max-width: 400px;
        padding: 12px 16px;
        font-family: var(--font-body);
        font-size: var(--text-body);
        color: var(--color-text);
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        outline: none;
        transition: border-color 200ms, box-shadow 200ms;
    }
    .search-input::placeholder {
        color: var(--color-text-muted);
    }
    .search-input:focus {
        border-color: var(--color-brand);
        box-shadow: 0 0 0 3px var(--color-brand-lighter);
    }
    .latest-article {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
        align-items: center;
    }
    .latest-label {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-muted);
    }
    .latest-link {
        font-family: var(--font-body);
        font-size: var(--text-body);
        color: var(--color-text);
        text-decoration: none;
        font-weight: 500;
        transition: color 200ms;
    }
    .latest-link:hover { color: var(--color-brand); }
    .latest-meta {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-tertiary);
    }

    /* Game prompt */
    .game-prompt {
        margin-top: var(--space-6);
        opacity: 0;
        transition: opacity 300ms ease;
        margin-bottom: var(--space-6);
    }
    .game-prompt.visible { opacity: 1; }
    .game-prompt-text {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-muted);
        margin: 0;
    }

    /* Game area */
    .game-area {
        display: none;
        position: relative;
        width: 100%;
        height: 240px;
        margin-top: var(--space-6);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        background: var(--color-surface);
        overflow: hidden;
    }
    .game-area.active { display: block; }
    .game-player {
        position: absolute;
        width: 16px;
        height: 16px;
        border: 2px solid var(--color-text);
        border-radius: 2px;
        transition: left 60ms, top 60ms;
    }
    .game-dot {
        position: absolute;
        width: 12px;
        height: 12px;
        background: var(--color-brand);
        border-radius: 50%;
        transition: left 1.5s ease-in-out, top 1.5s ease-in-out;
    }
    .game-score {
        position: absolute;
        top: 8px;
        right: 12px;
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-muted);
    }
    .game-dismiss {
        position: absolute;
        bottom: 8px;
        left: 50%;
        transform: translateX(-50%);
        background: none;
        border: none;
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-muted);
        cursor: pointer;
        text-decoration: underline;
        text-underline-offset: 2px;
    }
    .game-dismiss:hover { color: var(--color-text); }

    /* Dot catch burst */
    @keyframes dot-burst {
        0% { transform: scale(1); opacity: 1; }
        100% { transform: scale(3); opacity: 0; }
    }
    .game-dot.caught {
        animation: dot-burst 300ms ease-out forwards;
    }

    /* Win message */
    .game-win {
        display: none;
        margin-top: var(--space-6);
        text-align: center;
    }
    .game-win.visible { display: flex; flex-direction: column; align-items: center; gap: var(--space-3); margin-bottom: var(--space-8); }
    .game-win p {
        font-family: var(--font-body);
        font-size: var(--text-body);
        color: var(--color-text);
        margin: 0 0 var(--space-3);
    }

    /* Hide game on mobile (keyboard required) */
    @media (max-width: 767px) {
        .game-prompt, .game-area, .game-win { display: none !important; }
    }
</style>

<script>
    document.addEventListener('astro:page-load', () => {
        // Respect reduced motion
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

        const prompt = document.getElementById('game-prompt');
        const area = document.getElementById('game-area');
        const player = document.getElementById('game-player') as HTMLElement | null;
        const dot = document.getElementById('game-dot') as HTMLElement | null;
        const scoreEl = document.getElementById('game-score-value');
        const dismissBtn = document.getElementById('game-dismiss');
        const winEl = document.getElementById('game-win');

        if (!prompt || !area || !player || !dot || !scoreEl || !dismissBtn || !winEl) return;

        let idleTimer: number;
        let gameActive = false;
        let score = 0;
        let playerX = 120;
        let playerY = 110;
        let dotDriftTimer: number;
        const controller = new AbortController();
        const STEP = 12;

        function resetIdleTimer() {
            clearTimeout(idleTimer);
            if (gameActive) return;
            idleTimer = window.setTimeout(() => {
                prompt.classList.add('visible');
            }, 5000);
        }

        // Start idle detection
        [
            // 'mousemove',
        'keydown',
        // 'scroll',
        'click'].forEach(evt => {
            document.addEventListener(evt, resetIdleTimer, { passive: true, signal: controller.signal });
        });
        resetIdleTimer();

        function startGame() {
            gameActive = true;
            prompt.classList.remove('visible');
            area.classList.add('active');
            player.style.left = `${playerX}px`;
            player.style.top = `${playerY}px`;
            placeDot();
            startDotDrift();
        }

        function placeDot() {
            const areaW = area.offsetWidth - 20;
            const areaH = area.offsetHeight - 40;
            dot.classList.remove('caught');
            dot.style.left = `${Math.random() * areaW + 4}px`;
            dot.style.top = `${Math.random() * (areaH - 20) + 4}px`;
        }

        function startDotDrift() {
            dotDriftTimer = window.setInterval(() => {
                const areaW = area.offsetWidth - 20;
                const areaH = area.offsetHeight - 40;
                dot.style.left = `${Math.random() * areaW + 4}px`;
                dot.style.top = `${Math.random() * (areaH - 20) + 4}px`;
            }, 2000);
        }

        function checkCatch() {
            const pr = player.getBoundingClientRect();
            const dr = dot.getBoundingClientRect();
            const overlap = !(pr.right < dr.left || pr.left > dr.right || pr.bottom < dr.top || pr.top > dr.bottom);
            if (overlap) {
                score++;
                scoreEl.textContent = String(score);
                dot.classList.add('caught');
                if (score >= 5) {
                    endGame();
                } else {
                    setTimeout(placeDot, 300);
                }
            }
        }

        function endGame() {
            clearInterval(dotDriftTimer);
            area.classList.remove('active');
            winEl.classList.add('visible');
            gameActive = false;
        }

        function dismissGame() {
            clearInterval(dotDriftTimer);
            area.classList.remove('active');
            prompt.classList.remove('visible');
            gameActive = false;
        }

        document.addEventListener('keydown', (e) => {
            if (!area.classList.contains('active') && prompt.classList.contains('visible') && ['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(e.key)) {
                e.preventDefault();
                startGame();
                return;
            }
            if (!gameActive) return;

            const areaW = area.offsetWidth - 20;
            const areaH = area.offsetHeight - 20;

            switch (e.key) {
                case 'ArrowUp':    e.preventDefault(); playerY = Math.max(0, playerY - STEP); break;
                case 'ArrowDown':  e.preventDefault(); playerY = Math.min(areaH, playerY + STEP); break;
                case 'ArrowLeft':  e.preventDefault(); playerX = Math.max(0, playerX - STEP); break;
                case 'ArrowRight': e.preventDefault(); playerX = Math.min(areaW, playerX + STEP); break;
                case 'Escape':     dismissGame(); return;
                default: return;
            }
            player.style.left = `${playerX}px`;
            player.style.top = `${playerY}px`;
            checkCatch();
        }, { signal: controller.signal });

        dismissBtn.addEventListener('click', dismissGame, { signal: controller.signal });

        document.addEventListener('astro:before-preparation', () => {
            controller.abort();
            clearTimeout(idleTimer);
            clearInterval(dotDriftTimer);
        }, { once: true });
    });
</script>
