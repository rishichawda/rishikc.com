---
import Hero from "../components/landing/hero.astro";
import ArticlesPreview from "../components/landing/articles_preview.astro";
import BitsPreview from "../components/landing/bits_preview.astro";
import GalleryPreview from "../components/landing/gallery_preview.astro";
import QuoteSpotlight from "../components/landing/quote_spotlight.astro";
import CallToAction from "../components/landing/call_to_action.astro";
import Services from "../components/landing/services.astro";
import "../styles/global.css";
import BaseLayout from "../layouts/base_layout.astro";
import favicon from "../../content/assets/logo/logo.png";
import { getCollection } from "astro:content";
import { buildWebPageEntity, personRef } from "../utils/jsonLd";

interface Social { platform: string; url: string; }
interface Position { title: string; }
interface Experience { company: string; positions: Position[]; }
interface ProfileData { name: string; title: string; summary: string; experience: Experience[]; socials: Social[]; }

const profileEntry = await getCollection("profile");
const profile = profileEntry[0].data as ProfileData;

const page_info = {
	title: `${profile.name} — Software Engineer, Writer & Photographer`,
	description: `Portfolio and blog by ${profile.name} — technical articles on web development, React, TypeScript, DevSecOps, photography, and open source projects.`,
	keywords: `${profile.name}, software engineer, web developer, technical articles, React, TypeScript, Astro, DevSecOps, photography, open source`,
};

const siteUrl = new URL(
	Astro.url.pathname,
	Astro.site || "https://rishikc.com",
).toString();

const pageSchemaEntities = [
	buildWebPageEntity({
		url: siteUrl,
		name: page_info.title,
		description: page_info.description,
		mainEntity: personRef,
	}),
];
---

<BaseLayout page_info={page_info} activeRoute="/" pageSchemaEntities={pageSchemaEntities}>
	<div>
		<Hero />
		<Services />
		<ArticlesPreview />
		<GalleryPreview />
		<QuoteSpotlight />
		<CallToAction />
	</div>
</BaseLayout>
