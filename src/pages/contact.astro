---
import BaseLayout from "../layouts/base_layout.astro";
import { getCollection } from "astro:content";
import { buildWebPageEntity, personRef } from "../utils/jsonLd";
import Breadcrumbs from "../components/common/breadcrumbs.astro";

interface Social { platform: string; url: string; }
interface ProfileData { name: string; socials: Social[]; }

const profileEntry = await getCollection("profile");
const profile = profileEntry[0].data as ProfileData;

const page_info = {
  title: `Contact | ${profile.name}`,
  description: `Get in touch with ${profile.name} for collaborations, job opportunities, or general inquiries`,
  keywords: `contact, email, collaboration, ${profile.name}, software engineer`,
};

const pageUrl = new URL(
  Astro.url.pathname,
  Astro.site || "https://rishikc.com",
).toString();

const pageSchemaEntities = [
  buildWebPageEntity({
    type: "ContactPage",
    url: pageUrl,
    name: `Contact ${profile.name}`,
    description: page_info.description,
    mainEntity: personRef,
  }),
];
---

<BaseLayout page_info={page_info} activeRoute="/contact/" pageSchemaEntities={pageSchemaEntities}>

  <div class="contact-page">
    <Breadcrumbs items={[{ label: "Contact" }]} />

    <!-- Page Header -->
    <section class="page-header" data-reveal>
      <span class="overline">SAY HELLO</span>
      <h1 class="page-title">Let's Connect</h1>
      <p class="page-subtitle">Have a project in mind, want to collaborate, or just want to say hello? I'd love to hear from you.</p>
      <p class="response-note">I typically respond within 24–48 hours.</p>
    </section>

    <div class="form-container" data-reveal>
      <!-- Progress Steps -->
      <div class="progress-bar" role="progressbar" aria-valuenow="1" aria-valuemin="1" aria-valuemax="4" aria-label="Form progress: Step 1 of 4">
        <div class="progress-steps">
          <div class="step-dot active" data-step="1"><span>1</span></div>
          <div class="step-line"><div class="step-line-fill"></div></div>
          <div class="step-dot" data-step="2"><span>2</span></div>
          <div class="step-line"><div class="step-line-fill"></div></div>
          <div class="step-dot" data-step="3"><span>3</span></div>
          <div class="step-line"><div class="step-line-fill"></div></div>
          <div class="step-dot" data-step="4"><span>4</span></div>
        </div>
        <div class="progress-labels">
          <span class="step-label active">Topic</span>
          <span class="step-label">About You</span>
          <span class="step-label">Message</span>
          <span class="step-label">Review</span>
        </div>
      </div>

      <form id="contact-form">
        <!-- Honeypot anti-spam -->
        <div class="hp-field" aria-hidden="true">
          <label for="hp-input">Leave empty</label>
          <input type="text" id="hp-input" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <!-- Step 1: Subject -->
        <div class="form-step active" data-form-step="1">
          <h2 class="step-title">What brings you here?</h2>
          <p class="step-desc">Pick the topic that best describes your message.</p>
          <div class="subject-grid" role="radiogroup" aria-label="Select a subject">
            <button type="button" class="subject-card" data-subject="General Inquiry" role="radio" aria-checked="false" tabindex="0">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              <span class="subject-label">General Inquiry</span>
              <span class="subject-hint">Say hi or ask a question</span>
            </button>
            <button type="button" class="subject-card" data-subject="Job Opportunity" role="radio" aria-checked="false" tabindex="-1">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
              <span class="subject-label">Job Opportunity</span>
              <span class="subject-hint">Discuss a role or position</span>
            </button>
            <button type="button" class="subject-card" data-subject="Collaboration" role="radio" aria-checked="false" tabindex="-1">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span class="subject-label">Collaboration</span>
              <span class="subject-hint">Work on something together</span>
            </button>
            <button type="button" class="subject-card" data-subject="Consulting" role="radio" aria-checked="false" tabindex="-1">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <span class="subject-label">Consulting</span>
              <span class="subject-hint">Expert advice on a project</span>
            </button>
            <button type="button" class="subject-card" data-subject="Other" role="radio" aria-checked="false" tabindex="-1">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              <span class="subject-label">Other</span>
              <span class="subject-hint">Something else entirely</span>
            </button>
          </div>
          <input type="hidden" id="subject" name="subject" required />
          <div class="error-text hidden"><span class="error-message"></span></div>
        </div>

        <!-- Step 2: Name & Email -->
        <div class="form-step" data-form-step="2">
          <h2 class="step-title">Tell me about yourself</h2>
          <p class="step-desc">So I know who I'm talking to and how to reach you.</p>
          <div class="form-group">
            <label for="name" class="form-label">Full Name</label>
            <input type="text" id="name" name="from_name" required class="form-input" placeholder="John Doe" />
            <div class="error-text hidden"><span class="error-message"></span></div>
          </div>
          <div class="form-group">
            <label for="email" class="form-label">Email Address</label>
            <input type="email" id="email" name="reply_to" required class="form-input" placeholder="john@example.com" />
            <div class="error-text hidden"><span class="error-message"></span></div>
          </div>
        </div>

        <!-- Step 3: Message -->
        <div class="form-step" data-form-step="3">
          <h2 class="step-title">What's on your mind?</h2>
          <p class="step-desc">The more detail you share, the better I can help.</p>
          <div class="form-group">
            <label for="message" class="form-label">Your Message</label>
            <textarea id="message" name="message" rows="8" required maxlength="2000" class="form-input form-textarea" placeholder="Tell me about your project, idea, or opportunity..."></textarea>
            <div class="textarea-footer">
              <div class="error-text hidden"><span class="error-message"></span></div>
              <span class="char-count" id="char-count" aria-live="polite">0 / 2000</span>
            </div>
          </div>
        </div>

        <!-- Step 4: Review -->
        <div class="form-step" data-form-step="4">
          <h2 class="step-title">Review & Send</h2>
          <p class="step-desc">Take a moment to make sure everything looks good.</p>
          <div class="review-card">
            <div class="review-field">
              <span class="review-label">Subject</span>
              <span class="review-value" id="review-subject"></span>
            </div>
            <div class="review-field">
              <span class="review-label">Name</span>
              <span class="review-value" id="review-name"></span>
            </div>
            <div class="review-field">
              <span class="review-label">Email</span>
              <span class="review-value" id="review-email"></span>
            </div>
            <div class="review-field review-field-message">
              <span class="review-label">Message</span>
              <p class="review-value review-message" id="review-message"></p>
            </div>
          </div>
        </div>

        <!-- Navigation -->
        <div class="form-nav">
          <button type="button" id="prev-btn" class="nav-btn nav-prev" style="visibility: hidden;" aria-label="Back to: Topic (Step 1 of 4)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back
          </button>
          <button type="button" id="next-btn" class="nav-btn nav-next" aria-label="Continue to: About You (Step 2 of 4)">
            Continue
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
          <button type="submit" id="submit-button" class="nav-btn nav-submit" style="display: none;">
            Send Message
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </div>
      </form>

      <!-- Success State -->
      <div id="success-state" class="success-state hidden" role="status">
        <svg class="success-checkmark" viewBox="0 0 52 52" aria-hidden="true">
          <circle class="checkmark-circle" cx="26" cy="26" r="24" fill="none" stroke="currentColor" stroke-width="2" />
          <path class="checkmark-check" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" d="M14 27l7 7 16-16" />
        </svg>
        <h3 class="success-title">Message Sent!</h3>
        <p class="success-text">Thanks for reaching out. I'll get back to you within 24–48 hours.</p>
        <button type="button" id="send-another" class="send-another-link">Send Another Message</button>
      </div>

      <!-- Error State -->
      <div id="error-message" class="status-msg status-error hidden" role="alert">
        There was an error sending your message. Please try again.
      </div>
    </div>

    <!-- Social links -->
    <div class="contact-footer" data-reveal>
      <p class="footer-text">You can also find me on</p>
      <div class="social-links">
        {profile.socials.filter((s: Social) => ['GitHub', 'LinkedIn', 'Instagram'].includes(s.platform)).map((social: Social) => (
          <a href={social.url} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={`${social.platform} (opens in new tab)`}>
            {social.platform === 'GitHub' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            )}
            {social.platform === 'LinkedIn' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            )}
            {social.platform === 'Instagram' && (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            )}
            <span>{social.platform}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-page {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  /* Page Header */
  .page-header {
    max-width: 720px;
    margin: 0 auto;
    padding: var(--space-20) 0 var(--space-8);
    text-align: center;
  }
  .overline {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }
  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-4);
    line-height: 1.1;
    letter-spacing: -0.025em;
  }
  .page-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    max-width: 560px;
    margin: 0 auto var(--space-3);
    line-height: 1.6;
  }
  .response-note {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Form Container */
  .form-container {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 40px;
    margin-bottom: var(--space-12);
  }

  /* Progress */
  .progress-bar { margin-bottom: var(--space-10); }
  .progress-steps {
    display: flex;
    align-items: center;
    gap: 0;
  }
  .step-dot {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-bg-alt);
    border: 2px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-muted);
    transition: all 300ms;
    flex-shrink: 0;
  }
  .step-dot.active {
    background: var(--color-brand);
    border-color: var(--color-brand);
    color: #fff;
  }
  .step-dot.completed {
    background: var(--color-brand);
    border-color: var(--color-brand);
    color: #fff;
  }
  .step-line {
    flex: 1;
    height: 2px;
    background: var(--color-border);
    position: relative;
    overflow: hidden;
  }
  .step-line-fill {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 0;
    background: var(--color-brand);
    transition: width 400ms ease;
  }
  .progress-labels {
    display: flex;
    justify-content: space-between;
    margin-top: var(--space-2);
    padding: 0 2px;
  }
  .step-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-muted);
    text-align: center;
    width: 32px;
    white-space: nowrap;
    transition: color 200ms;
  }
  .step-label.active { color: var(--color-brand-dark); font-weight: 600; }

  /* Form Steps */
  .form-step {
    display: none;
    min-height: 280px;
  }
  .form-step.active { display: block; }
  .step-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
    line-height: 1.2;
  }
  .step-desc {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-8);
    line-height: 1.6;
  }

  /* Subject Grid */
  .subject-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
  }
  .subject-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-5);
    border: 1.5px solid var(--color-border);
    border-radius: 14px;
    background: transparent;
    cursor: pointer;
    text-align: left;
    transition: all 200ms;
    color: var(--color-text);
  }
  .subject-card:hover {
    border-color: var(--color-brand-light);
    background: var(--color-bg-alt);
  }
  .subject-card.selected {
    border-color: var(--color-brand);
    background: var(--color-brand-lighter);
  }
  .subject-card svg { color: var(--color-brand); flex-shrink: 0; }
  .subject-label {
    font-family: var(--font-ui);
    font-size: var(--text-body-sm);
    font-weight: 600;
    color: var(--color-text);
  }
  .subject-hint {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-tertiary);
    line-height: 1.4;
  }
  @media (max-width: 480px) {
    .subject-grid { grid-template-columns: 1fr; }
  }

  /* Honeypot */
  .hp-field {
    position: absolute;
    left: -9999px;
    top: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
    overflow: hidden;
  }

  /* Form Elements */
  .form-group { margin-bottom: var(--space-5); }
  .form-label {
    display: block;
    font-family: var(--font-ui);
    font-size: var(--text-body-sm);
    font-weight: 600;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2);
  }
  .form-input {
    width: 100%;
    padding: 12px 16px;
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text);
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: 12px;
    outline: none;
    transition: border-color 200ms, box-shadow 200ms;
    box-sizing: border-box;
  }
  .form-input::placeholder { color: var(--color-text-muted); }
  .form-input:focus {
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px var(--color-brand-lighter);
  }
  .form-input.is-valid { border-color: #10b981; }
  .form-input.is-valid:focus { box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.15); }
  .form-input.is-invalid { border-color: #ef4444; }
  .form-input.is-invalid:focus { box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.15); }
  .form-textarea { resize: vertical; min-height: 160px; }
  .textarea-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-top: var(--space-2);
  }
  .char-count {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    margin-left: auto;
    flex-shrink: 0;
  }
  .char-count.near-limit { color: #f59e0b; }
  .char-count.at-limit { color: #ef4444; }

  /* Error */
  .error-text {
    font-family: var(--font-ui);
    font-size: 13px;
    color: #ef4444;
    margin-top: var(--space-2);
  }
  .error-text.hidden { display: none; }

  /* Review Card */
  .review-card {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: var(--space-6);
  }
  .review-field {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .review-field:last-child { border-bottom: none; }
  .review-field-message { flex-direction: column; }
  .review-label {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    min-width: 80px;
    flex-shrink: 0;
  }
  .review-value {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text);
  }
  .review-message {
    margin: var(--space-2) 0 0;
    white-space: pre-wrap;
    line-height: 1.6;
  }

  /* Navigation */
  .form-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-8);
    gap: var(--space-4);
  }
  .nav-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--text-body);
    font-weight: 600;
    padding: 12px 24px;
    border-radius: 12px;
    border: none;
    cursor: pointer;
    transition: all 200ms;
  }
  .nav-prev {
    background: transparent;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
  }
  .nav-prev:hover { border-color: var(--color-text-secondary); }
  .nav-next, .nav-submit {
    background: var(--btn-bg);
    color: #fff;
    margin-left: auto;
  }
  .nav-next:hover, .nav-submit:hover {
    filter: brightness(0.9);
    transform: translateY(-1px);
  }
  .nav-submit:disabled { opacity: 0.6; cursor: not-allowed; }

  /* Status Messages */
  .status-msg {
    padding: 16px 20px;
    border-radius: 12px;
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    text-align: center;
    line-height: 1.5;
    margin-top: var(--space-5);
  }
  .status-msg.hidden { display: none; }
  .status-error {
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.2);
    color: #dc2626;
  }

  /* Success State */
  .success-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-12) var(--space-6);
    min-height: 320px;
  }
  .success-state.hidden { display: none; }
  .success-checkmark {
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    color: var(--color-brand);
    margin-bottom: var(--space-5);
  }
  .checkmark-circle {
    stroke-dasharray: 150;
    stroke-dashoffset: 150;
    animation: checkmark-circle-draw 600ms ease-out forwards;
  }
  .checkmark-check {
    stroke-dasharray: 50;
    stroke-dashoffset: 50;
    animation: checkmark-draw 400ms ease-out 400ms forwards;
  }
  @keyframes checkmark-circle-draw { to { stroke-dashoffset: 0; } }
  @keyframes checkmark-draw { to { stroke-dashoffset: 0; } }
  .success-title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-2);
  }
  .success-text {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-6);
  }
  .send-another-link {
    font-family: var(--font-ui);
    font-size: var(--text-body-sm);
    color: var(--color-brand);
    background: none;
    border: none;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Contact Footer */
  .contact-footer {
    text-align: center;
    padding-bottom: var(--space-20);
  }
  .footer-text {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
  }
  .social-links {
    display: flex;
    justify-content: center;
    gap: var(--space-5);
  }
  .social-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: var(--text-body-sm);
    transition: color 200ms;
  }
  .social-link:hover { color: var(--color-brand); }

  @media (max-width: 640px) {
    .form-container { padding: 24px; }
    .form-nav { flex-wrap: wrap; }
  }
</style>

<script>
  import emailjs from '@emailjs/browser';
  import gsap from 'gsap';

  const emailJSPublicKey = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY;
  const emailJSServiceID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID;
  const emailJSTemplateID = import.meta.env.PUBLIC_EMAILJS_TEMPLATE_ID;

  function setUpForm() {
    emailjs.init(emailJSPublicKey);

    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    if (!form || form.dataset.initialized) return;
    form.dataset.initialized = "true";

    const steps = document.querySelectorAll<HTMLElement>('.form-step');
    const dots = document.querySelectorAll<HTMLElement>('.step-dot');
    const labels = document.querySelectorAll<HTMLElement>('.step-label');
    const lineFills = document.querySelectorAll<HTMLElement>('.step-line-fill');
    const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
    const submitBtn = document.getElementById('submit-button') as HTMLButtonElement;
    const successState = document.getElementById("success-state")!;
    const errorMessageEl = document.getElementById("error-message")!;
    const sendAnother = document.getElementById("send-another")!;
    const honeypot = document.getElementById("hp-input") as HTMLInputElement;
    const subjectInput = document.getElementById("subject") as HTMLInputElement;

    let currentStep = 1;
    const totalSteps = 4;
    const stepNames = ['Topic', 'About You', 'Message', 'Review'];
    const formLoadTime = Date.now();

    // Character count
    const textarea = document.getElementById('message') as HTMLTextAreaElement | null;
    const charCountEl = document.getElementById('char-count');
    if (textarea && charCountEl) {
      const maxLen = textarea.maxLength || 2000;
      const updateCount = () => {
        const len = textarea.value.length;
        charCountEl.textContent = `${len} / ${maxLen}`;
        charCountEl.classList.toggle('near-limit', len >= maxLen * 0.85 && len < maxLen);
        charCountEl.classList.toggle('at-limit', len >= maxLen);
      };
      textarea.addEventListener('input', updateCount);
      updateCount();
    }

    // Subject card selection
    const subjectCards = Array.from(document.querySelectorAll<HTMLButtonElement>('.subject-card'));
    function selectSubjectCard(card: HTMLButtonElement) {
      subjectCards.forEach(c => {
        c.classList.remove('selected');
        c.setAttribute('aria-checked', 'false');
        c.setAttribute('tabindex', '-1');
      });
      card.classList.add('selected');
      card.setAttribute('aria-checked', 'true');
      card.setAttribute('tabindex', '0');
      card.focus();
      subjectInput.value = card.getAttribute('data-subject') || '';
      // Clear error
      const errorEl = card.closest('.form-step')?.querySelector('.error-text');
      if (errorEl) errorEl.classList.add('hidden');
    }
    subjectCards.forEach(card => {
      card.addEventListener('click', () => selectSubjectCard(card));
    });

    // Arrow key navigation for radiogroup
    const radioGroup = document.querySelector('.subject-grid[role="radiogroup"]');
    if (radioGroup) {
      radioGroup.addEventListener('keydown', (e: Event) => {
        const event = e as KeyboardEvent;
        const keys = ['ArrowDown', 'ArrowRight', 'ArrowUp', 'ArrowLeft'];
        if (!keys.includes(event.key)) return;
        event.preventDefault();
        const currentIndex = subjectCards.indexOf(document.activeElement as HTMLButtonElement);
        if (currentIndex === -1) return;
        let nextIndex: number;
        if (event.key === 'ArrowDown' || event.key === 'ArrowRight') {
          nextIndex = (currentIndex + 1) % subjectCards.length;
        } else {
          nextIndex = (currentIndex - 1 + subjectCards.length) % subjectCards.length;
        }
        selectSubjectCard(subjectCards[nextIndex]);
      });
    }

    function goToStep(step: number) {
      const prevStep = currentStep;
      currentStep = step;

      // Animate step transition
      const outgoing = document.querySelector(`[data-form-step="${prevStep}"]`) as HTMLElement;
      const incoming = document.querySelector(`[data-form-step="${step}"]`) as HTMLElement;
      const direction = step > prevStep ? 1 : -1;

      if (outgoing && incoming) {
        gsap.to(outgoing, {
          opacity: 0,
          x: -30 * direction,
          duration: 0.2,
          ease: 'power2.in',
          onComplete: () => {
            outgoing.classList.remove('active');
            incoming.classList.add('active');
            gsap.fromTo(incoming,
              { opacity: 0, x: 30 * direction },
              { opacity: 1, x: 0, duration: 0.3, ease: 'power2.out' }
            );
          }
        });
      }

      // Update progress
      dots.forEach((dot, i) => {
        const s = i + 1;
        dot.classList.toggle('active', s === step);
        dot.classList.toggle('completed', s < step);
      });
      labels.forEach((label, i) => {
        label.classList.toggle('active', i + 1 === step);
      });
      lineFills.forEach((fill, i) => {
        fill.style.width = (i + 1 < step) ? '100%' : '0%';
      });

      // Update navigation
      prevBtn.style.visibility = step === 1 ? 'hidden' : 'visible';
      if (step === totalSteps) {
        nextBtn.style.display = 'none';
        submitBtn.style.display = 'inline-flex';
        populateReview();
      } else {
        nextBtn.style.display = 'inline-flex';
        submitBtn.style.display = 'none';
      }

      // Update ARIA attributes for progress bar and nav buttons
      const progressBar = document.querySelector('.progress-bar') as HTMLElement;
      if (progressBar) {
        progressBar.setAttribute('aria-valuenow', String(step));
        progressBar.setAttribute('aria-label', `Form progress: Step ${step} of ${totalSteps}`);
      }
      if (step > 1) {
        prevBtn.setAttribute('aria-label', `Back to: ${stepNames[step - 2]} (Step ${step - 1} of ${totalSteps})`);
      }
      if (step < totalSteps) {
        nextBtn.setAttribute('aria-label', `Continue to: ${stepNames[step]} (Step ${step + 1} of ${totalSteps})`);
      }

      // Focus first input in step
      setTimeout(() => {
        const firstInput = incoming?.querySelector<HTMLElement>('input:not([type="hidden"]), textarea, select, .subject-card');
        if (firstInput) firstInput.focus();
      }, 350);
    }

    function populateReview() {
      const reviewSubject = document.getElementById('review-subject');
      const reviewName = document.getElementById('review-name');
      const reviewEmail = document.getElementById('review-email');
      const reviewMessage = document.getElementById('review-message');
      if (reviewSubject) reviewSubject.textContent = subjectInput.value;
      if (reviewName) reviewName.textContent = (document.getElementById('name') as HTMLInputElement).value;
      if (reviewEmail) reviewEmail.textContent = (document.getElementById('email') as HTMLInputElement).value;
      if (reviewMessage) reviewMessage.textContent = (document.getElementById('message') as HTMLTextAreaElement).value;
    }

    const formFields: Record<string, { validator: (v: string) => boolean; errorMessage: string; emptyMessage?: string }> = {
      name: {
        validator: (value: string) => value.trim() !== "",
        errorMessage: "Please enter your name",
      },
      email: {
        validator: (value: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value),
        errorMessage: "Please enter a valid email address",
        emptyMessage: "Please enter your email address",
      },
      message: {
        validator: (value: string) => value.trim() !== "",
        errorMessage: "Please enter your message",
      },
    };

    function validateField(fieldId: string, showError = true): boolean {
      const field = document.getElementById(fieldId) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement;
      const fieldConfig = formFields[fieldId];
      if (!fieldConfig) return true;

      const formGroup = field.closest('.form-group') || field.parentElement;
      const errorElement = formGroup?.querySelector('.error-text') as HTMLElement | null;

      let isValid = true;
      let message = "";

      if (fieldId === "email" && !field.value.trim()) {
        isValid = false;
        message = fieldConfig.emptyMessage || fieldConfig.errorMessage;
      } else if (!fieldConfig.validator(field.value)) {
        isValid = false;
        message = fieldConfig.errorMessage;
      }

      if (showError && errorElement) {
        if (!isValid) {
          const span = errorElement.querySelector('.error-message');
          if (span) span.textContent = message;
          errorElement.classList.remove("hidden");
          field.classList.remove("is-valid");
          field.classList.add("is-invalid");
          field.setAttribute("aria-invalid", "true");
        } else {
          errorElement.classList.add("hidden");
          field.classList.remove("is-invalid");
          field.classList.add("is-valid");
          field.setAttribute("aria-invalid", "false");
        }
      }
      return isValid;
    }

    function validateStep(step: number): boolean {
      if (step === 1) {
        if (!subjectInput.value) {
          const errorEl = document.querySelector('[data-form-step="1"] .error-text');
          const span = errorEl?.querySelector('.error-message');
          if (span) span.textContent = 'Please select a subject';
          if (errorEl) errorEl.classList.remove('hidden');
          return false;
        }
        return true;
      }
      if (step === 2) {
        const nameValid = validateField('name', true);
        const emailValid = validateField('email', true);
        return nameValid && emailValid;
      }
      if (step === 3) {
        return validateField('message', true);
      }
      return true;
    }

    // Real-time validation
    form.addEventListener("input", (e: Event) => {
      const target = e.target as HTMLElement;
      if (target.id && formFields[target.id]) validateField(target.id);
    });
    form.addEventListener("blur", (e: Event) => {
      const target = e.target as HTMLElement;
      if (target.id && formFields[target.id]) validateField(target.id);
    }, true);

    nextBtn.addEventListener('click', () => {
      if (validateStep(currentStep) && currentStep < totalSteps) {
        goToStep(currentStep + 1);
      }
    });

    prevBtn.addEventListener('click', () => {
      if (currentStep > 1) goToStep(currentStep - 1);
    });

    // Keyboard: Enter to advance (except textarea)
    form.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' && (e.target as HTMLElement).tagName !== 'TEXTAREA') {
        e.preventDefault();
        if (currentStep < totalSteps) {
          if (validateStep(currentStep)) goToStep(currentStep + 1);
        }
      }
    });

    form.addEventListener("submit", (event: Event) => {
      event.preventDefault();

      if (honeypot && honeypot.value) return;
      if (Date.now() - formLoadTime < 2000) return;

      submitBtn.disabled = true;
      submitBtn.textContent = "Sending...";
      submitBtn.setAttribute("aria-busy", "true");

      const templateParams = {
        from_name: (document.getElementById("name") as HTMLInputElement).value,
        reply_to: (document.getElementById("email") as HTMLInputElement).value,
        subject: subjectInput.value,
        message: (document.getElementById("message") as HTMLTextAreaElement).value,
      };

      emailjs
        .send(emailJSServiceID, emailJSTemplateID, templateParams)
        .then(() => {
          submitBtn.textContent = "Send Message";
          submitBtn.disabled = false;
          submitBtn.setAttribute("aria-busy", "false");
          form.reset();
          document.querySelectorAll('.subject-card').forEach((c, i) => {
            c.classList.remove('selected');
            c.setAttribute('aria-checked', 'false');
            c.setAttribute('tabindex', i === 0 ? '0' : '-1');
          });

          errorMessageEl.classList.add("hidden");

          gsap.to(form, {
            opacity: 0,
            y: -10,
            duration: 0.3,
            ease: 'power2.inOut',
            onComplete: () => {
              form.style.display = 'none';
              // Hide progress bar too
              const progressBar = document.querySelector('.progress-bar') as HTMLElement;
              if (progressBar) progressBar.style.display = 'none';
              successState.classList.remove('hidden');
              gsap.fromTo(successState,
                { opacity: 0, y: 10 },
                { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }
              );
            }
          });
        })
        .catch((error: Error) => {
          console.error("EmailJS error:", error);
          submitBtn.textContent = "Send Message";
          submitBtn.disabled = false;
          submitBtn.setAttribute("aria-busy", "false");
          errorMessageEl.classList.remove("hidden");
        });
    });

    sendAnother.addEventListener('click', () => {
      gsap.to(successState, {
        opacity: 0,
        y: -10,
        duration: 0.3,
        ease: 'power2.inOut',
        onComplete: () => {
          successState.classList.add('hidden');
          form.style.display = '';
          const progressBar = document.querySelector('.progress-bar') as HTMLElement;
          if (progressBar) progressBar.style.display = '';
          // Reset to step 1
          currentStep = 1;
          steps.forEach((s, i) => s.classList.toggle('active', i === 0));
          dots.forEach((d, i) => { d.classList.toggle('active', i === 0); d.classList.remove('completed'); });
          labels.forEach((l, i) => l.classList.toggle('active', i === 0));
          lineFills.forEach(f => f.style.width = '0%');
          prevBtn.style.visibility = 'hidden';
          nextBtn.style.display = 'inline-flex';
          submitBtn.style.display = 'none';

          // Reset ARIA attributes
          if (progressBar) {
            progressBar.setAttribute('aria-valuenow', '1');
            progressBar.setAttribute('aria-label', 'Form progress: Step 1 of 4');
          }
          nextBtn.setAttribute('aria-label', `Continue to: ${stepNames[1]} (Step 2 of ${totalSteps})`);
          prevBtn.setAttribute('aria-label', `Back to: ${stepNames[0]} (Step 1 of ${totalSteps})`);

          gsap.fromTo(form,
            { opacity: 0, y: 10 },
            { opacity: 1, y: 0, duration: 0.4, ease: 'power2.out' }
          );
        }
      });
    });
  }

  document.addEventListener("DOMContentLoaded", setUpForm);
  document.addEventListener("astro:page-load", setUpForm);
</script>
