---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/base_layout.astro";
import { Image } from "astro:assets";
import { buildWebPageEntity } from "../../../utils/jsonLd";
import { getAllSeries, getSeriesSlug } from "../../../utils/seriesUtils";
import Breadcrumbs from "../../../components/common/breadcrumbs.astro";

interface Social { platform: string; url: string; }
interface ProfileData { name: string; socials: Social[]; }

export async function getStaticPaths() {
    const allArticles = await getCollection("articles");
    const seriesCollection = await getCollection("series");
    const allSeries = getAllSeries(allArticles);

    return allSeries.map((series) => {
        const slug = getSeriesSlug(series.seriesTitle);
        const seriesData = seriesCollection.find(
            (s) => s.data.title === series.seriesTitle
        );
        return {
            params: { slug },
            props: { series, seriesData },
        };
    });
}

const { series, seriesData } = Astro.props;

const profileEntry = await getCollection("profile");
const profile = profileEntry[0].data as ProfileData;

const description = seriesData?.data.description
    || `A ${series.totalParts}-part series exploring ${series.seriesTitle.toLowerCase()} in depth.`;

const page_info = {
    title: `${series.seriesTitle} | ${profile.name}`,
    description,
    keywords: seriesData?.data.keywords || series.seriesTitle.toLowerCase(),
};

function formatDate(date: Date): string {
    return new Date(date).toLocaleDateString("en-US", {
        day: "numeric",
        month: "long",
        year: "numeric",
    });
}

const pageUrl = new URL(
    Astro.url.pathname,
    Astro.site || "https://rishikc.com",
).toString();

const pageSchemaEntities = [
    buildWebPageEntity({
        type: "CollectionPage",
        url: pageUrl,
        name: series.seriesTitle,
        description,
        mainEntity: {
            "@type": "CreativeWorkSeries",
            name: series.seriesTitle,
            hasPart: series.articles.map((article) => ({
                "@type": article.data.jsonld_schema || "Article",
                name: article.data.title,
                url: new URL(
                    article.data.path,
                    Astro.site || "https://rishikc.com"
                ).toString(),
            })),
        },
    }),
];
---

<BaseLayout page_info={page_info} activeRoute="/articles/" pageSchemaEntities={pageSchemaEntities}>
    <div>
        <Breadcrumbs items={[
            { label: "Articles", href: "/articles/" },
            { label: "Series", href: "/articles/series/" },
            { label: series.seriesTitle },
        ]} />

        <section class="page-header" data-reveal>
            <h1 class="page-title">{series.seriesTitle}</h1>
            <p class="page-subtitle">{description}</p>
            <div class="series-meta-bar">
                <span class="series-meta-item">{series.totalParts} parts</span>
                {series.isOngoing && (
                    <span class="ongoing-badge">Ongoing</span>
                )}
            </div>
        </section>

        <section class="series-content">
            <div class="journey-timeline">
                {series.articles.map((article, index) => (
                    <a href={article.data.path} class:list={["journey-item", index % 2 === 1 ? "journey-item--alt" : ""]}>
                        <div class="journey-connector" aria-hidden="true">
                            <div class="journey-dot">{index + 1}</div>
                            {index < series.articles.length - 1 && <div class="journey-line"></div>}
                        </div>
                        <div class="journey-content">
                            {article.data.hero_image && (
                                <div class="journey-image">
                                    <Image
                                        src={article.data.hero_image}
                                        alt={article.data.hero_image_alt || article.data.title}
                                        width={480}
                                        height={270}
                                        class="journey-img"
                                    />
                                </div>
                            )}
                            <div class="journey-body">
                                <span class="journey-part">Part {index + 1}</span>
                                <h2 class="journey-title">{article.data.title}</h2>
                                <p class="journey-desc">{article.data.description}</p>
                                <div class="journey-meta">
                                    <time datetime={article.data.date.toISOString()}>{formatDate(article.data.date)}</time>
                                    <span class="journey-read-link">Read article <span class="arrow">&rarr;</span></span>
                                </div>
                            </div>
                        </div>
                    </a>
                ))}
            </div>

            <div class="series-start-cta">
                <a href={series.articles[0]?.data.path} class="start-reading-btn">
                    Start Reading from Part 1
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                    </svg>
                </a>
            </div>
        </section>
    </div>
</BaseLayout>

<style>
    .page-header {
        max-width: 720px;
        margin: 0 auto;
        padding: var(--space-20) var(--space-6) var(--space-12);
        text-align: center;
    }
    .page-title {
        font-family: var(--font-display);
        font-size: var(--text-display-lg);
        font-weight: 700;
        color: var(--color-text);
        margin: 0 0 var(--space-4);
        line-height: 1.1;
    }
    .page-subtitle {
        font-family: var(--font-body);
        font-size: var(--text-body-lg);
        color: var(--color-text-secondary);
        max-width: 560px;
        margin: 0 auto var(--space-6);
        line-height: 1.6;
    }
    .series-meta-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-3);
    }
    .series-meta-item {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-muted);
    }
    .ongoing-badge {
        font-family: var(--font-ui);
        font-size: 11px;
        padding: 2px 8px;
        border-radius: 9999px;
        background: #FEF3C7;
        color: #92400E;
    }
    [data-theme="dark"] .ongoing-badge {
        background: rgba(245, 158, 11, 0.15);
        color: #FBBF24;
    }

    /* Series Content */
    .series-content {
        max-width: 960px;
        margin: 0 auto;
        padding: 0 var(--space-6) var(--space-20);
    }

    /* Journey Timeline */
    .journey-timeline {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .journey-item {
        display: grid;
        grid-template-columns: 40px 1fr;
        gap: var(--space-6);
        text-decoration: none;
        color: inherit;
        padding: var(--space-4) 0;
        transition: transform 200ms;
    }
    .journey-item:hover {
        transform: translateX(4px);
    }
    .journey-item:hover .journey-title {
        color: var(--color-brand-dark);
    }

    .journey-connector {
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .journey-dot {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: var(--color-brand-lighter);
        color: var(--color-brand-dark);
        font-family: var(--font-display);
        font-size: 14px;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background 200ms, color 200ms;
    }
    .journey-item:hover .journey-dot {
        background: var(--btn-bg);
        color: #fff;
    }
    .journey-line {
        width: 2px;
        flex: 1;
        background: var(--color-border);
        margin-top: var(--space-2);
    }

    .journey-content {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-4);
        padding-bottom: var(--space-6);
        border-bottom: 1px solid var(--color-border);
    }
    .journey-item:last-child .journey-content {
        border-bottom: none;
        padding-bottom: 0;
    }

    @media (min-width: 768px) {
        .journey-content {
            grid-template-columns: 200px 1fr;
            gap: var(--space-6);
        }
        .journey-item--alt .journey-content {
            grid-template-columns: 1fr 200px;
        }
        .journey-item--alt .journey-image {
            order: 2;
        }
        .journey-item--alt .journey-body {
            order: 1;
        }
    }

    .journey-image {
        border-radius: 12px;
        overflow: hidden;
    }
    .journey-img {
        width: 100%;
        height: auto;
        object-fit: cover;
        border-radius: 12px;
        transition: transform 400ms ease;
    }
    .journey-item:hover .journey-img {
        transform: scale(1.03);
    }

    .journey-body {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .journey-part {
        font-family: var(--font-mono);
        font-size: var(--text-overline);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--color-brand-dark);
        margin-bottom: var(--space-1);
    }
    .journey-title {
        font-family: var(--font-display);
        font-size: var(--text-h3);
        font-weight: 600;
        color: var(--color-text);
        margin: 0 0 var(--space-2);
        line-height: 1.3;
        letter-spacing: -0.01em;
        transition: color 200ms;
    }
    .journey-desc {
        font-family: var(--font-body);
        font-size: var(--text-body-sm);
        color: var(--color-text-secondary);
        margin: 0 0 var(--space-3);
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .journey-meta {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-tertiary);
        display: flex;
        align-items: center;
        gap: var(--space-3);
    }
    .journey-read-link {
        color: var(--color-brand-dark);
        font-family: var(--font-ui);
        font-weight: 500;
    }
    .journey-read-link .arrow {
        display: inline-block;
        transition: transform 200ms;
    }
    .journey-item:hover .journey-read-link .arrow {
        transform: translateX(4px);
    }

    /* Start Reading CTA */
    .series-start-cta {
        text-align: center;
        margin-top: var(--space-8);
    }
    .start-reading-btn {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        font-family: var(--font-ui);
        font-size: var(--text-body);
        font-weight: 600;
        padding: 12px 28px;
        border-radius: 12px;
        background: var(--btn-bg);
        color: #fff;
        text-decoration: none;
        transition: filter 200ms, transform 200ms;
    }
    .start-reading-btn:hover {
        filter: brightness(0.9);
        transform: translateY(-1px);
    }

    @media (max-width: 767px) {
        .journey-item { grid-template-columns: 28px 1fr; gap: var(--space-3); }
        .journey-dot { width: 28px; height: 28px; font-size: 12px; }
        .journey-item:hover { transform: none; }
    }
</style>
