---
import { getCollection, render } from "astro:content";
import BlogPost from "../../layouts/article.astro";
import Prose from "../../components/article/prose.astro";
import RelatedArticles from "../../components/article/related_articles.astro";
import BaseLayout from "../../layouts/base_layout.astro";
import TableOfContents from "../../components/article/table_of_contents.astro";
import ExternalLink from "../../components/article/ExternalLink.astro";
import SeriesNavigation from "../../components/article/series_navigation.astro";
import { getSeriesInfo, getSeriesTitle } from "../../utils/seriesUtils";
import { buildWebPageEntity, personRef } from "../../utils/jsonLd";
import "remark-notes-plugin/styles.css";

export async function getStaticPaths() {
	let posts = await getCollection("articles");

	return posts.map((post) => {
		return {
			params: { slug: post.id },
			props: { post, allPosts: posts },
		};
	});
}

const { post, allPosts } = Astro.props;
const { Content, remarkPluginFrontmatter, headings } = await render(post);

// Sort all posts by date for prev/next navigation
const sorted = [...allPosts].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const currentIndex = sorted.findIndex((p) => p.id === post.id);
const prevPost = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sorted[currentIndex - 1] : null;

// Series info
const seriesInfo = getSeriesInfo(post, allPosts);
const seriesTitle = post.data.series ? getSeriesTitle(post.data.series) : "";

// Build JSON-LD entities for the @graph
const articleUrl = new URL(
	post.data.path || Astro.url.pathname,
	Astro.site || "https://rishikc.com",
).toString();
const imageUrl = post.data.hero_image?.src
	? new URL(post.data.hero_image.src, Astro.site || "https://rishikc.com").toString()
	: "";
const isoDate = post.data.date ? post.data.date.toISOString() : "";
const isoDateModified = post.data.dateModified ? new Date(post.data.dateModified).toISOString() : isoDate;

const articleEntity: Record<string, unknown> = {
	"@type": post.data.jsonld_schema || "Article",
	"@id": `${articleUrl}#article`,
	headline: post.data.title,
	description: post.data.description,
	image: imageUrl,
	datePublished: isoDate,
	dateModified: isoDateModified,
	author: personRef,
	publisher: personRef,
	mainEntityOfPage: { "@id": articleUrl },
	keywords: post.data.tags,
	...(post.data.category ? { articleSection: post.data.category } : {}),
	...(remarkPluginFrontmatter?.minutesRead ? {
		wordCount: Math.round(parseInt(remarkPluginFrontmatter.minutesRead, 10) * 250),
	} : {}),
	speakable: {
		"@type": "SpeakableSpecification",
		cssSelector: [".article-title", ".article-subtitle", ".article-meta"],
	},
};

const pageSchemaEntities: Record<string, unknown>[] = [
	buildWebPageEntity({
		url: articleUrl,
		name: post.data.title,
		description: post.data.description,
		dateModified: isoDateModified,
		mainEntity: { "@id": `${articleUrl}#article` },
	}),
	articleEntity,
];

// Add FAQ entity if present
if (post.data.faq && post.data.faq.length > 0) {
	pageSchemaEntities.push({
		"@type": "FAQPage",
		"@id": `${articleUrl}#faq`,
		mainEntity: post.data.faq.map((item: { question: string; answer: string }) => ({
			"@type": "Question",
			name: item.question,
			acceptedAnswer: { "@type": "Answer", text: item.answer },
		})),
	});
}
---

<BaseLayout
	page_info={{
		title: `${post.data.title} | Rishi Kumar Chawda`,
		description: post.data.description,
		image: imageUrl,
		keywords: post.data.keywords,
		type: "article",
		datePublished: post.data.date.toISOString(),
		dateModified: post.data.dateModified ? new Date(post.data.dateModified).toISOString() : post.data.date.toISOString(),
		tags: post.data.tags,
	}}
	activeRoute="/articles/"
	pageSchemaEntities={pageSchemaEntities}
>
	<div class="article-page">
		<BlogPost content={post.data} frontmatter={remarkPluginFrontmatter}>
			<TableOfContents headings={headings} />
			<Prose>
				<Content components={{ a: ExternalLink }} />
			</Prose>
		</BlogPost>

		<!-- Series Navigation -->
		{seriesInfo && (
			<div class="series-nav-wrapper" aria-label="Series navigation">
				<SeriesNavigation seriesInfo={seriesInfo} seriesTitle={seriesTitle} />
			</div>
		)}

		<!-- Related Articles -->
		<RelatedArticles currentArticle={post} allArticles={allPosts} />

		<!-- Prev / Next Navigation -->
		<nav class="article-nav" aria-label="Article navigation">
			{prevPost ? (
				<a href={prevPost.data.path} class="nav-card prev">
					<span class="nav-label">&larr; Previous</span>
					<span class="nav-title">{prevPost.data.title}</span>
				</a>
			) : <div />}
			{nextPost ? (
				<a href={nextPost.data.path} class="nav-card next">
					<span class="nav-label">Next &rarr;</span>
					<span class="nav-title">{nextPost.data.title}</span>
				</a>
			) : <div />}
		</nav>
	</div>
</BaseLayout>

<style>
	.article-page {
		display: flex;
		flex-direction: column;
		align-items: center;
		padding-top: var(--space-10);
	}

	.series-nav-wrapper {
		max-width: 920px;
		width: 100%;
		padding: 0 var(--space-6);
		margin: 0 auto;
	}

	/* Prev / Next Nav */
	.article-nav {
		max-width: 720px;
		width: 100%;
		margin: 0 auto;
		padding: var(--space-12) var(--space-6) var(--space-20);
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-4);
	}
	.nav-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		padding: var(--space-5);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 12px;
		text-decoration: none;
		color: inherit;
		transition: transform 200ms, box-shadow 200ms;
	}
	.nav-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-elevated);
	}
	.nav-card.next { text-align: right; }
	.nav-label {
		font-family: var(--font-mono);
		font-size: var(--text-caption);
		color: var(--color-text-tertiary);
	}
	.nav-title {
		font-family: var(--font-body);
		font-size: var(--text-body);
		color: var(--color-text);
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		transition: color 200ms;
	}
	.nav-card:hover .nav-title { color: var(--color-brand); }

	@media (max-width: 767px) {
		.article-nav {
			grid-template-columns: 1fr;
			padding: var(--space-8) var(--space-4) var(--space-16);
		}
	}
</style>
