---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/base_layout.astro";
import { Image } from "astro:assets";
import { buildWebPageEntity } from "../../utils/jsonLd";
import { getAllSeries, getSeriesSlug } from "../../utils/seriesUtils";

const page_info = {
    title: "Articles | Rishi Chawda",
    description: "Long-form writing about engineering, web performance, and the things I've learned along the way.",
    keywords: "articles, web development, engineering, tutorials, performance",
};

const allArticles = await getCollection("articles");
const sortedArticles = allArticles.sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const allTags = [...new Set(sortedArticles.flatMap((a) => a.data.tags))].sort();
const featuredArticle = sortedArticles[0];
const gridArticles = sortedArticles.slice(1);
const allSeries = getAllSeries(allArticles);

function formatDate(date: Date): string {
    return new Date(date).toLocaleDateString("en-US", {
        month: "short",
        day: "numeric",
        year: "numeric",
    });
}

const pageUrl = new URL(
    Astro.url.pathname,
    Astro.site || "https://rishikc.com",
).toString();

const pageSchemaEntities = [
    buildWebPageEntity({
        type: "CollectionPage",
        url: pageUrl,
        name: "Articles by Rishi Chawda",
        description: page_info.description,
        mainEntity: {
            "@type": "ItemList",
            numberOfItems: sortedArticles.length,
            itemListElement: sortedArticles.slice(0, 10).map((article, index) => ({
                "@type": "ListItem",
                position: index + 1,
                item: {
                    "@type": article.data.jsonld_schema || "Article",
                    headline: article.data.title,
                    description: article.data.description,
                    url: new URL(article.data.path, Astro.site || "https://rishikc.com").toString(),
                    datePublished: article.data.date.toISOString(),
                    keywords: article.data.tags.join(", ")
                }
            }))
        }
    }),
];
---

<BaseLayout page_info={page_info} activeRoute="/articles/" pageSchemaEntities={pageSchemaEntities}>

    <main>
        <!-- Page Header -->
        <section class="page-header" data-reveal>
            <span class="overline">THOUGHTS &amp; TUTORIALS</span>
            <h1 class="page-title">Articles</h1>
            <p class="page-subtitle">Long-form writing about engineering, web performance, and the things I've learned along the way.</p>
            <span class="article-count">{sortedArticles.length} articles published</span>
        </section>

        <!-- Article Series -->
        {allSeries.length > 0 && (
            <section class="series-section" data-reveal>
                <div class="series-header">
                    <h2 class="series-heading">Series</h2>
                    <div class="series-divider"></div>
                </div>
                <div class="series-scroll" role="region" aria-label="Article series">
                    {allSeries.map((series) => (
                        <a href={`/articles/series/${getSeriesSlug(series.seriesTitle)}/`} class="series-card">
                            <h3 class="series-card-title">{series.seriesTitle}</h3>
                            <span class="series-card-meta">{series.totalParts} parts</span>
                            <span class="series-card-link">View Series <span class="arrow">&rarr;</span></span>
                        </a>
                    ))}
                </div>
            </section>
        )}

        <!-- Filter Bar -->
        <div class="filter-bar" id="filter-bar">
            <div class="filter-inner">
                <div class="tag-filters-wrapper">
                    <div class="tag-filters" role="group" aria-label="Filter by tag" id="tag-filters">
                        <div class="tag-indicator" id="tag-indicator" aria-hidden="true"></div>
                        <button class="tag-pill active" data-tag="all" aria-pressed="true">All</button>
                        {allTags.map((tag, i) => (
                            <button class:list={["tag-pill", i >= 8 ? "tag-overflow" : ""]} data-tag={tag} aria-pressed="false">{tag}<span class="tag-dismiss" aria-hidden="true">×</span></button>
                        ))}
                    </div>
                    {allTags.length > 8 && (
                        <button class="tag-expand-btn" id="tag-expand" aria-expanded="false">
                            <span class="tag-expand-text">+{allTags.length - 8} more</span>
                        </button>
                    )}
                </div>
                <div class="filter-controls">
                    <div class="view-toggle" role="group" aria-label="View mode">
                        <button class="view-btn active" data-view="grid" aria-label="Grid view" aria-pressed="true">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="1" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="1" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/><rect x="9" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.5"/></svg>
                        </button>
                        <button class="view-btn" data-view="list" aria-label="List view" aria-pressed="false">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><line x1="1" y1="3" x2="15" y2="3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="1" y1="8" x2="15" y2="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="1" y1="13" x2="15" y2="13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                        </button>
                    </div>
                    <select class="sort-select" id="sort-select" aria-label="Sort articles">
                        <option value="newest">Newest First</option>
                        <option value="oldest">Oldest First</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Featured Article -->
        {featuredArticle && (
            <section class="featured-section" data-reveal>
                <a href={featuredArticle.data.path} class="featured-card" data-article data-tags={featuredArticle.data.tags.join(",")}>
                    <div class="featured-image">
                        <Image
                            src={featuredArticle.data.hero_image}
                            alt={featuredArticle.data.hero_image_alt || featuredArticle.data.title}
                            width={720}
                            height={405}
                            class="featured-img"
                            transition:name={`${featuredArticle.data.path}-image`}
                        />
                    </div>
                    <div class="featured-content">
                        {featuredArticle.data.category && (
                            <span class="category-pill">{featuredArticle.data.category}</span>
                        )}
                        <h2 class="featured-title" transition:name={`${featuredArticle.data.path}-title`}>
                            {featuredArticle.data.title}
                        </h2>
                        {featuredArticle.data.subtitle && (
                            <p class="featured-subtitle">{featuredArticle.data.subtitle}</p>
                        )}
                        <p class="featured-desc">{featuredArticle.data.description}</p>
                        <div class="featured-meta">
                            <time datetime={featuredArticle.data.date.toISOString()}>{formatDate(featuredArticle.data.date)}</time>
                            <span class="meta-sep">&middot;</span>
                            <span>{featuredArticle.data.tags.slice(0, 3).join(", ")}</span>
                        </div>
                        <span class="read-link">Continue Reading <span class="arrow">&rarr;</span></span>
                    </div>
                </a>
            </section>
        )}

        <!-- All Articles Grid -->
        <section class="articles-section">
            <div class="articles-grid" id="articles-grid" role="list">
                {gridArticles.map((article) => (
                    <div
                        class="article-card"
                        role="listitem"
                        data-article
                        data-tags={article.data.tags.join(",")}
                        data-date={article.data.date.getTime()}
                        data-title={article.data.title}
                    >
                        <a href={article.data.path} class="card-link">
                            <div class="card-image">
                                <Image
                                    src={article.data.hero_image}
                                    alt={article.data.hero_image_alt || article.data.title}
                                    width={400}
                                    height={225}
                                    class="card-img"
                                    transition:name={`${article.data.path}-image`}
                                />
                            </div>
                            <div class="card-body">
                                {article.data.category && (
                                    <span class="category-pill small">{article.data.category}</span>
                                )}
                                <h3 class="card-title" transition:name={`${article.data.path}-title`}>{article.data.title}</h3>
                                <p class="card-desc">{article.data.description}</p>
                                <div class="card-footer">
                                    <time class="card-date" datetime={article.data.date.toISOString()}>{formatDate(article.data.date)}</time>
                                    <div class="card-tags">
                                        {article.data.tags.slice(0, 3).map((tag: string) => (
                                            <span class="card-tag">{tag}</span>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        </a>
                        <!-- List view variant -->
                        <a href={article.data.path} class="list-link">
                            <div class="list-thumb">
                                <Image
                                    src={article.data.hero_image}
                                    alt=""
                                    width={340}
                                    height={190}
                                    class="list-thumb-img"
                                />
                            </div>
                            <div class="list-body">
                                <h3 class="list-title">{article.data.title}</h3>
                                <p class="list-desc">{article.data.description}</p>
                            </div>
                            <div class="list-meta">
                                <time datetime={article.data.date.toISOString()}>{formatDate(article.data.date)}</time>
                            </div>
                        </a>
                    </div>
                ))}
            </div>

            <!-- Empty State -->
            <div class="empty-state" id="empty-state" hidden>
                <p class="empty-title">No articles found with this tag.</p>
                <p class="empty-desc">Try another tag or browse all articles.</p>
                <button class="clear-filter-btn" id="clear-filter">Clear Filter</button>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    /* Page Header */
    .page-header {
        max-width: var(--max-content);
        margin: 0 auto;
        padding: var(--space-20) var(--space-6) var(--space-12);
        text-align: center;
    }
    .overline {
        display: block;
        font-family: var(--font-mono);
        font-size: var(--text-overline);
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-text-tertiary);
        margin-bottom: var(--space-4);
    }
    .page-title {
        font-family: var(--font-display);
        font-size: var(--text-display-lg);
        font-weight: 700;
        color: var(--color-text);
        margin: 0 0 var(--space-4);
        line-height: 1.1;
        letter-spacing: -0.025em;
    }
    .page-subtitle {
        font-family: var(--font-body);
        font-size: var(--text-body-lg);
        color: var(--color-text-secondary);
        max-width: 640px;
        margin: 0 auto var(--space-4);
        line-height: 1.6;
    }
    .article-count {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-muted);
    }

    /* Filter Bar */
    .filter-bar {
        position: sticky;
        top: var(--nav-height);
        z-index: 40;
        background: color-mix(in srgb, var(--color-bg) 85%, transparent);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--color-border);
        padding: 12px 0;
    }
    .filter-inner {
        max-width: var(--max-content);
        margin: 0 auto;
        padding: 0 var(--space-6);
        display: flex;
        align-items: center;
        gap: var(--space-4);
    }
    .tag-filters-wrapper {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        flex: 1;
        min-width: 0;
    }
    .tag-filters {
        display: flex;
        gap: var(--space-2);
        overflow-x: auto;
        flex: 1;
        scrollbar-width: none;
        -ms-overflow-style: none;
        padding: 2px 0;
        position: relative;
        flex-wrap: wrap;
    }
    .tag-filters::-webkit-scrollbar { display: none; }
    .tag-overflow {
        display: none;
    }
    .tag-filters.expanded .tag-overflow {
        display: inline-flex;
    }
    .tag-expand-btn {
        font-family: var(--font-ui);
        font-size: 13px;
        padding: 6px 14px;
        border-radius: 9999px;
        border: 1px dashed var(--color-border);
        background: transparent;
        color: var(--color-text-tertiary);
        cursor: pointer;
        white-space: nowrap;
        flex-shrink: 0;
        transition: color 200ms, border-color 200ms;
    }
    .tag-expand-btn:hover {
        color: var(--color-brand);
        border-color: var(--color-brand);
    }
    .tag-indicator {
        position: absolute;
        border-radius: 9999px;
        background: var(--btn-bg);
        transition: left 250ms cubic-bezier(0.7, 0, 0.3, 1), width 250ms cubic-bezier(0.7, 0, 0.3, 1), top 250ms cubic-bezier(0.7, 0, 0.3, 1), height 250ms cubic-bezier(0.7, 0, 0.3, 1);
        pointer-events: none;
        z-index: 0;
    }
    .tag-pill {
        font-family: var(--font-ui);
        font-size: 14px;
        padding: 6px 16px;
        border-radius: 9999px;
        border: 1px solid var(--color-border);
        background: var(--color-surface);
        color: var(--color-text-secondary);
        cursor: pointer;
        white-space: nowrap;
        transition: color 200ms, border-color 200ms;
        flex-shrink: 0;
        position: relative;
        z-index: 1;
    }
    .tag-pill:hover:not(.active) {
        background: var(--color-brand-lighter);
    }
    .tag-pill.active {
        background: transparent;
        color: #fff;
        border-color: transparent;
    }
    .tag-pill .tag-dismiss {
        display: none;
        margin-left: 4px;
        font-size: 12px;
        line-height: 1;
        opacity: 0.8;
    }
    .tag-pill.active:not([data-tag="all"]) .tag-dismiss {
        display: inline;
    }
    .filter-controls {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        flex-shrink: 0;
    }
    .view-toggle {
        display: flex;
        border: 1px solid var(--color-border);
        border-radius: 8px;
        overflow: hidden;
    }
    .view-btn {
        padding: 6px 10px;
        background: var(--color-surface);
        color: var(--color-text-tertiary);
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 200ms, color 200ms;
    }
    .view-btn + .view-btn {
        border-left: 1px solid var(--color-border);
    }
    .view-btn.active {
        background: var(--color-brand-lighter);
        color: var(--color-brand);
    }
    .view-btn:hover:not(.active) {
        background: var(--color-bg-alt);
    }
    .sort-select {
        font-family: var(--font-ui);
        font-size: 14px;
        padding: 6px 12px;
        border-radius: 8px;
        border: 1px solid var(--color-border);
        background: var(--color-surface);
        color: var(--color-text);
        cursor: pointer;
        appearance: auto;
    }

    /* Featured Article */
    .featured-section {
        max-width: var(--max-content);
        margin: 0 auto;
        padding: var(--space-8) var(--space-6);
    }
    .featured-card {
        display: grid;
        grid-template-columns: 40% 1fr;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition: box-shadow 300ms;
    }
    .featured-card:hover {
        box-shadow: var(--shadow-elevated);
    }
    .featured-image {
        overflow: hidden;
    }
    .featured-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 500ms;
    }
    .featured-card:hover .featured-img {
        transform: scale(1.03);
    }
    .featured-content {
        padding: var(--space-10);
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: var(--space-3);
    }
    .category-pill {
        display: inline-block;
        align-self: flex-start;
        font-family: var(--font-ui);
        font-size: 12px;
        padding: 4px 12px;
        border-radius: 9999px;
        background: var(--color-brand-lighter);
        color: var(--color-brand-dark);
        font-weight: 500;
    }
    .category-pill.small {
        font-size: 11px;
        padding: 3px 10px;
    }
    .featured-title {
        font-family: var(--font-display);
        font-size: var(--text-h2);
        font-weight: 700;
        letter-spacing: -0.025em;
        color: var(--color-text);
        line-height: 1.2;
        margin: 0;
        transition: color 200ms;
    }
    .featured-card:hover .featured-title {
        color: var(--color-brand);
    }
    .featured-subtitle {
        font-family: var(--font-body);
        font-size: var(--text-h4);
        color: var(--color-text-secondary);
        font-weight: 400;
        letter-spacing: -0.01em;
        margin: 0;
        line-height: 1.4;
    }
    .featured-desc {
        font-family: var(--font-body);
        font-size: var(--text-body);
        color: var(--color-text-secondary);
        line-height: 1.6;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .featured-meta {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-tertiary);
        display: flex;
        align-items: center;
        gap: var(--space-2);
        flex-wrap: wrap;
    }
    .meta-sep { opacity: 0.5; }
    .read-link {
        font-family: var(--font-ui);
        font-size: var(--text-body);
        color: var(--color-brand-dark);
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
    }
    .read-link .arrow {
        transition: transform 200ms;
    }
    .featured-card:hover .read-link .arrow {
        transform: translateX(4px);
    }

    /* Series Section */
    .series-section {
        max-width: var(--max-content);
        margin: 0 auto;
        padding: var(--space-12) var(--space-6);
    }
    .series-header {
        display: flex;
        align-items: center;
        gap: var(--space-4);
        margin-bottom: var(--space-6);
    }
    .series-heading {
        font-family: var(--font-display);
        font-size: var(--text-h3);
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.3;
        color: var(--color-text);
        margin: 0;
        white-space: nowrap;
    }
    .series-divider {
        flex: 1;
        height: 1px;
        background: var(--color-border);
    }
    .series-scroll {
        display: flex;
        gap: var(--space-5);
        overflow-x: auto;
        scrollbar-width: none;
        -ms-overflow-style: none;
        padding-bottom: var(--space-2);
    }
    .series-scroll::-webkit-scrollbar { display: none; }
    .series-card {
        min-width: 280px;
        max-width: 280px;
        padding: var(--space-6);
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        transition: transform 300ms, box-shadow 300ms;
    }
    .series-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-elevated);
    }
    .series-card-title {
        font-family: var(--font-display);
        font-size: var(--text-body-lg);
        font-weight: 600;
        color: var(--color-text);
        margin: 0;
    }
    .series-card-meta {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-tertiary);
    }
    .series-card-link {
        font-family: var(--font-ui);
        font-size: 14px;
        color: var(--color-brand-dark);
        font-weight: 500;
        margin-top: auto;
    }
    .series-card-link .arrow { transition: transform 200ms; }
    .series-card:hover .series-card-link .arrow { transform: translateX(4px); }

    /* Articles Grid */
    .articles-section {
        max-width: var(--max-content);
        margin: 0 auto;
        padding: var(--space-8) var(--space-6) var(--space-20);
    }
    .articles-grid {
        columns: 3;
        column-gap: 24px;
    }
    .articles-grid[data-view="list"] {
        columns: 1;
        column-gap: 0;
        overflow: hidden;
    }

    /* Grid Card */
    .article-card {
        transition: opacity 200ms;
        break-inside: avoid;
        margin-bottom: 24px;
    }
    .article-card[hidden] { display: none; }
    .card-link {
        display: flex;
        flex-direction: column;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        transition: transform 300ms, box-shadow 300ms;
    }
    .card-link:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-elevated);
    }
    .card-image {
        aspect-ratio: 16 / 9;
        overflow: hidden;
    }
    .card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 500ms;
    }
    .card-link:hover .card-img {
        transform: scale(1.05);
    }
    .card-body {
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        flex: 1;
    }
    .card-title {
        font-family: var(--font-display);
        font-size: var(--text-body-lg);
        font-weight: 600;
        color: var(--color-text);
        margin: 0;
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: color 200ms;
    }
    .card-link:hover .card-title {
        color: var(--color-brand);
    }
    .card-desc {
        font-family: var(--font-body);
        font-size: var(--text-body-sm);
        color: var(--color-text-secondary);
        line-height: 1.5;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: auto;
        padding-top: var(--space-3);
    }
    .card-date {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-tertiary);
    }
    .card-tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }
    .card-tag {
        font-family: var(--font-ui);
        font-size: 12px;
        padding: 2px 8px;
        border-radius: 6px;
        background: var(--color-brand-lighter);
        color: var(--color-brand-dark);
    }

    /* List View */
    .list-link {
        display: none;
        text-decoration: none;
        color: inherit;
        padding: var(--space-5) 0;
        border-bottom: 1px solid var(--color-border);
        align-items: center;
        gap: var(--space-5);
        transition: background 200ms;
    }
    .list-link:hover {
        background: var(--color-bg-alt);
        padding-left: var(--space-3);
        padding-right: var(--space-3);
        margin-left: calc(-1 * var(--space-3));
        margin-right: calc(-1 * var(--space-3));
        border-radius: 8px;
    }
    .articles-grid[data-view="list"] .card-link { display: none; }
    .articles-grid[data-view="list"] .list-link { display: flex; }
    .list-thumb {
        width: 340px;
        height: 190px;
        flex-shrink: 0;
        border-radius: 10px;
        overflow: hidden;
    }
    .list-thumb-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 400ms;
    }
    .list-link:hover .list-thumb-img {
        transform: scale(1.05);
    }
    .list-body { flex: 1; min-width: 0; }
    .list-title {
        font-family: var(--font-display);
        font-size: var(--text-body-lg);
        font-weight: 600;
        color: var(--color-text);
        margin: 0 0 6px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: color 200ms;
    }
    .list-link:hover .list-title { color: var(--color-brand); }
    .list-desc {
        font-family: var(--font-body);
        font-size: var(--text-body-sm);
        color: var(--color-text-secondary);
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .list-meta {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-tertiary);
        white-space: nowrap;
        flex-shrink: 0;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: var(--space-16) 0;
    }
    .empty-state[hidden] { display: none; }
    .empty-title {
        font-family: var(--font-display);
        font-size: var(--text-body-lg);
        color: var(--color-text-secondary);
        margin: 0 0 var(--space-2);
    }
    .empty-desc {
        font-family: var(--font-body);
        font-size: var(--text-body-sm);
        color: var(--color-text-tertiary);
        margin: 0 0 var(--space-6);
    }
    .clear-filter-btn {
        font-family: var(--font-ui);
        font-size: 14px;
        padding: 8px 20px;
        border-radius: 8px;
        border: 1px solid var(--color-brand);
        background: transparent;
        color: var(--color-brand);
        cursor: pointer;
        transition: background 200ms, color 200ms;
    }
    .clear-filter-btn:hover {
        background: var(--btn-bg);
        color: #fff;
    }

    /* Responsive */
    @media (max-width: 1023px) {
        .articles-grid { columns: 2; }
        .featured-card { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 767px) {
        .articles-grid { columns: 1; }
        .featured-card { grid-template-columns: 1fr; }
        .featured-content { padding: var(--space-6); }
        .featured-title { font-size: var(--text-h2); }
        .filter-controls { display: none; }
        .page-header { padding: var(--space-12) var(--space-4) var(--space-8); }
        .list-link { flex-direction: column; }
        .list-thumb { width: 100%; height: 180px; }
    }
</style>

<script>
    document.addEventListener('astro:page-load', () => {
        const tagPills = document.querySelectorAll<HTMLButtonElement>('.tag-pill');
        const viewBtns = document.querySelectorAll<HTMLButtonElement>('.view-btn');
        const sortSelect = document.getElementById('sort-select') as HTMLSelectElement | null;
        const grid = document.getElementById('articles-grid') as HTMLElement | null;
        const articles = document.querySelectorAll<HTMLElement>('[data-article]');
        const emptyState = document.getElementById('empty-state') as HTMLElement | null;
        const clearFilterBtn = document.getElementById('clear-filter') as HTMLButtonElement | null;

        if (!grid) return;

        let activeTag = 'all';

        // Sliding indicator
        const indicator = document.getElementById('tag-indicator') as HTMLElement | null;
        function moveIndicator(pill: HTMLElement) {
            if (!indicator) return;
            const container = pill.parentElement!;
            const containerRect = container.getBoundingClientRect();
            const pillRect = pill.getBoundingClientRect();
            indicator.style.left = `${pillRect.left - containerRect.left + container.scrollLeft}px`;
            indicator.style.top = `${pillRect.top - containerRect.top + container.scrollTop}px`;
            indicator.style.width = `${pillRect.width}px`;
            indicator.style.height = `${pillRect.height}px`;
        }

        // Restore view preference
        const savedView = localStorage.getItem('articles-view') || 'grid';
        grid.dataset.view = savedView;
        viewBtns.forEach(btn => {
            btn.classList.toggle('active', btn.dataset.view === savedView);
            btn.setAttribute('aria-pressed', String(btn.dataset.view === savedView));
        });

        // Restore tag from URL
        const urlParams = new URLSearchParams(window.location.search);
        const urlTag = urlParams.get('tag');
        if (urlTag) {
            activeTag = urlTag;
            tagPills.forEach(pill => {
                const isActive = pill.dataset.tag === urlTag;
                pill.classList.toggle('active', isActive);
                pill.setAttribute('aria-pressed', String(isActive));
            });
        }

        // Position indicator on initial active pill
        requestAnimationFrame(() => {
            const activePill = document.querySelector<HTMLElement>('.tag-pill.active');
            if (activePill) moveIndicator(activePill);
        });

        function filterArticles() {
            let visibleCount = 0;
            articles.forEach(article => {
                const tags = (article.dataset.tags || '').toLowerCase().split(',');
                const matches = activeTag === 'all' || tags.includes(activeTag.toLowerCase());
                if (matches) {
                    article.hidden = false;
                    visibleCount++;
                } else {
                    article.hidden = true;
                }
            });
            if (emptyState) {
                emptyState.hidden = visibleCount > 0;
            }
        }

        // Tag filtering (toggle deselect: clicking active tag resets to "all")
        tagPills.forEach(pill => {
            pill.addEventListener('click', () => {
                const clickedTag = pill.dataset.tag || 'all';

                if (clickedTag !== 'all' && activeTag === clickedTag) {
                    // Deselect: reset to "all"
                    activeTag = 'all';
                    tagPills.forEach(p => {
                        p.classList.toggle('active', p.dataset.tag === 'all');
                        p.setAttribute('aria-pressed', String(p.dataset.tag === 'all'));
                    });
                    const allPill = document.querySelector<HTMLElement>('.tag-pill[data-tag="all"]');
                    if (allPill) moveIndicator(allPill);
                } else {
                    activeTag = clickedTag;
                    tagPills.forEach(p => {
                        const isActive = p === pill;
                        p.classList.toggle('active', isActive);
                        p.setAttribute('aria-pressed', String(isActive));
                    });
                    moveIndicator(pill);
                }

                // Update URL
                const url = new URL(window.location.href);
                if (activeTag === 'all') {
                    url.searchParams.delete('tag');
                } else {
                    url.searchParams.set('tag', activeTag);
                }
                history.replaceState({}, '', url.toString());

                filterArticles();
            });
        });

        // Expand/collapse tags
        const tagExpandBtn = document.getElementById('tag-expand') as HTMLButtonElement | null;
        const tagFiltersEl = document.getElementById('tag-filters') as HTMLElement | null;
        if (tagExpandBtn && tagFiltersEl) {
            tagExpandBtn.addEventListener('click', () => {
                const isExpanded = tagFiltersEl.classList.toggle('expanded');
                tagExpandBtn.setAttribute('aria-expanded', String(isExpanded));
                const overflowCount = tagFiltersEl.querySelectorAll('.tag-overflow').length;
                tagExpandBtn.querySelector('.tag-expand-text')!.textContent = isExpanded ? 'Show fewer' : `+${overflowCount} more`;
            });
        }

        // View toggle
        viewBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const view = btn.dataset.view || 'grid';
                grid.dataset.view = view;
                localStorage.setItem('articles-view', view);
                viewBtns.forEach(b => {
                    b.classList.toggle('active', b === btn);
                    b.setAttribute('aria-pressed', String(b === btn));
                });
            });
        });

        // Sort
        sortSelect?.addEventListener('change', () => {
            const value = sortSelect.value;
            const gridContainer = grid;
            const articleEls = [...gridContainer.querySelectorAll<HTMLElement>('.article-card')];

            articleEls.sort((a, b) => {
                const dateA = Number(a.dataset.date || 0);
                const dateB = Number(b.dataset.date || 0);
                switch (value) {
                    case 'oldest': return dateA - dateB;
                    case 'newest':
                    default: return dateB - dateA;
                }
            });

            articleEls.forEach(el => gridContainer.appendChild(el));
        });

        // Clear filter
        clearFilterBtn?.addEventListener('click', () => {
            activeTag = 'all';
            tagPills.forEach(p => {
                p.classList.toggle('active', p.dataset.tag === 'all');
                p.setAttribute('aria-pressed', String(p.dataset.tag === 'all'));
            });
            const allPill = document.querySelector<HTMLElement>('.tag-pill[data-tag="all"]');
            if (allPill) moveIndicator(allPill);
            const url = new URL(window.location.href);
            url.searchParams.delete('tag');
            history.replaceState({}, '', url.toString());
            filterArticles();
        });

        // Initial filter
        filterArticles();
    });
</script>
