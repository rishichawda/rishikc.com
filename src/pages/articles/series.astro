---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/base_layout.astro";
import { Image } from "astro:assets";
import { buildWebPageEntity } from "../../utils/jsonLd";
import { getAllSeries } from "../../utils/seriesUtils";

interface Social { platform: string; url: string; }
interface ProfileData { name: string; socials: Social[]; }

const profileEntry = await getCollection("profile");
const profile = profileEntry[0].data as ProfileData;

const page_info = {
    title: `Article Series | ${profile.name}`,
    description: "Explore multi-part article series covering in-depth topics in web development, React architecture, SEO, and more.",
    keywords: "article series, multi-part articles, web development tutorials, React architecture, SEO guides",
};

const allArticles = await getCollection("articles");
const allSeries = getAllSeries(allArticles);

function formatDate(date: Date): string {
    return new Date(date).toLocaleDateString("en-US", {
        day: "numeric",
        month: "long",
        year: "numeric",
    });
}

const pageUrl = new URL(
    Astro.url.pathname,
    Astro.site || "https://rishikc.com",
).toString();

const pageSchemaEntities = [
    buildWebPageEntity({
        type: "CollectionPage",
        url: pageUrl,
        name: `Article Series by ${profile.name}`,
        description: page_info.description,
        mainEntity: {
            "@type": "ItemList",
            numberOfItems: allSeries.length,
            itemListElement: allSeries.map((series, index) => ({
                "@type": "ListItem",
                position: index + 1,
                item: {
                    "@type": "CreativeWorkSeries",
                    name: series.seriesTitle,
                    hasPart: series.articles.map(article => ({
                        "@type": article.data.jsonld_schema || "Article",
                        name: article.data.title,
                        url: new URL(article.data.path, Astro.site || "https://rishikc.com").toString(),
                    }))
                }
            }))
        }
    }),
];
---

<BaseLayout page_info={page_info} activeRoute="/articles/" pageSchemaEntities={pageSchemaEntities}>

    <main>
        <!-- Page Header -->
        <section class="page-header" data-reveal>
            <span class="overline">ARTICLE SERIES</span>
            <h1 class="page-title">Series</h1>
            <p class="page-subtitle">In-depth, multi-part explorations of complex topics in web development and engineering.</p>
            <span class="series-count">{allSeries.length} series published</span>
        </section>

        {allSeries.length > 0 ? (
            <section class="series-list">
                {allSeries.map((series) => (
                    <div class="series-block" data-reveal>
                        <div class="series-block-header">
                            <h2 class="series-block-title">{series.seriesTitle}</h2>
                            <div class="series-block-meta">
                                <span>{series.totalParts} parts</span>
                                {series.isOngoing && (
                                    <span class="ongoing-badge">Ongoing</span>
                                )}
                            </div>
                        </div>

                        <ol class="chapter-list" aria-label="Article series chapters">
                            {series.articles.map((article, index) => (
                                <li class="chapter-item" data-reveal-item>
                                    <a href={article.data.path} class="chapter-link">
                                        <span class="chapter-number">{String(index + 1).padStart(2, '0')}</span>
                                        <div class="chapter-body">
                                            <h3 class="chapter-title">{article.data.title}</h3>
                                            <p class="chapter-desc">{article.data.description}</p>
                                            <div class="chapter-meta">
                                                <time datetime={article.data.date.toISOString()}>{formatDate(article.data.date)}</time>
                                            </div>
                                        </div>
                                        <span class="chapter-cta">Read Part {index + 1} <span class="arrow">&rarr;</span></span>
                                    </a>
                                </li>
                            ))}
                        </ol>
                    </div>
                ))}
            </section>
        ) : (
            <div class="empty-state" data-reveal>
                <p class="empty-title">No series found</p>
                <p class="empty-desc">There are currently no multi-part article series available.</p>
                <a href="/articles/" class="back-link">Browse all articles &rarr;</a>
            </div>
        )}
    </main>
</BaseLayout>

<style>
    .page-header {
        max-width: 720px;
        margin: 0 auto;
        padding: var(--space-20) var(--space-6) var(--space-12);
        text-align: center;
    }
    .overline {
        display: block;
        font-family: var(--font-mono);
        font-size: var(--text-overline);
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-brand);
        margin-bottom: var(--space-4);
    }
    .page-title {
        font-family: var(--font-display);
        font-size: var(--text-display-lg);
        font-weight: 700;
        color: var(--color-text);
        margin: 0 0 var(--space-4);
        line-height: 1.1;
    }
    .page-subtitle {
        font-family: var(--font-body);
        font-size: var(--text-body-lg);
        color: var(--color-text-secondary);
        max-width: 560px;
        margin: 0 auto var(--space-4);
        line-height: 1.6;
    }
    .series-count {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-muted);
    }

    /* Series List */
    .series-list {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 var(--space-6) var(--space-20);
        display: flex;
        flex-direction: column;
        gap: var(--space-16);
    }

    .series-block-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: var(--space-4);
        margin-bottom: var(--space-6);
        padding-bottom: var(--space-4);
        border-bottom: 1px solid var(--color-border);
    }
    .series-block-title {
        font-family: var(--font-display);
        font-size: var(--text-h2);
        font-weight: 600;
        line-height: 1.2;
        letter-spacing: -0.015em;
        color: var(--color-text);
        margin: 0;
    }
    .series-block-meta {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-tertiary);
        display: flex;
        align-items: center;
        gap: var(--space-3);
        flex-shrink: 0;
    }
    .ongoing-badge {
        font-family: var(--font-ui);
        font-size: 11px;
        padding: 2px 8px;
        border-radius: 9999px;
        background: #FEF3C7;
        color: #92400E;
    }
    [data-theme="dark"] .ongoing-badge {
        background: rgba(245, 158, 11, 0.15);
        color: #FBBF24;
    }

    /* Chapter List */
    .chapter-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .chapter-item {
        border-bottom: 1px solid var(--color-border);
    }
    .chapter-item:last-child { border-bottom: none; }
    .chapter-link {
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: var(--space-5);
        padding: var(--space-6) var(--space-4);
        text-decoration: none;
        color: inherit;
        align-items: center;
        transition: background 100ms;
        border-radius: 8px;
    }
    .chapter-link:hover {
        background: var(--color-bg-alt);
    }
    .chapter-number {
        font-family: var(--font-display);
        font-size: var(--text-display);
        font-weight: 700;
        letter-spacing: -0.025em;
        color: var(--color-brand);
        opacity: 0.25;
        line-height: 1;
    }
    .chapter-body { min-width: 0; }
    .chapter-title {
        font-family: var(--font-display);
        font-size: var(--text-body-lg);
        font-weight: 600;
        color: var(--color-text);
        margin: 0 0 var(--space-2);
        line-height: 1.3;
        transition: color 200ms;
    }
    .chapter-link:hover .chapter-title {
        color: var(--color-brand);
    }
    .chapter-desc {
        font-family: var(--font-body);
        font-size: var(--text-body-sm);
        color: var(--color-text-secondary);
        margin: 0 0 var(--space-2);
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .chapter-meta {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-tertiary);
    }
    .chapter-cta {
        font-family: var(--font-ui);
        font-size: 14px;
        color: var(--color-brand);
        font-weight: 500;
        white-space: nowrap;
        flex-shrink: 0;
    }
    .chapter-cta .arrow {
        display: inline-block;
        transition: transform 200ms;
    }
    .chapter-link:hover .chapter-cta .arrow {
        transform: translateX(4px);
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: var(--space-20) var(--space-6);
        max-width: 480px;
        margin: 0 auto;
    }
    .empty-title {
        font-family: var(--font-display);
        font-size: var(--text-h2);
        font-weight: 600;
        letter-spacing: -0.015em;
        line-height: 1.2;
        color: var(--color-text);
        margin: 0 0 var(--space-3);
    }
    .empty-desc {
        font-family: var(--font-body);
        font-size: var(--text-body);
        color: var(--color-text-secondary);
        margin: 0 0 var(--space-6);
    }
    .back-link {
        font-family: var(--font-ui);
        font-size: var(--text-body);
        color: var(--color-brand);
        text-decoration: none;
        font-weight: 500;
    }
    .back-link:hover { text-decoration: underline; }

    @media (max-width: 767px) {
        .chapter-link {
            grid-template-columns: auto 1fr;
            gap: var(--space-3);
        }
        .chapter-cta { display: none; }
        .chapter-number { font-size: var(--text-h2); }
        .series-block-header { flex-direction: column; gap: var(--space-2); }
    }
</style>
