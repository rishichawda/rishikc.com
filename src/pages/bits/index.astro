---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/base_layout.astro";
import { buildWebPageEntity } from "../../utils/jsonLd";

const page_info = {
    title: "Bits | Rishi Chawda",
    description: "Short thoughts, insights, and ideas - bite-sized posts on technology, creativity, and engineering",
    keywords: "bits, thoughts, insights, short posts, Rishi Chawda",
};

const allBits = await getCollection("bits");
const sortedBits = allBits.sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

// Group bits by year for year dividers
const currentYear = new Date().getFullYear();
const bitsByYear = new Map<number, typeof sortedBits>();
sortedBits.forEach((bit) => {
    const year = bit.data.date.getFullYear();
    if (!bitsByYear.has(year)) bitsByYear.set(year, []);
    bitsByYear.get(year)!.push(bit);
});
const yearGroups = Array.from(bitsByYear.entries()).sort(([a], [b]) => b - a);
const shouldGroupByYear = sortedBits.length > 20;

function formatDate(date: Date): string {
    return new Date(date).toLocaleDateString("en-US", {
        day: "numeric",
        month: "long",
        year: "numeric",
    });
}

const pageUrl = new URL(
    Astro.url.pathname,
    Astro.site || "https://rishikc.com",
).toString();

const pageSchemaEntities = [
    buildWebPageEntity({
        type: "CollectionPage",
        url: pageUrl,
        name: "Bits by Rishi Chawda",
        description: page_info.description,
        mainEntity: {
            "@type": "ItemList",
            numberOfItems: sortedBits.length,
            itemListElement: sortedBits.slice(0, 10).map((bit, index) => ({
                "@type": "ListItem",
                position: index + 1,
                item: {
                    "@type": "BlogPosting",
                    headline: bit.data.title,
                    description: bit.data.description,
                    url: new URL(bit.data.path, Astro.site || "https://rishikc.com").toString(),
                    datePublished: bit.data.date.toISOString(),
                    keywords: bit.data.tags?.join(", ") || ""
                }
            }))
        }
    }),
];
---

<BaseLayout page_info={page_info} activeRoute="/bits/" pageSchemaEntities={pageSchemaEntities}>

    <main>
        <section class="page-header" data-reveal>
            <span class="overline">QUICK READS</span>
            <h1 class="page-title">Bits</h1>
            <p class="page-subtitle">Short-form thoughts, tips, and observations.</p>
            <span class="bits-count">{sortedBits.length} bits published</span>
        </section>

        {sortedBits.length > 0 ? (
            <section class="bits-list">
                {shouldGroupByYear ? (
                    yearGroups.map(([year, bits]) => (
                        <details class="year-group" open={year === currentYear}>
                            <summary class="year-divider">
                                <h3 class="year-heading">
                                    <span class="year-toggle" aria-hidden="true">▸</span>
                                    {year}
                                    <span class="year-count">({bits.length} {bits.length === 1 ? 'bit' : 'bits'})</span>
                                </h3>
                                <span class="year-line" aria-hidden="true"></span>
                            </summary>
                            <ul role="list">
                                {bits.map((bit) => (
                                    <li class="bit-item" data-reveal>
                                        <a href={bit.data.path} class="bit-link">
                                            <h3 class="bit-title">{bit.data.title}</h3>
                                            <p class="bit-desc">{bit.data.description}</p>
                                            <div class="bit-meta">
                                                <time datetime={bit.data.date.toISOString()}>{formatDate(bit.data.date)}</time>
                                                {bit.data.tags && bit.data.tags.length > 0 && (
                                                    <span class="bit-tags">
                                                        {bit.data.tags.map((tag: string) => (
                                                            <span class="bit-tag">{tag}</span>
                                                        ))}
                                                    </span>
                                                )}
                                            </div>
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </details>
                    ))
                ) : (
                    <ul role="list">
                        {sortedBits.map((bit) => (
                            <li class="bit-item" data-reveal>
                                <a href={bit.data.path} class="bit-link">
                                    <h3 class="bit-title">{bit.data.title}</h3>
                                    <p class="bit-desc">{bit.data.description}</p>
                                    <div class="bit-meta">
                                        <time datetime={bit.data.date.toISOString()}>{formatDate(bit.data.date)}</time>
                                        {bit.data.tags && bit.data.tags.length > 0 && (
                                            <span class="bit-tags">
                                                {bit.data.tags.map((tag: string) => (
                                                    <span class="bit-tag">{tag}</span>
                                                ))}
                                            </span>
                                        )}
                                    </div>
                                </a>
                            </li>
                        ))}
                    </ul>
                )}
            </section>
        ) : (
            <div class="empty-state" data-reveal>
                <p class="empty-title">Short-form thoughts coming soon.</p>
                <p class="empty-desc">In the meantime, check out the full articles.</p>
                <a href="/articles/" class="back-link">Browse Articles &rarr;</a>
            </div>
        )}
    </main>
</BaseLayout>

<style>
    .page-header {
        max-width: 720px;
        margin: 0 auto;
        padding: var(--space-20) var(--space-6) var(--space-12);
        text-align: center;
    }
    .overline {
        display: block;
        font-family: var(--font-mono);
        font-size: var(--text-overline);
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-text-tertiary);
        margin-bottom: var(--space-4);
    }
    .page-title {
        font-family: var(--font-display);
        font-size: var(--text-display-lg);
        font-weight: 700;
        color: var(--color-text);
        margin: 0 0 var(--space-4);
        line-height: 1.1;
        letter-spacing: -0.025em;
    }
    .page-subtitle {
        font-family: var(--font-body);
        font-size: var(--text-body-lg);
        color: var(--color-text-secondary);
        max-width: 560px;
        margin: 0 auto var(--space-4);
        line-height: 1.6;
    }
    .bits-count {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-muted);
    }

    /* Bits List */
    .bits-list {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 var(--space-6) var(--space-20);
    }
    .bits-list ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    /* Year grouping */
    .year-group {
        margin-bottom: var(--space-2);
    }
    .year-divider {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        cursor: pointer;
        padding: var(--space-4) 0 var(--space-2);
        list-style: none;
    }
    .year-divider::-webkit-details-marker { display: none; }
    .year-heading {
        font-family: var(--font-display);
        font-size: var(--text-h3);
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.3;
        color: var(--color-text-muted);
        margin: 0;
        display: flex;
        align-items: center;
        gap: var(--space-2);
        white-space: nowrap;
    }
    .year-toggle {
        display: inline-block;
        transition: transform 200ms;
        font-size: 0.7em;
    }
    .year-group[open] .year-toggle {
        transform: rotate(90deg);
    }
    .year-count {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        font-weight: 400;
        color: var(--color-text-muted);
    }
    .year-line {
        flex: 1;
        height: 1px;
        background: var(--color-border);
    }
    .bit-item {
        border-bottom: 1px solid var(--color-border);
    }
    .bit-item:last-child { border-bottom: none; }

    .bit-link {
        display: block;
        padding: var(--space-6) var(--space-4);
        text-decoration: none;
        color: inherit;
        border-radius: 8px;
        transition: background 150ms;
    }
    .bit-link:hover {
        background: var(--color-bg-alt);
    }
    .bit-title {
        font-family: var(--font-display);
        font-size: var(--text-h3);
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--color-text);
        margin: 0 0 var(--space-2);
        line-height: 1.3;
        transition: color 200ms, transform 200ms;
    }
    .bit-link:hover .bit-title {
        color: var(--color-brand);
        transform: translateX(4px);
    }
    .bit-desc {
        font-family: var(--font-body);
        font-size: var(--text-body);
        color: var(--color-text-secondary);
        margin: 0 0 var(--space-3);
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .bit-meta {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-tertiary);
        display: flex;
        align-items: center;
        gap: var(--space-3);
        flex-wrap: wrap;
    }
    .bit-tags {
        display: flex;
        gap: var(--space-2);
    }
    .bit-tag {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-muted);
    }
    .bit-tag::before { content: "·"; margin-right: var(--space-2); }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: var(--space-20) var(--space-6);
        max-width: 480px;
        margin: 0 auto;
    }
    .empty-title {
        font-family: var(--font-display);
        font-size: var(--text-h2);
        color: var(--color-text);
        margin: 0 0 var(--space-3);
    }
    .empty-desc {
        font-family: var(--font-body);
        font-size: var(--text-body);
        color: var(--color-text-secondary);
        margin: 0 0 var(--space-6);
    }
    .back-link {
        font-family: var(--font-ui);
        font-size: var(--text-body);
        color: var(--color-brand);
        text-decoration: none;
        font-weight: 500;
    }
    .back-link:hover { text-decoration: underline; }
</style>
