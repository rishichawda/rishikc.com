---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/base_layout.astro";
import Prose from "../../components/article/prose.astro";
import ExternalLink from "../../components/article/ExternalLink.astro";
import { buildWebPageEntity, personRef } from "../../utils/jsonLd";
import Breadcrumbs from "../../components/common/breadcrumbs.astro";
import "remark-notes-plugin/styles.css";

export async function getStaticPaths() {
    let bits = await getCollection("bits");
    return bits.map((bit) => ({
        params: { slug: bit.id },
        props: { bit, allBits: bits },
    }));
}

interface Props {
    bit: CollectionEntry<"bits">;
    allBits: CollectionEntry<"bits">[];
}

const { bit, allBits } = Astro.props as Props;
const { Content } = await render(bit);

const sortedBits = allBits.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const currentIndex = sortedBits.findIndex((b) => b.id === bit.id);
const prevBit = currentIndex > 0 ? sortedBits[currentIndex - 1] : null;
const nextBit = currentIndex < sortedBits.length - 1 ? sortedBits[currentIndex + 1] : null;

function formatDate(date: Date): string {
    return new Date(date).toLocaleDateString("en-US", {
        day: "numeric",
        month: "long",
        year: "numeric",
    });
}

const pageUrl = new URL(
    bit.data.path,
    Astro.site || "https://rishikc.com",
).toString();

const pageSchemaEntities = [
    buildWebPageEntity({
        url: pageUrl,
        name: bit.data.title,
        description: bit.data.description,
        mainEntity: {
            "@type": "BlogPosting",
            headline: bit.data.title,
            description: bit.data.description,
            datePublished: bit.data.date.toISOString(),
            url: pageUrl,
            author: personRef,
        },
    }),
];
---

<BaseLayout
    page_info={{
        title: bit.data.title,
        description: bit.data.description,
        keywords: bit.data.tags?.join(', ') || bit.data.title,
    }}
    activeRoute="/bits/"
    pageSchemaEntities={pageSchemaEntities}
>

    <main class="bit-page">
        <Breadcrumbs items={[
            { label: "Bits", href: "/bits/" },
            { label: bit.data.title },
        ]} />

        <article>
            <header class="bit-header">
                <h1 class="bit-title">{bit.data.title}</h1>
                <div class="bit-meta">
                    <time datetime={bit.data.date.toISOString()}>{formatDate(bit.data.date)}</time>
                </div>
                {bit.data.tags && bit.data.tags.length > 0 && (
                    <div class="bit-tags">
                        {bit.data.tags.map((tag: string) => (
                            <span class="tag-pill">{tag}</span>
                        ))}
                    </div>
                )}
            </header>

            <div class="bit-body">
                <Prose>
                    <Content components={{ a: ExternalLink }} />
                </Prose>
            </div>
        </article>

        {(prevBit || nextBit) && (
            <nav class="bit-nav" aria-label="Bit navigation">
                {prevBit ? (
                    <a href={prevBit.data.path} class="nav-card nav-prev">
                        <span class="nav-label">Previous</span>
                        <span class="nav-title">{prevBit.data.title}</span>
                    </a>
                ) : <div />}
                {nextBit ? (
                    <a href={nextBit.data.path} class="nav-card nav-next">
                        <span class="nav-label">Next</span>
                        <span class="nav-title">{nextBit.data.title}</span>
                    </a>
                ) : <div />}
            </nav>
        )}
    </main>
</BaseLayout>

<style>
    .bit-page {
        max-width: 720px;
        margin: 0 auto;
        padding: 0 var(--space-6);
    }

    .bit-header {
        padding: var(--space-16) 0 var(--space-10);
        text-align: center;
    }
    .bit-title {
        font-family: var(--font-display);
        font-size: var(--text-display);
        font-weight: 700;
        letter-spacing: -0.025em;
        color: var(--color-text);
        margin: 0 0 var(--space-4);
        line-height: 1.15;
    }
    .bit-meta {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-tertiary);
        margin-bottom: var(--space-4);
    }
    .bit-tags {
        display: flex;
        gap: var(--space-2);
        justify-content: center;
        flex-wrap: wrap;
    }
    .tag-pill {
        font-family: var(--font-ui);
        font-size: 12px;
        padding: 4px 12px;
        border-radius: 9999px;
        background: var(--color-brand-lighter);
        color: var(--color-brand-dark);
        font-weight: 500;
    }

    .bit-body {
        padding-bottom: var(--space-16);
    }

    /* Navigation */
    .bit-nav {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-4);
        padding-bottom: var(--space-20);
        border-top: 1px solid var(--color-border);
        padding-top: var(--space-10);
    }
    .nav-card {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        padding: var(--space-5);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        text-decoration: none;
        color: inherit;
        transition: transform 200ms, box-shadow 200ms;
    }
    .nav-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-elevated);
    }
    .nav-prev { text-align: left; }
    .nav-next { text-align: right; }
    .nav-label {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-tertiary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .nav-title {
        font-family: var(--font-display);
        font-size: var(--text-body);
        font-weight: 600;
        color: var(--color-text);
        line-height: 1.3;
    }
    .nav-card:hover .nav-title { color: var(--color-brand); }

    @media (max-width: 639px) {
        .bit-nav { grid-template-columns: 1fr; }
    }
</style>
