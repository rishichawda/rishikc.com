---
import BaseLayout from "../layouts/base_layout.astro";
import { buildWebPageEntity } from "../utils/jsonLd";

const page_info = {
  title: "Search | Rishi Kumar Chawda",
  description: "Search articles, bits, gallery, and content on Rishi Chawda's website",
  keywords: "search, articles, bits, gallery, photography, development",
  noindex: true,
};

const pageUrl = new URL(
  Astro.url.pathname,
  Astro.site || "https://rishikc.com",
).toString();

const pageSchemaEntities = [
  buildWebPageEntity({
    type: "SearchResultsPage",
    url: pageUrl,
    name: page_info.title,
    description: page_info.description,
  }),
];
---

<BaseLayout page_info={page_info} activeRoute="/search/" pageSchemaEntities={pageSchemaEntities}>

  <div class="search-page">
    <!-- Page Header -->
    <header class="page-header" data-reveal>
      <h1 class="page-title" id="page-title">Search</h1>
      <p class="page-subtitle" id="search-description">Discover articles, photography galleries, and inspiring quotes</p>

      <!-- Search Results Info -->
      <div id="search-results-info" class="results-info hidden" aria-live="polite" aria-atomic="true">
        <span id="results-count">0</span>
        result<span id="results-plural">s</span> found for
        &ldquo;<span id="search-query-display"></span>&rdquo;
      </div>
    </header>

    <!-- Search Input -->
    <section class="search-bar-section">
      <form class="search-form" id="search-form">
        <svg class="search-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-6-6m2-5a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z"></path>
        </svg>
        <input
          type="text"
          name="q"
          placeholder="Search articles, gallery, quotes..."
          class="search-input"
          autocomplete="off"
          id="search-input"
          aria-label="Search articles, gallery, quotes. Press Command+K to focus."
        />
        <kbd class="search-kbd" aria-hidden="true">⌘K</kbd>
        <button type="submit" class="search-submit" aria-label="Search">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-6-6m2-5a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z"></path>
          </svg>
        </button>
      </form>
    </section>

    <!-- Recent Searches -->
    <div id="recent-searches" class="recent-searches hidden">
      <div class="recent-searches-header">
        <h2 class="recent-searches-title">Recent Searches</h2>
        <button id="clear-recent" class="clear-recent" aria-label="Clear recent searches">Clear</button>
      </div>
      <div id="recent-searches-list" class="recent-searches-list"></div>
    </div>

    <!-- No Results -->
    <div id="no-results" class="no-results hidden">
      <h2 class="no-results-title">No results found</h2>
      <p class="no-results-desc">Try different keywords or explore our content sections.</p>
      <div class="no-results-links">
        <a href="/articles/" class="browse-link">Browse Articles &rarr;</a>
        <a href="/bits/" class="browse-link">Browse Bits &rarr;</a>
        <a href="/gallery/" class="browse-link">View Gallery &rarr;</a>
        <a href="/reads/" class="browse-link">Explore Quotes &rarr;</a>
      </div>
    </div>

    <!-- Search Results Container -->
    <div id="search-results" class="results-container hidden">
      <!-- Articles -->
      <section id="articles-section" class="result-section hidden">
        <div class="result-section-header">
          <h2 class="result-section-title">Articles</h2>
          <span class="result-count-badge"><span id="articles-count">0</span> results</span>
        </div>
        <div id="articles-container" class="articles-list"></div>
        <div id="articles-show-more" class="show-more-wrap hidden">
          <button class="show-more-btn">Show more articles</button>
        </div>
      </section>

      <!-- Bits -->
      <section id="bits-section" class="result-section hidden">
        <div class="result-section-header">
          <h2 class="result-section-title">Bits</h2>
          <span class="result-count-badge"><span id="bits-count">0</span> results</span>
        </div>
        <div id="bits-container" class="bits-grid"></div>
        <div id="bits-show-more" class="show-more-wrap hidden">
          <button class="show-more-btn">Show more bits</button>
        </div>
      </section>

      <!-- Gallery -->
      <section id="gallery-section" class="result-section hidden">
        <div class="result-section-header">
          <h2 class="result-section-title">Photography</h2>
          <span class="result-count-badge"><span id="gallery-count">0</span> results</span>
        </div>
        <div id="gallery-container" class="gallery-grid"></div>
        <div id="gallery-show-more" class="show-more-wrap hidden">
          <button class="show-more-btn">Show more galleries</button>
        </div>
      </section>

      <!-- Quotes -->
      <section id="quotes-section" class="result-section hidden">
        <div class="result-section-header">
          <h2 class="result-section-title">Quotes</h2>
          <span class="result-count-badge"><span id="quotes-count">0</span> results</span>
        </div>
        <div id="quotes-container" class="quotes-grid"></div>
        <div id="quotes-show-more" class="show-more-wrap hidden">
          <button class="show-more-btn">Show more quotes</button>
        </div>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .search-page {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 var(--space-6) var(--space-20);
  }

  /* Header */
  .page-header {
    text-align: center;
    padding: var(--space-20) 0 var(--space-8);
  }
  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
    line-height: 1.1;
  }
  .page-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }
  .results-info {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 8px 16px;
    margin-top: var(--space-4);
  }
  .results-info.hidden { display: none; }
  #results-count { font-weight: 700; color: var(--color-brand); }
  #search-query-display { font-weight: 600; color: var(--color-text); }

  /* Search Bar */
  .search-bar-section {
    max-width: 640px;
    margin: 0 auto var(--space-12);
  }
  .search-form {
    position: relative;
    display: flex;
    align-items: center;
  }
  .search-icon {
    position: absolute;
    left: 16px;
    width: 20px;
    height: 20px;
    color: var(--color-text-muted);
    pointer-events: none;
  }
  .search-input {
    width: 100%;
    padding: 14px 100px 14px 48px;
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text);
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: 16px;
    outline: none;
    transition: border-color 200ms, box-shadow 200ms;
  }
  .search-input::placeholder { color: var(--color-text-muted); }
  .search-input:focus {
    border-color: var(--color-brand);
    box-shadow: 0 0 0 3px var(--color-brand-lighter);
  }
  .search-kbd {
    position: absolute;
    right: 56px;
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 4px 8px;
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text-muted);
  }
  .search-submit {
    position: absolute;
    right: 8px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--btn-bg);
    border: none;
    border-radius: 10px;
    color: white;
    cursor: pointer;
    transition: filter 200ms;
  }
  .search-submit:hover { filter: brightness(0.9); }
  .search-submit svg { width: 18px; height: 18px; }

  /* No Results */
  .no-results {
    text-align: center;
    padding: var(--space-16) 0;
  }
  .no-results.hidden { display: none; }
  .no-results-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
  }
  .no-results-desc {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-8);
  }
  .no-results-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }
  .browse-link {
    font-family: var(--font-ui);
    font-size: 14px;
    font-weight: 500;
    padding: 10px 20px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    color: var(--color-text);
    text-decoration: none;
    transition: border-color 200ms, color 200ms;
  }
  .browse-link:hover {
    border-color: var(--color-brand);
    color: var(--color-brand);
  }

  /* Results Container */
  .results-container { display: flex; flex-direction: column; gap: var(--space-10); }
  .results-container.hidden { display: none; }

  /* Result Sections */
  .result-section.hidden { display: none; }
  .result-section-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }
  .result-section-title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--color-text);
    margin: 0;
  }
  .result-count-badge {
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 3px 10px;
    background: var(--color-brand-lighter);
    color: var(--color-brand-dark);
    border-radius: 8px;
  }

  /* Articles List — dynamically populated */
  .articles-list { display: flex; flex-direction: column; gap: var(--space-4); }

  /* Bits Grid */
  .bits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  /* Gallery Grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  /* Quotes Grid */
  .quotes-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
  }

  /* Show More */
  .show-more-wrap { text-align: center; margin-top: var(--space-5); }
  .show-more-wrap.hidden { display: none; }
  .show-more-btn {
    font-family: var(--font-ui);
    font-size: 14px;
    font-weight: 500;
    padding: 10px 24px;
    background: var(--btn-bg);
    color: white;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    transition: filter 200ms;
  }
  .show-more-btn:hover { filter: brightness(0.9); }

  /* ============================================================
     Dynamic element styles (used by JS STYLES object via classes)
     ============================================================ */

  /* Article result card (created by JS) */
  :global(.sr-article) { }
  :global(.sr-article-link) {
    display: flex;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 250ms, box-shadow 250ms;
  }
  :global(.sr-article-link:hover) {
    transform: translateY(-2px);
    box-shadow: var(--shadow-elevated);
  }
  :global(.sr-article-img-wrap) {
    flex-shrink: 0;
    width: 240px;
    overflow: hidden;
  }
  :global(.sr-article-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 500ms;
  }
  :global(.sr-article-link:hover .sr-article-img) {
    transform: scale(1.05);
  }
  :global(.sr-article-body) {
    flex: 1;
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-width: 0;
  }
  :global(.sr-article-title) {
    font-family: var(--font-display);
    font-size: var(--text-body-lg);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 200ms;
  }
  :global(.sr-article-link:hover .sr-article-title) {
    color: var(--color-brand);
  }
  :global(.sr-article-desc) {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0 0 8px;
  }
  :global(.sr-article-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  :global(.sr-article-tag) {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 6px;
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }
  :global(.sr-article-meta) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 12px;
    border-top: 1px solid var(--color-border);
    margin-top: 8px;
  }
  :global(.sr-article-date) {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-muted);
  }
  :global(.sr-article-read) {
    font-family: var(--font-ui);
    font-size: var(--text-body-sm);
    font-weight: 500;
    color: var(--color-brand);
    display: flex;
    align-items: center;
    gap: 4px;
  }

  /* Bit result card */
  :global(.sr-bit) {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 250ms, box-shadow 250ms;
  }
  :global(.sr-bit:hover) {
    transform: translateY(-2px);
    box-shadow: var(--shadow-elevated);
  }
  :global(.sr-bit-link) {
    display: block;
    padding: 20px;
    text-decoration: none;
    height: 100%;
  }
  :global(.sr-bit-inner) {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  :global(.sr-bit-date) {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-tertiary);
    margin-bottom: 8px;
  }
  :global(.sr-bit-title) {
    font-family: var(--font-display);
    font-size: var(--text-body-lg);
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 8px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color 200ms;
  }
  :global(.sr-bit:hover .sr-bit-title) {
    color: var(--color-brand);
  }
  :global(.sr-bit-desc) {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex-grow: 1;
    margin-bottom: 8px;
  }
  :global(.sr-bit-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 8px;
  }
  :global(.sr-bit-tag) {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 6px;
    background: var(--color-brand-lighter);
    color: var(--color-brand-dark);
  }
  :global(.sr-bit-readmore) {
    font-family: var(--font-ui);
    font-size: var(--text-body-sm);
    font-weight: 500;
    color: var(--color-brand);
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: auto;
  }

  /* Gallery result card */
  :global(.sr-gallery) {
    display: block;
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    border-radius: 12px;
    text-decoration: none;
  }
  :global(.sr-gallery-img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 500ms;
  }
  :global(.sr-gallery:hover .sr-gallery-img) {
    transform: scale(1.05);
  }
  :global(.sr-gallery-overlay) {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.2) 50%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  :global(.sr-gallery-content) {
    padding: 16px;
  }
  :global(.sr-gallery-title) {
    font-family: var(--font-display);
    font-size: var(--text-body-lg);
    font-weight: 500;
    color: white;
    margin: 0 0 4px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(.sr-gallery-desc) {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: rgba(255,255,255,0.8);
    margin: 0 0 6px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  :global(.sr-gallery-meta) {
    display: flex;
    gap: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: rgba(255,255,255,0.7);
  }
  :global(.sr-gallery-tags) {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 6px;
  }
  :global(.sr-gallery-tag) {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 2px 8px;
    background: rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.9);
    border-radius: 9999px;
  }

  /* Quote result card */
  :global(.sr-quote) {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }
  :global(.sr-quote-decoration) {
    position: absolute;
    top: -8px;
    left: -4px;
    font-size: 96px;
    font-family: serif;
    color: var(--color-brand-lighter);
    opacity: 0.3;
    user-select: none;
    z-index: 0;
  }
  :global(.sr-quote-text) {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text);
    line-height: 1.7;
    font-style: italic;
    margin: 0 0 12px;
    position: relative;
    z-index: 1;
  }
  :global(.sr-quote-cite) {
    font-family: var(--font-ui);
    font-size: var(--text-body-sm);
    font-style: italic;
    color: var(--color-text-tertiary);
    position: relative;
    z-index: 1;
  }

  @media (max-width: 767px) {
    :global(.sr-article-link) { flex-direction: column; }
    :global(.sr-article-img-wrap) { width: 100%; height: 180px; }
    .bits-grid { grid-template-columns: 1fr; }
    .gallery-grid { grid-template-columns: 1fr; }
    .quotes-grid { grid-template-columns: 1fr; }
    .search-kbd { display: none; }
    .search-input { padding-right: 56px; }
  }
  @media (min-width: 768px) and (max-width: 1023px) {
    .bits-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* Recent Searches */
  .recent-searches {
    max-width: 640px;
    margin: 0 auto var(--space-10);
  }
  .recent-searches.hidden { display: none; }
  .recent-searches-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-3);
  }
  .recent-searches-title {
    font-family: var(--font-ui);
    font-size: var(--text-caption);
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }
  .clear-recent {
    background: none;
    border: none;
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .clear-recent:hover { color: var(--color-text); }
  .recent-searches-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  :global(.recent-search-pill) {
    font-family: var(--font-ui);
    font-size: 13px;
    padding: 6px 14px;
    border-radius: 9999px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    cursor: pointer;
    transition: background 200ms, color 200ms;
    text-decoration: none;
  }
  :global(.recent-search-pill:hover) {
    background: var(--color-brand-lighter);
    color: var(--color-brand);
  }
</style>

<script>
  import { initializeSearch, type SearchRenderer, type SearchResults, type ArticleItem, type BitsItem, type GalleryItem, type QuoteItem } from "../utils/search.ts";

  const PAGINATION = {
    articles: { initial: 3, increment: 3 },
    bits: { initial: 4, increment: 4 },
    gallery: { initial: 3, increment: 3 },
    quotes: { initial: 4, increment: 4 },
  };

  const el = (tag: string, className?: string, attrs?: Record<string, string>) => {
    const element = document.createElement(tag);
    if (className) element.className = className;
    if (attrs) Object.entries(attrs).forEach(([k, v]) => element.setAttribute(k, v));
    return element;
  };

  class DOMSearchRenderer implements SearchRenderer {
    private elements: Record<string, HTMLElement> = {};
    private currentResults: SearchResults = { articles: [], bits: [], gallery: [], quotes: [] };
    private displayed = { articles: 0, bits: 0, gallery: 0, quotes: 0 };

    constructor() { this.initElements(); }

    private initElements(): void {
      const init = () => {
        const ids = [
          "page-title", "search-results-info", "search-description", "no-results", "search-results",
          "articles-section", "articles-container", "articles-count", "articles-show-more",
          "bits-section", "bits-container", "bits-count", "bits-show-more",
          "gallery-section", "gallery-container", "gallery-count", "gallery-show-more",
          "quotes-section", "quotes-container", "quotes-count", "quotes-show-more",
          "results-count", "results-plural", "search-query-display",
        ];
        if (!document.getElementById("page-title")) return setTimeout(init, 50);
        ids.forEach(id => this.elements[id] = document.getElementById(id) as HTMLElement);
        ['articles', 'bits', 'gallery', 'quotes'].forEach(type => {
          const btn = this.elements[`${type}-show-more`]?.querySelector('button');
          if (btn) btn.addEventListener('click', () => this.showMore(type));
        });
        if (window.location.search.includes("q=")) {
          window.clientSideSearchInstance?.initializeFromURL();
        }
      };
      init();
    }

    private showMore(type: string): void {
      const config = PAGINATION[type as keyof typeof PAGINATION];
      const newCount = Math.min(this.currentResults[type as keyof SearchResults].length, this.displayed[type as keyof typeof this.displayed] + config.increment);
      this.displayed[type as keyof typeof this.displayed] = newCount;
      if (type === 'articles') this.renderArticles();
      else if (type === 'bits') this.renderBits();
      else if (type === 'gallery') this.renderGallery();
      else if (type === 'quotes') this.renderQuotes();
      if (newCount >= this.currentResults[type as keyof SearchResults].length) {
        this.elements[`${type}-show-more`].classList.add("hidden");
      }
    }

    showDefaultState(): void {
      this.elements["page-title"].textContent = "Search";
      this.elements["search-results-info"].classList.add("hidden");
      this.elements["search-description"].classList.remove("hidden");
      this.elements["no-results"].classList.add("hidden");
      this.elements["search-results"].classList.add("hidden");
      ["articles", "bits", "gallery", "quotes"].forEach(type => {
        this.elements[`${type}-section`].classList.add("hidden");
        this.elements[`${type}-show-more`]?.classList.add("hidden");
      });
      renderRecentSearches();
    }

    displayResults(query: string, results: SearchResults): void {
      saveRecentSearch(query);
      const recentEl = document.getElementById('recent-searches');
      if (recentEl) recentEl.classList.add('hidden');

      const total = results.articles.length + results.bits.length + results.gallery.length + results.quotes.length;
      this.currentResults = results;
      this.displayed = { articles: 0, bits: 0, gallery: 0, quotes: 0 };
      this.elements["page-title"].textContent = "Search Results";
      this.elements["search-query-display"].textContent = query;
      this.elements["results-count"].textContent = total.toString();
      this.elements["results-plural"].textContent = total === 1 ? "" : "s";
      this.elements["search-results-info"].classList.remove("hidden");
      this.elements["search-description"].classList.add("hidden");
      if (total === 0) {
        this.elements["no-results"].classList.remove("hidden");
        this.elements["search-results"].classList.add("hidden");
        return;
      }
      this.elements["no-results"].classList.add("hidden");
      this.elements["search-results"].classList.remove("hidden");
      this.displayArticles(results.articles);
      this.displayBits(results.bits);
      this.displayGallery(results.gallery);
      this.displayQuotes(results.quotes);
    }

    hideAllSections(): void {
      ["articles", "bits", "gallery", "quotes"].forEach(type => this.elements[`${type}-section`].classList.add("hidden"));
    }

    private displaySection(type: 'articles' | 'bits' | 'gallery' | 'quotes', items: any[]): void {
      if (items.length === 0) {
        this.elements[`${type}-section`].classList.add("hidden");
        return;
      }
      this.elements[`${type}-count`].textContent = items.length.toString();
      this.elements[`${type}-section`].classList.remove("hidden");
      this.displayed[type] = Math.min(items.length, PAGINATION[type].initial);
      if (type === 'articles') this.renderArticles();
      else if (type === 'bits') this.renderBits();
      else if (type === 'gallery') this.renderGallery();
      else if (type === 'quotes') this.renderQuotes();
      this.elements[`${type}-show-more`].classList.toggle("hidden", items.length <= PAGINATION[type].initial);
    }

    displayArticles(articles: ArticleItem[]): void { this.displaySection('articles', articles); }
    displayBits(bits: BitsItem[]): void { this.displaySection('bits', bits); }
    displayGallery(gallery: GalleryItem[]): void { this.displaySection('gallery', gallery); }
    displayQuotes(quotes: QuoteItem[]): void { this.displaySection('quotes', quotes); }

    private renderArticles(): void {
      this.elements["articles-container"].innerHTML = "";
      this.currentResults.articles.slice(0, this.displayed.articles).forEach(article => {
        this.elements["articles-container"].appendChild(this.createArticleElement(article));
      });
    }
    private renderBits(): void {
      this.elements["bits-container"].innerHTML = "";
      this.currentResults.bits.slice(0, this.displayed.bits).forEach(bit => {
        this.elements["bits-container"].appendChild(this.createBitsElement(bit));
      });
    }
    private renderGallery(): void {
      this.elements["gallery-container"].innerHTML = "";
      this.currentResults.gallery.slice(0, this.displayed.gallery).forEach(item => {
        this.elements["gallery-container"].appendChild(this.createGalleryElement(item));
      });
    }
    private renderQuotes(): void {
      this.elements["quotes-container"].innerHTML = "";
      this.currentResults.quotes.slice(0, this.displayed.quotes).forEach(quote => {
        this.elements["quotes-container"].appendChild(this.createQuoteElement(quote));
      });
    }

    private createArticleElement(article: ArticleItem): HTMLElement {
      const s = window.clientSideSearchInstance;
      if (!s) return el("div");

      const articleEl = el("article", "sr-article");
      const linkEl = el("a", "sr-article-link", { href: s.escapeForAttribute(article.path) });
      const imgWrap = el("div", "sr-article-img-wrap");
      const imgEl = el("img", "sr-article-img", {
        src: s.escapeForAttribute(article.hero_image.src),
        alt: s.escapeForAttribute(article.hero_image_alt),
        width: "240", height: "160",
      });
      imgWrap.appendChild(imgEl);

      const body = el("div", "sr-article-body");
      const titleEl = el("h2", "sr-article-title");
      titleEl.textContent = article.title;
      const descEl = el("p", "sr-article-desc");
      descEl.textContent = article.description;

      const tagsEl = el("div", "sr-article-tags");
      article.tags.slice(0, 4).forEach(tag => {
        const tagEl = el("span", "sr-article-tag");
        tagEl.textContent = tag;
        tagsEl.appendChild(tagEl);
      });

      const metaEl = el("div", "sr-article-meta");
      const dateEl = el("time", "sr-article-date");
      dateEl.textContent = s.formatDate(article.date);
      const readEl = el("span", "sr-article-read");
      readEl.textContent = "Read article →";
      metaEl.append(dateEl, readEl);

      const upper = el("div");
      upper.append(titleEl, descEl, tagsEl);
      body.append(upper, metaEl);
      linkEl.append(imgWrap, body);
      articleEl.appendChild(linkEl);
      return articleEl;
    }

    private createBitsElement(bit: BitsItem): HTMLElement {
      const s = window.clientSideSearchInstance;
      if (!s) return el("div");

      const bitEl = el("article", "sr-bit");
      const linkEl = el("a", "sr-bit-link", { href: s.escapeForAttribute(bit.path) });
      const inner = el("div", "sr-bit-inner");

      const dateEl = el("p", "sr-bit-date");
      dateEl.textContent = s.formatDate(bit.date);
      const titleEl = el("h2", "sr-bit-title");
      titleEl.textContent = bit.title;
      const descEl = el("p", "sr-bit-desc");
      descEl.textContent = bit.description;

      const tagsEl = el("div", "sr-bit-tags");
      if (bit.tags && bit.tags.length > 0) {
        bit.tags.forEach(tag => {
          const tagEl = el("span", "sr-bit-tag");
          tagEl.textContent = tag;
          tagsEl.appendChild(tagEl);
        });
      }

      const readEl = el("div", "sr-bit-readmore");
      readEl.textContent = "Read more →";

      inner.append(dateEl, titleEl, descEl, tagsEl, readEl);
      linkEl.appendChild(inner);
      bitEl.appendChild(linkEl);
      return bitEl;
    }

    private createGalleryElement(item: GalleryItem): HTMLElement {
      const s = window.clientSideSearchInstance;
      if (!s) return el("div");

      const linkEl = el("a", "sr-gallery", { href: `/gallery/${s.escapeForAttribute(item.directory)}/` });
      const imgEl = el("img", "sr-gallery-img", {
        src: s.escapeForAttribute(item.featured_image.src),
        alt: s.escapeForAttribute(item.featured_image_alt),
        width: "400", height: "300",
      });

      const overlay = el("div", "sr-gallery-overlay");
      const content = el("div", "sr-gallery-content");
      const titleEl = el("h3", "sr-gallery-title");
      titleEl.textContent = item.title;
      content.appendChild(titleEl);

      if (item.description) {
        const descEl = el("p", "sr-gallery-desc");
        descEl.textContent = item.description;
        content.appendChild(descEl);
      }

      if (item.location || item.images_count > 0) {
        const metaEl = el("div", "sr-gallery-meta");
        if (item.location) {
          const locEl = el("span");
          locEl.textContent = item.location;
          metaEl.appendChild(locEl);
        }
        if (item.images_count > 0) {
          const countEl = el("span");
          countEl.textContent = `${item.images_count} photos`;
          metaEl.appendChild(countEl);
        }
        content.appendChild(metaEl);
      }

      if (item.tags?.length) {
        const tagsEl = el("div", "sr-gallery-tags");
        item.tags.slice(0, 3).forEach(tag => {
          const tagEl = el("span", "sr-gallery-tag");
          tagEl.textContent = tag;
          tagsEl.appendChild(tagEl);
        });
        content.appendChild(tagsEl);
      }

      overlay.appendChild(content);
      linkEl.append(imgEl, overlay);
      return linkEl;
    }

    private createQuoteElement(quote: QuoteItem): HTMLElement {
      const quoteEl = el("div", "sr-quote");
      const decoration = el("span", "sr-quote-decoration", { "aria-hidden": "true" });
      decoration.innerHTML = '\u201C';
      const textEl = el("p", "sr-quote-text");
      textEl.textContent = quote.quote;
      quoteEl.append(decoration, textEl);
      if (quote.info) {
        const citeEl = el("cite", "sr-quote-cite");
        citeEl.textContent = `— ${quote.info}`;
        quoteEl.appendChild(citeEl);
      }
      return quoteEl;
    }
  }

  const RECENT_SEARCHES_KEY = 'recent-searches';
  const MAX_RECENT = 8;

  function getRecentSearches(): string[] {
    try {
      return JSON.parse(localStorage.getItem(RECENT_SEARCHES_KEY) || '[]');
    } catch { return []; }
  }

  function saveRecentSearch(query: string) {
    const trimmed = query.trim();
    if (!trimmed) return;
    const recent = getRecentSearches().filter(q => q !== trimmed);
    recent.unshift(trimmed);
    localStorage.setItem(RECENT_SEARCHES_KEY, JSON.stringify(recent.slice(0, MAX_RECENT)));
  }

  function renderRecentSearches() {
    const container = document.getElementById('recent-searches');
    const list = document.getElementById('recent-searches-list');
    const clearBtn = document.getElementById('clear-recent');
    const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
    if (!container || !list) return;

    const recent = getRecentSearches();
    if (recent.length === 0) {
      container.classList.add('hidden');
      return;
    }

    list.innerHTML = '';
    recent.forEach(q => {
      const pill = document.createElement('button');
      pill.className = 'recent-search-pill';
      pill.textContent = q;
      pill.type = 'button';
      pill.addEventListener('click', () => {
        if (searchInput) {
          searchInput.value = q;
          searchInput.form?.requestSubmit();
        }
      });
      list.appendChild(pill);
    });

    container.classList.remove('hidden');

    clearBtn?.addEventListener('click', () => {
      localStorage.removeItem(RECENT_SEARCHES_KEY);
      container.classList.add('hidden');
    }, { once: true });
  }

  const setupKeyboardShortcuts = () => {
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    if (!searchInput) return;
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        searchInput.focus();
        searchInput.select();
      }
      if (e.key === 'Escape' && document.activeElement === searchInput) {
        searchInput.blur();
      }
    });
  };

  const fetchSearchIndex = async () => {
    if (window.searchIndex) return;
    try {
      const response = await fetch('/api/search-index.json');
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      window.searchIndex = await response.json();
    } catch (error) {
      console.error('Failed to load search index:', error);
    }
  };

  const initializeSearchWithRetry = async () => {
    await fetchSearchIndex();
    if (window.searchIndex) {
      const renderer = new DOMSearchRenderer();
      initializeSearch(renderer);
    }
  };

  document.addEventListener("DOMContentLoaded", () => {
    initializeSearchWithRetry();
    setupKeyboardShortcuts();
    renderRecentSearches();
  });

  document.addEventListener("astro:page-load", () => {
    setTimeout(() => {
      initializeSearchWithRetry();
      setupKeyboardShortcuts();
      renderRecentSearches();
    }, 50);
  });
</script>
