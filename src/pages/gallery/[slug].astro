---
import BaseLayout from "../../layouts/base_layout.astro";
import "../../styles/global.css";
import "../../styles/gallery.css";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { buildWebPageEntity, personRef } from "../../utils/jsonLd";
import type { ImageObject as SchemaImageObject } from "schema-dts";
import Lightbox from "../../components/gallery/lightbox.astro";
import Breadcrumbs from "../../components/common/breadcrumbs.astro";
import masonry from "masonry-layout/dist/masonry.pkgd.min?url";
import imagesloaded from "imagesloaded/imagesloaded.pkgd.min?url";

interface Social {
  platform: string;
  url: string;
}
interface ProfileData {
  name: string;
  socials: Social[];
}

const profileEntry = await getCollection("profile");
const profile = profileEntry[0].data as ProfileData;

export async function getStaticPaths() {
  const galleries = await getCollection("gallery");
  return galleries.map((gallery) => ({
    params: { slug: gallery.data.directory },
    props: { gallery },
  }));
}

const { gallery } = Astro.props;

const {
  title,
  description,
  featured_image,
  tags,
  images: unsortedImages,
} = gallery.data;

// Sort images: featured image first, then by date (newest first)
const images =
  unsortedImages?.sort((a, b) => {
    const isAFeatured = a.src.src === featured_image.src;
    const isBFeatured = b.src.src === featured_image.src;

    if (isAFeatured) return -1;
    if (isBFeatured) return 1;

    const dateA = a.date ? new Date(a.date) : new Date(0);
    const dateB = b.date ? new Date(b.date) : new Date(0);
    return dateB.getTime() - dateA.getTime();
  }) || [];

const page_info = {
  title: `${title} - ${profile.name}`,
  description: description,
  image: featured_image.src,
  keywords: `photography, ${title.toLowerCase()}, portfolio, ${profile.name}`,
};

// Prepare image array for JSON-LD
const galleryImageUrls: SchemaImageObject[] =
  images?.map((img) => {
    const imageObject: SchemaImageObject = {
      "@type": "ImageObject",
      contentUrl: new URL(
        img.src.src,
        Astro.site || "https://rishikc.com",
      ).toString(),
      name: img.caption || img.alt || `${title} image`,
      description: img.caption || img.alt || `Image from ${title} gallery`,
    };
    return imageObject;
  }) || [];

const pageUrl = new URL(
  Astro.url.pathname,
  Astro.site || "https://rishikc.com",
).toString();

const pageSchemaEntities = [
  buildWebPageEntity({
    url: pageUrl,
    name: page_info.title,
    description: description,
    mainEntity: {
      "@type": "ImageGallery",
      headline: title,
      description: description,
      author: personRef,
      keywords: tags?.join(", "),
      associatedMedia: galleryImageUrls,
    },
  }),
];
---

<BaseLayout page_info={page_info} pageSchemaEntities={pageSchemaEntities}>

  <main class="gallery-page min-h-screen">
    <div class="page-container">
      <Breadcrumbs items={[
        { label: "Gallery", href: "/gallery/" },
        { label: title },
      ]} />

      <div class="page-header">
        <h1
          class="page-title"
          transition:name={`${gallery.id}-title`}
        >
          {title}
        </h1>
        <p
          class="page-subtitle"
          transition:name={`${gallery.id}-description`}
        >
          {description}
        </p>
        {tags && tags.length > 0 && (
          <div class="tag-list">
            {tags.map((tag) => (
              <span
                class="tag-pill"
                transition:name={`${gallery.id}-${tag}`}
              >
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>

      <!-- Masonry Grid -->
      <div id="masonry-grid" class="masonry-grid">
        {images.map((image, index) => (
          <button
            type="button"
            class="grid-item group lightbox-trigger"
            data-cursor="image"
            data-caption={image.caption || ""}
            data-camera={image.camera || ""}
            data-lens={image.lens || ""}
            data-settings={image.settings || ""}
            data-location={image.location || ""}
            aria-label={`View full size: ${image.alt || image.caption || `photo ${index + 1}`}`}
          >
            <Image
              src={image.src}
              alt=""
              class="grid-image"
              widths={[400, 800, 1200]}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
              loading={index < 3 ? "eager" : "lazy"}
            />
            {image.caption && (
              <div class="caption-overlay">
                <p class="caption-text">{image.caption}</p>
              </div>
            )}
          </button>
        ))}
      </div>

      <p class="copyright-text">
        All photographs displayed in this gallery are the intellectual property
        of {profile.name}. Any reproduction, distribution, or use of these
        images, in whole or in part, without explicit written permission from
        the copyright holder is strictly prohibited.
      </p>
    </div>
  </main>

  <Lightbox />

  <script src={masonry} is:inline></script>
  <script src={imagesloaded} is:inline></script>

  <script is:inline>
    document.addEventListener("astro:page-load", () => {
      const grid = document.querySelector("#masonry-grid");
      if (grid) {
        const imgLoad = imagesLoaded(grid);

        imgLoad.on("always", function () {
          const msnry = new Masonry(grid, {
            itemSelector: ".grid-item",
            columnWidth: ".grid-item",
            percentPosition: true,
            gutter: 16,
          });

          window.addEventListener("resize", () => {
            let newGutter = 16;
            if (window.innerWidth >= 640) {
              newGutter = 24;
            }
            msnry.options.gutter = newGutter;
            msnry.layout();
          });

          setTimeout(() => msnry.layout(), 100);
        });
      }
    });
  </script>
</BaseLayout>

<style>
  .page-container {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: var(--space-16) var(--space-4) var(--space-12);
  }

  @media (min-width: 640px) {
    .page-container {
      padding: var(--space-20) var(--space-6) var(--space-16);
    }
  }

  /* ─── Back Link ─── */
  .back-link {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2) var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    color: var(--color-text-secondary);
    font-family: var(--font-ui);
    font-size: var(--text-body-sm);
    font-weight: 500;
    transition: all var(--duration-normal) ease;
    margin-bottom: var(--space-12);
  }

  @media (min-width: 640px) {
    .back-link {
      margin-bottom: var(--space-16);
    }
  }

  .back-link:hover {
    color: var(--color-brand);
    border-color: var(--color-brand-light);
    box-shadow: var(--shadow-subtle);
  }

  .back-arrow {
    width: 16px;
    height: 16px;
    margin-right: var(--space-2);
    transition: transform var(--duration-normal) ease;
  }

  .back-link:hover .back-arrow {
    transform: translateX(-2px);
  }

  /* ─── Page Header ─── */
  .page-header {
    max-width: 768px;
    margin: 0 auto var(--space-16);
    text-align: center;
  }

  @media (min-width: 640px) {
    .page-header {
      margin-bottom: var(--space-20);
    }
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: var(--space-6);
  }

  @media (min-width: 640px) {
    .page-title {
      margin-bottom: var(--space-8);
    }
  }

  .page-subtitle {
    color: var(--color-text-secondary);
    font-size: var(--text-body-lg);
    line-height: 1.6;
    font-weight: 300;
    max-width: 640px;
    margin: 0 auto;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
    margin-top: var(--space-8);
  }

  @media (min-width: 640px) {
    .tag-list {
      gap: var(--space-3);
      margin-top: var(--space-10);
    }
  }

  .tag-pill {
    font-size: var(--text-caption);
    background: var(--color-brand-lighter);
    color: var(--color-brand-darker);
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-full);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 500;
    transition: background var(--duration-normal) ease;
  }

  .tag-pill:hover {
    background: var(--color-brand-light);
  }

  /* ─── Masonry Grid ─── */
  .masonry-grid {
    position: relative;
    margin: 0;
    padding: var(--space-4) 0;
  }

  .grid-item {
    width: 100%;
    margin-bottom: 1rem;
    position: relative;
    aspect-ratio: auto;
    overflow: hidden;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-subtle);
    transition: box-shadow var(--duration-normal) ease;
    cursor: pointer;
    border: none;
    padding: 0;
    background: transparent;
    display: block;
    text-align: left;
  }

  .grid-item:hover {
    box-shadow: var(--shadow-elevated);
  }

  .grid-item:focus-visible {
    outline: 2px solid var(--color-brand);
    outline-offset: 2px;
  }

  @media (min-width: 640px) {
    .grid-item {
      width: calc(50% - 12px);
      margin-bottom: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .grid-item {
      width: calc(33.333% - 16px);
      margin-bottom: 1.5rem;
    }
  }

  .grid-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) ease;
  }

  .grid-item:hover .grid-image {
    transform: scale(1.05);
  }

  /* ─── Caption Overlay ─── */
  .caption-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, transparent 100%);
    padding: var(--space-8) var(--space-4) var(--space-4);
    opacity: 0;
    transform: translateY(4px);
    transition:
      opacity var(--duration-normal) ease,
      transform var(--duration-normal) ease;
    pointer-events: none;
  }

  .grid-item:hover .caption-overlay,
  .grid-item:focus-visible .caption-overlay {
    opacity: 1;
    transform: translateY(0);
  }

  .caption-text {
    color: rgba(255, 255, 255, 0.9);
    font-size: var(--text-body-sm);
    font-weight: 300;
    line-height: 1.4;
    margin: 0;
  }

  /* ─── Copyright ─── */
  .copyright-text {
    text-align: center;
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    margin-top: var(--space-12);
    font-weight: 300;
  }

  @media (min-width: 640px) {
    .copyright-text {
      font-size: var(--text-body-sm);
      margin-top: var(--space-16);
    }
  }
</style>
