---
import BaseLayout from "../../../layouts/base_layout.astro";
import "../../../styles/global.css";
import "../../../styles/gallery.css";
import { getCollection } from "astro:content";
import { buildWebPageEntity, personRef } from "../../../utils/jsonLd";
import StoryHero from "../../../components/gallery/story_hero.astro";
import StorySection from "../../../components/gallery/story_section.astro";
import StoryEpilogue from "../../../components/gallery/story_epilogue.astro";
import ScenarioRenderer from "../../../components/gallery/scenario_renderer.astro";
import Lightbox from "../../../components/gallery/lightbox.astro";
import ScrollProgress from "../../../components/gallery/scroll_progress.astro";
// Gallery CustomCursor is now handled by site-wide cursor in base_layout

interface Social {
  platform: string;
  url: string;
}
interface ProfileData {
  name: string;
  socials: Social[];
}

const profileEntry = await getCollection("profile");
const profile = profileEntry[0].data as ProfileData;

export async function getStaticPaths() {
  const stories = await getCollection("photo_stories");
  return stories.map((story) => {
    const slug = story.data.path
      .replace("/gallery/stories/", "")
      .replace(/\/$/, "");
    return {
      params: { slug },
      props: { story },
    };
  });
}

const { story } = Astro.props;
const {
  title,
  description,
  cover_image,
  cover_image_alt,
  prologue,
  sections,
  epilogue,
  tags,
  date,
  scenario,
} = story.data;

// Use scenario renderer for non-default scenarios
const useScenarioRenderer = scenario && scenario !== "scrollytelling";

const page_info = {
  title: `${title} — ${profile.name}`,
  description,
  image: cover_image.src,
  keywords: `photography, visual essay, ${tags?.join(", ") || ""}, ${profile.name}`,
};

const pageUrl = new URL(
  Astro.url.pathname,
  Astro.site || "https://rishikc.com",
).toString();

// Get all stories for "Next Story" CTA
const allStories = await getCollection("photo_stories");
const currentIndex = allStories.findIndex((s) => s.id === story.id);
const nextStory = allStories[(currentIndex + 1) % allStories.length];
const hasNextStory = allStories.length > 1;

const pageSchemaEntities = [
  buildWebPageEntity({
    url: pageUrl,
    name: page_info.title,
    description: description,
    mainEntity: {
      "@type": "Article",
      headline: title,
      description: description,
      image: cover_image.src,
      datePublished: date.toISOString(),
      author: personRef,
      keywords: tags?.join(", "),
    },
  }),
];
---

<BaseLayout page_info={page_info} pageSchemaEntities={pageSchemaEntities}>
  <ScrollProgress />

  <main class="gallery-page story-page relative min-h-screen">
    <!-- Back to gallery breadcrumb -->
    <nav class="story-breadcrumb" aria-label="Breadcrumb">
      <a href="/gallery/" class="breadcrumb-link">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Gallery
      </a>
    </nav>

    <!-- Scenario-aware rendering -->
    {
      useScenarioRenderer ? (
        <ScenarioRenderer
          scenario={scenario}
          title={title}
          prologue={prologue}
          cover_image={cover_image}
          cover_image_alt={cover_image_alt}
          sections={sections}
          storyId={story.id}
        />
      ) : (
        <>
          <StoryHero
            title={title}
            prologue={prologue}
            cover_image={cover_image}
            cover_image_alt={cover_image_alt}
            storyId={story.id}
          />

          <div class="relative">
            {sections.map((section, index) => (
              <StorySection section={section} index={index} />
            ))}
          </div>
        </>
      )
    }

    <!-- Epilogue -->
    <StoryEpilogue epilogue={epilogue} />

    <!-- Next Story CTA -->
    {
      hasNextStory && nextStory && nextStory.id !== story.id && (
        <section class="next-story-section" aria-label="Next story">
          <div class="next-story-inner">
            <span class="next-label">Next Story</span>
            <a href={nextStory.data.path} class="next-link group">
              <h2 class="next-title">{nextStory.data.title}</h2>
              <span class="next-cta">
                Read Story
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="next-arrow"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M14 5l7 7m0 0l-7 7m7-7H3"
                  />
                </svg>
              </span>
            </a>
          </div>
        </section>
      )
    }

    <!-- Copyright -->
    <footer class="story-copyright">
      <p>
        All photographs displayed are the intellectual property of {
          profile.name
        }. Any reproduction, distribution, or use of these images without
        explicit written permission is strictly prohibited.
      </p>
    </footer>
  </main>

  <Lightbox />
</BaseLayout>

<style>
  /* ─── Breadcrumb Navigation ─── */
  .story-breadcrumb {
    position: absolute;
    top: calc(var(--nav-height, 64px) + var(--space-4));
    left: var(--space-6);
    z-index: 30;
  }

  @media (min-width: 640px) {
    .story-breadcrumb {
      left: var(--space-8);
    }
  }

  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--text-caption);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition:
      color var(--duration-normal) ease,
      background var(--duration-normal) ease;
    letter-spacing: 0.02em;
    padding: 6px 14px;
    border-radius: 9999px;
    background: rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .breadcrumb-link:hover {
    color: rgba(255, 255, 255, 1);
    background: rgba(0, 0, 0, 0.5);
  }

  .breadcrumb-link svg {
    transition: transform var(--duration-normal) ease;
  }

  .breadcrumb-link:hover svg {
    transform: translateX(-2px);
  }

  /* ─── Next Story CTA ─── */
  .next-story-section {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-16);
    padding: var(--space-16) 0;
  }

  @media (min-width: 640px) {
    .next-story-section {
      margin-top: var(--space-24);
      padding: var(--space-24) 0;
    }
  }

  .next-story-inner {
    max-width: 768px;
    margin: 0 auto;
    padding: 0 var(--space-6);
    text-align: center;
  }

  @media (min-width: 640px) {
    .next-story-inner {
      padding: 0 var(--space-8);
    }
  }

  .next-label {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .next-link {
    display: inline-block;
  }

  .next-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--color-text);
    line-height: 1.2;
    margin-bottom: var(--space-3);
    transition: color var(--duration-normal) ease;
  }

  .next-link:hover .next-title {
    color: var(--color-brand);
  }

  .next-cta {
    display: inline-flex;
    align-items: center;
    color: var(--color-text-muted);
    font-size: var(--text-body-sm);
    transition: color var(--duration-normal) ease;
  }

  .next-link:hover .next-cta {
    color: var(--color-brand);
  }

  .next-arrow {
    width: 16px;
    height: 16px;
    margin-left: var(--space-2);
    transition: transform var(--duration-normal) ease;
  }

  .next-link:hover .next-arrow {
    transform: translateX(4px);
  }

  /* ─── Copyright ─── */
  .story-copyright {
    padding: var(--space-8) var(--space-6);
  }

  @media (min-width: 640px) {
    .story-copyright {
      padding: var(--space-12) var(--space-8);
    }
  }

  .story-copyright p {
    text-align: center;
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    font-weight: 300;
    max-width: 640px;
    margin: 0 auto;
    opacity: 0.6;
  }
</style>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const reveals = document.querySelectorAll(".gallery-reveal");
    if (reveals.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("revealed");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
    );

    reveals.forEach((el) => observer.observe(el));

    // Immediately reveal elements to prevent invisible content on page load
    requestAnimationFrame(() => {
      const vh = window.innerHeight || 800;
      reveals.forEach((el) => {
        const rect = el.getBoundingClientRect();
        const delay =
          rect.top > vh ? Math.min(800, ((rect.top - vh) / vh) * 100) : 0;
        el.style.transitionDelay = Math.round(delay) + "ms";
        el.classList.add("revealed");
        observer.unobserve(el);
      });
    });
  });
</script>
