---
import BaseLayout from "../../layouts/base_layout.astro";
import "../../styles/global.css";
import "../../styles/gallery.css";
import StoryCard from "../../components/gallery/story_card.astro";
import ProjectCard from "../../components/gallery/project_card.astro";
import CustomCursor from "../../components/gallery/custom_cursor.astro";
import { getCollection } from "astro:content";
import { Schema } from "astro-seo-schema";
import type { ListItem, ImageGallery as SchemaImageGallery } from "schema-dts";

// Define interfaces needed for profile data
interface Social {
  platform: string;
  url: string;
}
interface ProfileData {
  name: string;
  socials: Social[];
}

// Fetch profile data
const profileEntry = await getCollection("profile");
const profile = profileEntry[0].data as ProfileData;

// Find the Instagram social link
const instagramSocial = profile.socials.find(
  (social) => social.platform.toLowerCase() === "instagram",
);

const page_info = {
  title: `Gallery — ${profile.name}`,
  description: `Visual stories and photography by ${profile.name}. Immersive photo essays exploring landscapes, streets, and the world through a lens.`,
  keywords: `photography, portfolio, gallery, visual essays, ${profile.name}`,
};

// Get stories and galleries
const stories = await getCollection("photo_stories");
const sortedStories = stories.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date) : new Date(0);
  const dateB = b.data.date ? new Date(b.data.date) : new Date(0);
  return dateB.getTime() - dateA.getTime();
});

const galleries = await getCollection("gallery");
const sortedGalleries = galleries.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date) : new Date(0);
  const dateB = b.data.date ? new Date(b.data.date) : new Date(0);
  return dateB.getTime() - dateA.getTime();
});

const pageUrl = new URL(
  Astro.url.pathname,
  Astro.site || "https://rishikc.com",
).toString();

// Create gallery items for JSON-LD
const galleryItems = galleries.map((gallery) => {
  const gallerySchema: SchemaImageGallery = {
    "@type": "ImageGallery",
    name: gallery.data.title,
    description: gallery.data.description,
    url: new URL(
      `/gallery/${gallery.data.directory}/`,
      Astro.site || "https://rishikc.com",
    ).toString(),
    image: new URL(
      gallery.data.featured_image.src,
      Astro.site || "https://rishikc.com",
    ).toString(),
  };
  return gallerySchema;
});

const itemListElements: ListItem[] = galleryItems.map(
  (gallerySchema, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: gallerySchema,
  }),
);

const hasStories = sortedStories.length > 0;
---

<BaseLayout page_info={page_info}>
  <Schema
    slot="head"
    item={{
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      name: "Photography Gallery",
      description: page_info.description,
      mainEntity: {
        "@type": "ItemList",
        itemListElement: itemListElements,
      },
      author: {
        "@type": "Person",
        name: profile.name,
        url: "https://rishikc.com",
        sameAs: profile.socials.map((social: Social) => social.url),
      },
      url: pageUrl,
      potentialAction: [
        {
          "@type": "ViewAction",
          target: pageUrl,
          name: "Browse Photography Portfolio"
        },
        {
          "@type": "ShareAction",
          target: [
            {
              "@type": "EntryPoint",
              urlTemplate: `https://twitter.com/intent/tweet?url=${encodeURIComponent(pageUrl)}&text=${encodeURIComponent(`Check out ${profile.name}'s Photography Portfolio`)}`,
              actionPlatform: "https://schema.org/DesktopWebPlatform"
            },
            {
              "@type": "EntryPoint",
              urlTemplate: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`,
              actionPlatform: "https://schema.org/DesktopWebPlatform"
            }
          ],
          name: "Share Gallery"
        }
      ]
    }}
  />

  <main class="font-['Red_Hat_Display_Variable'] min-h-screen bg-gallery-bg">
    <!-- Hero Section -->
    <div class="relative py-20 sm:py-28 lg:py-36 px-6 sm:px-8">
      <div class="max-w-5xl mx-auto text-center">
        <a
          href="/"
          class="group inline-flex items-center px-4 py-2.5 bg-gallery-bg-secondary/80 backdrop-blur-sm border border-gallery-border rounded-full text-gallery-text/70 hover:text-gallery-text hover:bg-gallery-bg-secondary transition-all duration-300 text-sm font-light mb-16 sm:mb-20"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 mr-2 group-hover:-translate-x-1 transition-transform duration-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"
            ></path>
          </svg>
          Home
        </a>

        <h1 class="text-4xl sm:text-5xl lg:text-[64px] font-bold text-gallery-text leading-[1.1] tracking-tight mb-6">
          Visual Stories
        </h1>
        <p class="text-gallery-text-muted text-lg sm:text-xl leading-relaxed font-light max-w-2xl mx-auto mb-8">
          Photo essays and visual narratives — exploring the world one frame at a time.
        </p>
        {instagramSocial && (
          <a
            href={instagramSocial.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center text-sm text-gallery-text-muted hover:text-gallery-accent transition-colors duration-300 group"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 mr-2 opacity-70 group-hover:opacity-100 transition-opacity"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
            </svg>
            Instagram
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 ml-1 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        )}
      </div>
    </div>

    <!-- Stories Bento Grid -->
    {hasStories && (
      <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 sm:pb-28" aria-label="Visual stories">
        <div class="bento-grid">
          {sortedStories.map((story, index) => (
            <StoryCard story={story} featured={index === 0} />
          ))}
        </div>
      </section>
    )}

    <!-- Browse by Category -->
    <section class="border-t border-gallery-border" aria-label="Browse by category">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
        <div class="text-center mb-12 sm:mb-16">
          <h2 class="meta-label text-gallery-text-muted mb-4">Browse by Category</h2>
          <p class="text-gallery-text/70 text-base font-light max-w-lg mx-auto">
            Explore the full collection organized by theme and subject.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
          {sortedGalleries.map((gallery) => (
            <ProjectCard project={gallery} />
          ))}
        </div>
      </div>
    </section>

    <!-- Copyright -->
    <footer class="py-8 sm:py-12 px-6 sm:px-8 border-t border-gallery-border">
      <p class="text-center text-xs text-gallery-text-muted/60 font-light max-w-2xl mx-auto">
        All photographs displayed in this gallery are the intellectual property
        of {profile.name}. Any reproduction, distribution, or use of these
        images, in whole or in part, without explicit written permission from
        the copyright holder is strictly prohibited.
      </p>
    </footer>
  </main>

  <CustomCursor />
</BaseLayout>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const reveals = document.querySelectorAll(".gallery-reveal");
    if (reveals.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("revealed");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
    );

    reveals.forEach((el) => observer.observe(el));

    // Ripple effect on clickable cards
    document.querySelectorAll(".gallery-ripple").forEach(function(el) {
      el.addEventListener("click", function(e) {
        var rect = el.getBoundingClientRect();
        el.style.setProperty("--ripple-x", (e.clientX - rect.left) + "px");
        el.style.setProperty("--ripple-y", (e.clientY - rect.top) + "px");
        el.classList.remove("rippling");
        void el.offsetWidth;
        el.classList.add("rippling");
        setTimeout(function() { el.classList.remove("rippling"); }, 400);
      });
    });
  });
</script>
