---
import BaseLayout from "../../layouts/base_layout.astro";
import "../../styles/global.css";
import "../../styles/gallery.css";
import StoryCard from "../../components/gallery/story_card.astro";
import ProjectCard from "../../components/gallery/project_card.astro";
import { getCollection } from "astro:content";
import { buildWebPageEntity, personRef } from "../../utils/jsonLd";
import type { ListItem, ImageGallery as SchemaImageGallery } from "schema-dts";
import Breadcrumbs from "../../components/common/breadcrumbs.astro";

import { Image } from "astro:assets";

// Define interfaces needed for profile data
interface Social {
  platform: string;
  url: string;
}
interface ProfileData {
  name: string;
  socials: Social[];
}

// Fetch profile data
const profileEntry = await getCollection("profile");
const profile = profileEntry[0].data as ProfileData;

// Find the Instagram social link
const instagramSocial = profile.socials.find(
  (social) => social.platform.toLowerCase() === "instagram",
);

const page_info = {
  title: `Gallery | ${profile.name}`,
  description: `Visual stories and photography by ${profile.name}. Immersive photo essays exploring landscapes, streets, and the world through a lens.`,
  keywords: `photography, portfolio, gallery, visual essays, ${profile.name}`,
};

// Get stories and galleries
const stories = await getCollection("photo_stories");
const sortedStories = stories.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date) : new Date(0);
  const dateB = b.data.date ? new Date(b.data.date) : new Date(0);
  return dateB.getTime() - dateA.getTime();
});

const galleries = await getCollection("gallery");
const sortedGalleries = galleries.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date) : new Date(0);
  const dateB = b.data.date ? new Date(b.data.date) : new Date(0);
  return dateB.getTime() - dateA.getTime();
});

const pageUrl = new URL(
  Astro.url.pathname,
  Astro.site || "https://rishikc.com",
).toString();

// Create gallery items for JSON-LD
const galleryItems = galleries.map((gallery) => {
  const gallerySchema: SchemaImageGallery = {
    "@type": "ImageGallery",
    name: gallery.data.title,
    description: gallery.data.description,
    url: new URL(
      `/gallery/${gallery.data.directory}/`,
      Astro.site || "https://rishikc.com",
    ).toString(),
    image: new URL(
      gallery.data.featured_image.src,
      Astro.site || "https://rishikc.com",
    ).toString(),
  };
  return gallerySchema;
});

const itemListElements: ListItem[] = galleryItems.map(
  (gallerySchema, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: gallerySchema,
  }),
);

const hasStories = sortedStories.length > 0;
const featuredStory = sortedStories[0];
const remainingStories = sortedStories.slice(1);

const pageSchemaEntities = [
  buildWebPageEntity({
    type: "CollectionPage",
    url: pageUrl,
    name: "Photography Gallery",
    description: page_info.description,
    mainEntity: {
      "@type": "ItemList",
      itemListElement: itemListElements,
    },
  }),
];
---

<BaseLayout page_info={page_info} pageSchemaEntities={pageSchemaEntities}>

  <!-- Pre-rendered notification for theme switch — prevents z-index flash -->
  <div class="gallery-theme-note-backdrop" id="gallery-backdrop" aria-hidden="true"></div>
  <div class="gallery-theme-note" id="gallery-note" role="status" aria-live="polite" aria-label="Theme switched for gallery">
    <p style="margin:0;">Switched to dark mode for the best photo viewing experience. Your previous theme will be restored when you leave this page. You can still toggle the theme manually anytime.</p>
    <button class="gallery-theme-note-btn" id="gallery-note-btn">Got it</button>
  </div>
  <script is:inline>
    // Blocking script: check theme before page paints gallery images
    (function() {
      var shown = sessionStorage.getItem("gallery-theme-note-shown");
      var manualOverride = sessionStorage.getItem("gallery-manual-override") === "true";
      var current = document.documentElement.getAttribute("data-theme") || "light";
      if (!shown && !manualOverride && current !== "dark") {
        sessionStorage.setItem("gallery-prev-theme", current);
        document.documentElement.setAttribute("data-theme", "dark");
        localStorage.setItem("theme", "dark");
        document.getElementById("gallery-backdrop").classList.add("visible");
        document.getElementById("gallery-note").classList.add("visible");
        sessionStorage.setItem("gallery-theme-note-shown", "true");
      }
    })();
  </script>

  <div class="gallery-page min-h-screen">
    <Breadcrumbs items={[{ label: "Gallery" }]} />

    <!-- Hero Section -->
    <header class="page-header">
      <div class="header-inner">
        <span class="overline">Visual Stories</span>
        <h1 class="page-title">Gallery</h1>
        <p class="page-subtitle">
          Photo essays and visual narratives — exploring the world one frame at a time.
        </p>
        {instagramSocial && (
          <a
            href={instagramSocial.url}
            target="_blank"
            rel="noopener noreferrer"
            class="instagram-link group"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="icon"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
            </svg>
            Instagram
            <span class="sr-only">(opens in new tab)</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="arrow-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        )}
      </div>
    </header>

    <!-- Stories Section -->
    {hasStories ? (
      <>
        <!-- Featured Story Hero -->
        {featuredStory && (
          <section class="featured-section" aria-label="Featured story">
            <a
              href={featuredStory.data.path}
              class="featured-card group gallery-reveal gallery-ripple"
            >
              <Image
                src={featuredStory.data.cover_image}
                alt={featuredStory.data.cover_image_alt || featuredStory.data.title}
                class="featured-image"
                widths={[640, 1024, 1920]}
                sizes="(max-width: 768px) 100vw, 1280px"
                loading="eager"
                fetchpriority="high"
                transition:name={`story-cover-${featuredStory.id}`}
              />
              <div class="featured-gradient"></div>
              <div class="featured-content">
                <span class="featured-label">Featured Story</span>
                <h2
                  class="featured-title"
                  transition:name={`${featuredStory.id}-title`}
                >
                  {featuredStory.data.title}
                </h2>
                <p class="featured-desc">
                  {featuredStory.data.description}
                </p>
                <span class="featured-cta">
                  Read Story
                  <svg xmlns="http://www.w3.org/2000/svg" class="featured-cta-arrow" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                  </svg>
                </span>
              </div>
            </a>
          </section>
        )}

        <!-- Stories Bento Grid -->
        {remainingStories.length > 0 && (
          <section class="stories-section" aria-label="Visual stories">
            <div class="bento-grid">
              {remainingStories.map((story, index) => (
                <StoryCard story={story} featured={index === 0} />
              ))}
            </div>
          </section>
        )}
      </>
    ) : (
      <section class="stories-placeholder" aria-label="Stories coming soon">
        <div class="placeholder-inner">
          <div class="placeholder-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
            </svg>
          </div>
          <h2 class="placeholder-title">Stories & Essays Coming Soon</h2>
          <p class="placeholder-text">
            I'm currently curating photo stories and essays — immersive visual narratives
            that go beyond single images. They'll be here soon.
          </p>
          <p class="placeholder-text italic opacity-70">
            You can browse the existing photos below, and follow me on Instagram for the latest updates.
          </p>
          <span class="placeholder-badge">
            <span class="placeholder-dot" aria-hidden="true"></span>
            In Progress
          </span>
        </div>
      </section>
    )}

    <!-- Browse by Category -->
    <section class="category-section" aria-label="Browse by category">
      <div class="category-inner">
        <div class="category-header">
          <span class="overline">Browse by Category</span>
          <p class="category-subtitle">
            Explore the full collection organized by theme and subject.
          </p>
        </div>
        <div class="category-grid">
          {sortedGalleries.map((gallery) => (
            <ProjectCard project={gallery} />
          ))}
        </div>
      </div>
    </section>

    <!-- Copyright -->
    <footer class="copyright-footer">
      <p>
        All photographs displayed in this gallery are the intellectual property
        of {profile.name}. Any reproduction, distribution, or use of these
        images, in whole or in part, without explicit written permission from
        the copyright holder is strictly prohibited.
      </p>
    </footer>
  </div>
</BaseLayout>

<style>
  /* ─── Page Header ─── */
  .page-header {
    padding: var(--space-20) var(--space-6) var(--space-12);
    text-align: center;
  }

  @media (min-width: 640px) {
    .page-header {
      padding: var(--space-24) var(--space-8) var(--space-16);
    }
  }

  .header-inner {
    max-width: var(--max-content);
    margin: 0 auto;
  }

  .overline {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand);
    margin-bottom: var(--space-4);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-display-xl);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-6);
  }

  .page-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 640px;
    margin: 0 auto var(--space-8);
  }

  .instagram-link {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-body-sm);
    color: var(--color-text-tertiary);
    transition: color var(--duration-normal) ease;
    gap: var(--space-2);
  }

  .instagram-link:hover {
    color: var(--color-brand);
  }

  .instagram-link .icon {
    width: 16px;
    height: 16px;
    opacity: 0.7;
    transition: opacity var(--duration-normal) ease;
  }

  .instagram-link:hover .icon {
    opacity: 1;
  }

  .instagram-link .arrow-icon {
    width: 12px;
    height: 12px;
    transition: transform var(--duration-normal) ease;
  }

  .instagram-link:hover .arrow-icon {
    transform: translateX(2px);
  }

  /* ─── Featured Story ─── */
  .featured-section {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: 0 var(--space-4) var(--space-16);
  }

  @media (min-width: 640px) {
    .featured-section {
      padding: 0 var(--space-6) var(--space-20);
    }
  }

  .featured-card {
    display: block;
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg);
    aspect-ratio: 21/9;
  }

  @media (max-width: 767px) {
    .featured-card {
      aspect-ratio: 4/3;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .featured-card {
      aspect-ratio: 16/9;
    }
  }

  .featured-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-emphasis) ease;
  }

  .featured-card:hover .featured-image {
    transform: scale(1.05);
  }

  .featured-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 40%, transparent 70%);
  }

  .featured-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-6) var(--space-6);
  }

  @media (min-width: 640px) {
    .featured-content {
      padding: var(--space-10);
    }
  }

  .featured-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand);
    background: rgba(154, 167, 215, 0.15);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-3);
  }

  .featured-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 700;
    letter-spacing: -0.015em;
    color: #fff;
    line-height: 1.1;
    margin-bottom: var(--space-3);
    transition: color var(--duration-normal) ease;
  }

  .featured-card:hover .featured-title {
    color: var(--color-brand);
  }

  .featured-desc {
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-body);
    font-weight: 300;
    max-width: 640px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .featured-desc {
      font-size: var(--text-body-lg);
    }
  }

  .featured-cta {
    display: inline-flex;
    align-items: center;
    color: rgba(255, 255, 255, 0.6);
    font-size: var(--text-body-sm);
    margin-top: var(--space-4);
    transition: color var(--duration-normal) ease;
  }

  .featured-card:hover .featured-cta {
    color: var(--color-brand);
  }

  .featured-cta-arrow {
    width: 16px;
    height: 16px;
    margin-left: var(--space-2);
    transition: transform var(--duration-normal) ease;
  }

  .featured-card:hover .featured-cta-arrow {
    transform: translateX(4px);
  }

  /* ─── Stories Placeholder ─── */
  .stories-placeholder {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: 0 var(--space-4) var(--space-20);
  }

  @media (min-width: 640px) {
    .stories-placeholder {
      padding: 0 var(--space-6) var(--space-24);
    }
  }

  .placeholder-inner {
    text-align: center;
    padding: var(--space-16) var(--space-8);
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-surface) 50%, transparent);
  }

  .placeholder-icon {
    color: var(--color-brand);
    opacity: 0.5;
    margin-bottom: var(--space-6);
  }

  .placeholder-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: -0.015em;
    margin: 0 0 var(--space-4);
  }

  .placeholder-text {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto var(--space-6);
  }

  .placeholder-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-full);
    background: var(--color-bg-alt);
  }

  .placeholder-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-brand);
    animation: pulse-dot 2s infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* ─── Stories Section ─── */
  .stories-section {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: 0 var(--space-4) var(--space-20);
  }

  @media (min-width: 640px) {
    .stories-section {
      padding: 0 var(--space-6) var(--space-24);
    }
  }

  /* ─── Category Section ─── */
  .category-section {
    border-top: 1px solid var(--color-border);
  }

  .category-inner {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: var(--space-20) var(--space-4);
  }

  @media (min-width: 640px) {
    .category-inner {
      padding: var(--space-24) var(--space-6);
    }
  }

  .category-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  @media (min-width: 640px) {
    .category-header {
      margin-bottom: var(--space-16);
    }
  }

  .category-subtitle {
    color: var(--color-text-tertiary);
    font-size: var(--text-body);
    font-weight: 300;
    max-width: 480px;
    margin: 0 auto;
  }

  .category-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    .category-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }

  @media (min-width: 1024px) {
    .category-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ─── Copyright Footer ─── */
  .copyright-footer {
    padding: var(--space-8) var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  @media (min-width: 640px) {
    .copyright-footer {
      padding: var(--space-12) var(--space-8);
    }
  }

  .copyright-footer p {
    text-align: center;
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    font-weight: 300;
    max-width: 640px;
    margin: 0 auto;
  }

  /* Gallery dark mode notification — :global() needed for blocking script class manipulation */
  :global(.gallery-theme-note) {
    position: fixed;
    top: 20%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.95);
    background: var(--color-surface);
    color: var(--color-text-secondary);
    font-size: 14px;
    padding: 24px 28px;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-raised);
    opacity: 0;
    transition: opacity 0.3s, transform 0.3s;
    z-index: 1000;
    pointer-events: none;
    max-width: min(400px, 90vw);
    text-align: center;
    line-height: 1.6;
  }
  @media (max-width: 480px) {
    :global(.gallery-theme-note) {
      max-width: none;
      width: calc(100vw - 24px);
      padding: 20px 20px;
    }
  }
  :global(.gallery-theme-note.visible) {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
    pointer-events: auto;
  }
  :global(.gallery-theme-note-backdrop) {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    opacity: 0;
    transition: opacity 0.3s;
    z-index: 999;
    pointer-events: none;
  }
  :global(.gallery-theme-note-backdrop.visible) {
    opacity: 1;
    pointer-events: auto;
  }
  :global(.gallery-theme-note-btn) {
    display: inline-block;
    margin-top: 16px;
    padding: 8px 28px;
    background: #4A5A8A;
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
  }
  :global(.gallery-theme-note-btn:hover) {
    opacity: 0.9;
  }
</style>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const reveals = document.querySelectorAll(".gallery-reveal");
    if (reveals.length === 0) return;

    var viewportH = window.innerHeight;

    var observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("revealed");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: "0px 0px -50px 0px" }
    );

    reveals.forEach(function(el, i) {
      var rect = el.getBoundingClientRect();
      if (rect.top < viewportH * 5) {
        // Near viewport — reveal immediately with stagger via transition-delay
        el.style.transitionDelay = Math.min(800, Math.max(0, (rect.top / viewportH) * 150)) + "ms";
        requestAnimationFrame(function() { el.classList.add("revealed"); });
      } else {
        observer.observe(el);
      }
    });

    // Ripple effect on clickable cards
    document.querySelectorAll(".gallery-ripple").forEach(function(el) {
      el.addEventListener("click", function(e) {
        var rect = el.getBoundingClientRect();
        el.style.setProperty("--ripple-x", (e.clientX - rect.left) + "px");
        el.style.setProperty("--ripple-y", (e.clientY - rect.top) + "px");
        el.classList.remove("rippling");
        void el.offsetWidth;
        el.classList.add("rippling");
        setTimeout(function() { el.classList.remove("rippling"); }, 400);
      });
    });
  });
</script>

<script is:inline>
  // 1. Prevent multiple document-level event listeners
  if (!window.hasGalleryThemeListener) {
    window.hasGalleryThemeListener = true;

    document.addEventListener("astro:page-load", function() {
      var isGallery = window.location.pathname.startsWith("/gallery");

      // --- Restore Theme Logic ---
      if (!isGallery) {
        var prevTheme = sessionStorage.getItem("gallery-prev-theme");

        if (prevTheme) {
          document.documentElement.setAttribute("data-theme", prevTheme);
          localStorage.setItem("theme", prevTheme);
          sessionStorage.removeItem("gallery-prev-theme");
        }

        sessionStorage.removeItem("gallery-manual-override");
        return; 
      }

      // --- Gallery Theme Logic ---
      if (sessionStorage.getItem("gallery-manual-override") === "true") return;

      var current = document.documentElement.getAttribute("data-theme") || "light";

      // Wire up "Got it" button for pre-rendered notification (shown by blocking script)
      var backdrop = document.getElementById("gallery-backdrop");
      var note = document.getElementById("gallery-note");
      var btn = document.getElementById("gallery-note-btn");
      if (btn && note && backdrop && note.classList.contains("visible")) {
        btn.focus();
        btn.addEventListener("click", function() {
          note.classList.remove("visible");
          backdrop.classList.remove("visible");
        });
      }

      // Theme switch for SPA navigation (blocking script handles initial load)
      if (current !== "dark") {
        sessionStorage.setItem("gallery-prev-theme", current);
        document.documentElement.setAttribute("data-theme", "dark");
        localStorage.setItem("theme", "dark");

        if (backdrop && note) {
          backdrop.classList.add("visible");
          note.classList.add("visible");
          if (btn) {
            btn.focus();
            btn.addEventListener("click", function() {
              note.classList.remove("visible");
              backdrop.classList.remove("visible");
            });
          }
        }
        sessionStorage.setItem("gallery-theme-note-shown", "true");
      }

      // --- Manual Toggle Listener ---
      var toggle = document.querySelector("[data-theme-toggle]");

      // 2. Prevent multiple click listeners on the same button
      if (toggle && !toggle.hasAttribute("data-gallery-listener-attached")) {
        // Mark the button so we know it already has our listener
        toggle.setAttribute("data-gallery-listener-attached", "true");

        toggle.addEventListener("click", function handler() {
          sessionStorage.setItem("gallery-manual-override", "true");
          sessionStorage.removeItem("gallery-prev-theme");

          // Cleanup this specific listener
          toggle.removeEventListener("click", handler);
          toggle.removeAttribute("data-gallery-listener-attached");
        });
      }
    });
  }
</script>