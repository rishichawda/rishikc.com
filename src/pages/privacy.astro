---
import BaseLayout from "../layouts/base_layout.astro";
import { buildWebPageEntity } from "../utils/jsonLd";

const page_info = {
    title: "Privacy Policy",
    description: "Privacy Policy for rishikc.com",
    keywords: "privacy policy, data protection, gdpr, cookies",
};

const siteUrl = new URL(
    Astro.url.pathname,
    Astro.site || "https://rishikc.com",
).toString();

const pageSchemaEntities = [
    buildWebPageEntity({
        url: siteUrl,
        name: "Privacy Policy",
        description: "Privacy Policy for rishikc.com",
    }),
];
---

<BaseLayout page_info={page_info} pageSchemaEntities={pageSchemaEntities}>
    <main class="privacy-page">
        <article class="privacy-content">
            <h1 class="page-title">Privacy Policy</h1>
            <p class="last-updated">Last updated: {new Date().toLocaleDateString()}</p>

            <h2>1. Introduction</h2>
            <p>
                Welcome to <a href={Astro.url.origin}>rishikc.com</a>. We respect your privacy and are committed to protecting your personal data.
                This privacy policy explains how we collect, use, and safeguard your information when you visit our website.
            </p>

            <h2>2. Information We Collect</h2>

            <h3>Information You Provide Voluntarily</h3>
            <p>
                We collect information that you voluntarily provide to us when you use our "Contact" form. This includes:
            </p>
            <ul>
                <li><strong>Name:</strong> To address you properly in our response.</li>
                <li><strong>Email Address:</strong> To reply to your inquiries.</li>
                <li><strong>Message Content:</strong> The details of your inquiry or feedback.</li>
            </ul>
            <p>
                We do not create user accounts, and we do not ask for passwords or financial information.
            </p>

            <h3>Information Collected Automatically</h3>
            <p>
                When you visit our website, certain information may be collected automatically by our hosting provider or third-party services, including:
            </p>
            <ul>
                <li><strong>Log Data:</strong> Internet Protocol (IP) address, browser type, operating system, and access times.</li>
                <li><strong>Device Information:</strong> Information about the device you use to access the site.</li>
            </ul>

            <h2>3. How We Use Your Information</h2>
            <p>We use the information we collect for the following purposes:</p>
            <ul>
                <li>To respond to your comments, questions, and requests via our contact form.</li>
                <li>To maintain the security and operation of our website.</li>
            </ul>

            <h2>4. Cookies</h2>
            <p>
                This website may use essential cookies to enhance your browsing experience. We do not use cookies for advertising or tracking purposes.
            </p>

            <h2>5. GDPR and CPRA Compliance</h2>
            <p>
                If you are accessing this website from the European Economic Area (EEA), the UK, or California, you have specific rights regarding your personal data.
            </p>
            <ul>
                <li>
                    <strong>GDPR (EEA/UK):</strong> We comply with the General Data Protection Regulation. You have the right to access, rectify, or delete your personal data by contacting us.
                </li>
                <li>
                    <strong>CPRA (California):</strong> California residents have the right to know what personal information is collected and to request its deletion. You can exercise your rights by contacting us.
                </li>
            </ul>

            <h2>6. Third-Party Services</h2>
            <p>We may share your data with the following third-party service providers for specific functions:</p>
            <ul>
                <li><strong>EmailJS:</strong> We use EmailJS to process and deliver messages sent through our contact form. Your name, email, and message are transmitted securely to us via their service.</li>
            </ul>

            <h2>7. Data Retention</h2>
            <p>
                We retain the personal information you provide via email only for as long as necessary to respond to your inquiry and for our business records. We do not store your contact form submissions in a public database.
            </p>

            <h2>8. External Links</h2>
            <p>
                Our website contains links to external sites (e.g., GitHub, LinkedIn, Instagram). We are not responsible for the privacy practices or content of these third-party sites. We encourage you to review their privacy policies.
            </p>

            <h2>9. Contact Us</h2>
            <p>
                If you have any questions about this Privacy Policy, please contact us via our <a href="/contact/">Contact Page</a>.
            </p>
        </article>
    </main>
</BaseLayout>

<style>
    .privacy-page {
        max-width: 720px;
        margin: 0 auto;
        padding: var(--space-16) var(--space-6) var(--space-20);
    }
    .page-title {
        font-family: var(--font-display);
        font-size: var(--text-display);
        font-weight: 700;
        letter-spacing: -0.025em;
        color: var(--color-text);
        margin: 0 0 var(--space-3);
    }
    .last-updated {
        font-family: var(--font-mono);
        font-size: var(--text-caption);
        color: var(--color-text-muted);
        margin-bottom: var(--space-10);
    }
    .privacy-content h2 {
        font-family: var(--font-display);
        font-size: var(--text-h2);
        font-weight: 600;
        line-height: 1.2;
        letter-spacing: -0.015em;
        color: var(--color-text);
        margin: var(--space-10) 0 var(--space-4);
    }
    .privacy-content h3 {
        font-family: var(--font-display);
        font-size: var(--text-h3);
        font-weight: 600;
        line-height: 1.3;
        letter-spacing: -0.01em;
        color: var(--color-text);
        margin: var(--space-6) 0 var(--space-3);
    }
    .privacy-content p {
        font-family: var(--font-body);
        font-size: var(--text-body);
        color: var(--color-text-secondary);
        line-height: 1.7;
        margin: 0 0 var(--space-4);
    }
    .privacy-content ul {
        list-style: disc;
        padding-left: var(--space-6);
        margin: 0 0 var(--space-4);
    }
    .privacy-content li {
        font-family: var(--font-body);
        font-size: var(--text-body);
        color: var(--color-text-secondary);
        line-height: 1.7;
        margin-bottom: var(--space-2);
    }
    .privacy-content a {
        color: var(--color-brand);
        text-decoration: underline;
        text-underline-offset: 3px;
    }
    .privacy-content a:hover {
        color: var(--color-brand-dark);
    }
</style>
