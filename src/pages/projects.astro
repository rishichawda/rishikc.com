---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/base_layout.astro";
import { buildWebPageEntity, personRef } from "../utils/jsonLd";

interface Project {
    name: string;
    description: string;
    longDescription?: string;
    tags: string[];
    github: string;
    demo?: string;
    npm?: string;
    stars: number;
    forks: number;
    language: string;
    category: string;
    featured: boolean;
    year: string;
}

interface OpenSourceContribution {
    name: string;
    repository: string;
    description: string;
    organization?: string;
    contributions?: string[];
    technologies: string[];
    stats: {
        stars: number;
        forks: number;
        pullRequests: number;
        issues: number;
        commits: number;
        totalContributions: number;
    };
    dates: {
        created: string;
        updated: string;
        lastPush: string;
    };
    topics?: string[];
}

interface Social { platform: string; url: string; }
interface Position { title: string; }
interface Experience { company: string; positions: Position[]; }
interface ProfileData { name: string; title: string; summary: string; experience: Experience[]; socials: Social[]; }

const projectsCollection = await getCollection("projects");
const projects: Project[] = projectsCollection[0].data;
const openSourceContributions: OpenSourceContribution[] = projectsCollection[1].data;
const openSourceContributionsStats = projectsCollection[2].data;

const profileEntry = await getCollection("profile");
const profile = profileEntry[0].data as ProfileData;

const featuredProjects = projects.filter((project) => project.featured);
const otherProjects = projects.filter((project) => !project.featured);

const page_info = {
    title: `Projects | ${profile.name}`,
    description: `Explore ${profile.name}'s development projects including React Native components, web applications, developer tools, and open source contributions.`,
    keywords: `${profile.name}, Projects, Open Source, React, TypeScript`,
};

const siteUrl = new URL(
    Astro.url.pathname,
    Astro.site || "https://rishikc.com",
).toString();

const pageSchemaEntities = [
    buildWebPageEntity({
        type: "CollectionPage",
        url: siteUrl,
        name: page_info.title,
        description: page_info.description,
        mainEntity: {
            "@type": "ItemList",
            numberOfItems: projects.length,
            itemListElement: featuredProjects.map((project, index) => ({
                "@type": "ListItem",
                position: index + 1,
                item: {
                    "@type": "SoftwareSourceCode",
                    name: project.name,
                    description: project.description,
                    codeRepository: project.github,
                    programmingLanguage: project.language,
                },
            })),
        },
    }),
];
---

<BaseLayout page_info={page_info} activeRoute="/projects/" pageSchemaEntities={pageSchemaEntities}>

    <main>
        <!-- Page Header -->
        <section class="page-header" data-reveal>
            <span class="overline">BUILDING IN THE OPEN</span>
            <h1 class="page-title">Projects</h1>
            <p class="page-subtitle">Open source contributions, side projects, and experiments.</p>
        </section>

        <!-- Featured Projects -->
        {featuredProjects.length > 0 && (
            <section class="section featured-section">
                <div class="section-header" data-reveal>
                    <span class="section-overline">NOTABLE WORK</span>
                    <h2 class="section-title">Featured Projects</h2>
                </div>
                <div class="featured-grid">
                    {featuredProjects.map((project) => (
                        <div class="featured-card" data-reveal data-spatial-tooltip={`★ ${project.stars} · ${project.language}`}>
                            <div class="featured-accent" />
                            <h3 class="featured-name">{project.name}</h3>
                            <div class="featured-badges">
                                <span class="badge">{project.language}</span>
                                <span class="badge badge-brand">{project.category}</span>
                            </div>
                            <p class="featured-desc">{project.description}</p>
                            {project.longDescription && (
                                <p class="featured-long-desc">{project.longDescription}</p>
                            )}
                            <div class="featured-tags">
                                {project.tags.map((tag) => (
                                    <span class="tag-pill">{tag}</span>
                                ))}
                            </div>
                            <div class="featured-links">
                                <a href={project.github} target="_blank" rel="noopener noreferrer" class="link-btn link-secondary">
                                    Source Code <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:4px;vertical-align:middle;" aria-hidden="true"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
                                </a>
                                {project.demo && (
                                    <a href={project.demo} target="_blank" rel="noopener noreferrer" class="link-btn link-primary">
                                        Live Demo <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:4px;vertical-align:middle;" aria-hidden="true"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
                                    </a>
                                )}
                                {project.npm && (
                                    <a href={project.npm} target="_blank" rel="noopener noreferrer" class="link-btn link-npm">
                                        NPM <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:4px;vertical-align:middle;" aria-hidden="true"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
                                    </a>
                                )}
                            </div>
                        </div>
                    ))}
                </div>
            </section>
        )}

        <!-- Open Source Contributions -->
        <section class="section contributions-section">
            <div class="section-header" data-reveal>
                <span class="section-overline">OPEN SOURCE</span>
                <h2 class="section-title">Contributions</h2>
                <p class="section-desc">My contributions to the open source community.</p>
            </div>

            <div class="stats-row" data-reveal>
                <div class="stat">
                    <span class="stat-value">{openSourceContributionsStats.total_contributions}+</span>
                    <span class="stat-label">Total Contributions</span>
                </div>
                <div class="stat">
                    <span class="stat-value">{openSourceContributionsStats.total_pull_requests}+</span>
                    <span class="stat-label">Pull Requests</span>
                </div>
                <div class="stat">
                    <span class="stat-value">{openSourceContributionsStats.total_repositories}+</span>
                    <span class="stat-label">Repositories</span>
                </div>
                <div class="stat">
                    <span class="stat-value">{Math.floor(openSourceContributionsStats.account_age_years)}+</span>
                    <span class="stat-label">Years Active</span>
                </div>
            </div>
            <p class="stats-disclaimer">These statistics are autogenerated using GitHub APIs. They reflect public contributions only.</p>

            <div class="contrib-grid">
                {openSourceContributions.map((project) => (
                    <div class="contrib-card" data-reveal>
                        {project.organization && (
                            <span class="org-label">{project.organization}</span>
                        )}
                        <h4 class="contrib-name">{project.name}</h4>
                        <p class="contrib-desc">{project.description}</p>
                        <div class="contrib-tech">
                            {project.technologies.map((tech: string) => (
                                <span class="tech-pill">{tech}</span>
                            ))}
                            {project.topics && project.topics.map((topic: string) => (
                                <span class="tech-pill tech-topic">{topic}</span>
                            ))}
                        </div>
                        <a href={project.repository} target="_blank" rel="noopener noreferrer" class="contrib-link">
                            View Repository <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:4px;vertical-align:middle;" aria-hidden="true"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
                        </a>
                    </div>
                ))}
            </div>
        </section>

        <!-- Other Projects -->
        {otherProjects.length > 0 && (
            <section class="section other-section">
                <div class="section-header" data-reveal>
                    <span class="section-overline">MORE WORK</span>
                    <h2 class="section-title">More Projects</h2>
                </div>
                <div class="other-grid">
                    {otherProjects.map((project) => (
                        <div class="other-card" data-reveal>
                            <div class="other-header">
                                <h3 class="other-name">{project.name}</h3>
                                <span class="badge">{project.language}</span>
                            </div>
                            <span class="badge badge-brand" style="margin-bottom: var(--space-3); display: inline-block;">{project.category}</span>
                            <p class="other-desc">{project.description}</p>
                            <div class="other-links">
                                <a href={project.github} target="_blank" rel="noopener noreferrer" class="link-btn link-secondary link-sm">
                                    Source Code <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:4px;vertical-align:middle;" aria-hidden="true"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
                                </a>
                                {project.demo && (
                                    <a href={project.demo} target="_blank" rel="noopener noreferrer" class="link-btn link-primary link-sm">
                                        Live Demo <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:4px;vertical-align:middle;" aria-hidden="true"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
                                    </a>
                                )}
                                {project.npm && (
                                    <a href={project.npm} target="_blank" rel="noopener noreferrer" class="link-btn link-npm link-sm">
                                        NPM <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-left:4px;vertical-align:middle;" aria-hidden="true"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
                                    </a>
                                )}
                            </div>
                        </div>
                    ))}
                </div>
            </section>
        )}

        <!-- CTA -->
        <section class="cta-section" data-reveal>
            <h2 class="cta-title">Have a project in mind?</h2>
            <p class="cta-desc">I'm always interested in collaborating on meaningful work.</p>
            <div class="cta-links">
                <a href="/contact/" class="btn-primary">Get in Touch</a>
                <a href="/career/" class="btn-ghost">View My Career</a>
            </div>
        </section>
    </main>
</BaseLayout>

<style>
    /* Page Header */
    .page-header {
        max-width: 720px;
        margin: 0 auto;
        padding: var(--space-20) var(--space-6) var(--space-12);
        text-align: center;
    }
    .overline {
        display: block;
        font-family: var(--font-mono);
        font-size: var(--text-overline);
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-text-tertiary);
        margin-bottom: var(--space-4);
    }
    .page-title {
        font-family: var(--font-display);
        font-size: var(--text-display-lg);
        font-weight: 700;
        color: var(--color-text);
        margin: 0 0 var(--space-4);
        line-height: 1.1;
        letter-spacing: -0.025em;
    }
    .page-subtitle {
        font-family: var(--font-body);
        font-size: var(--text-body-lg);
        color: var(--color-text-secondary);
        max-width: 560px;
        margin: 0 auto;
        line-height: 1.6;
    }

    /* Sections */
    .section {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 var(--space-6) var(--space-16);
    }
    .section-header { text-align: center; margin-bottom: var(--space-10); }
    .section-overline {
        display: block;
        font-family: var(--font-mono);
        font-size: var(--text-overline);
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--color-text-tertiary);
        margin-bottom: var(--space-3);
    }
    .section-title {
        font-family: var(--font-display);
        font-size: var(--text-h2);
        font-weight: 600;
        line-height: 1.2;
        letter-spacing: -0.015em;
        color: var(--color-text);
        margin: 0 0 var(--space-3);
    }
    .section-desc {
        font-family: var(--font-body);
        font-size: var(--text-body);
        color: var(--color-text-secondary);
        margin: 0;
    }

    /* Featured Grid */
    .featured-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--space-8);
    }
    .featured-card {
        position: relative;
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 20px;
        padding: 32px;
        box-shadow: var(--shadow-raised);
        transition: transform 300ms, box-shadow 300ms;
        display: flex;
        flex-direction: column;
    }
    .featured-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-elevated);
    }
    .featured-accent {
        height: 4px;
        background: var(--color-brand);
        border-radius: 2px;
        margin-bottom: var(--space-5);
    }
    .featured-name {
        font-family: var(--font-display);
        font-size: var(--text-h2);
        font-weight: 600;
        line-height: 1.2;
        letter-spacing: -0.015em;
        color: var(--color-text);
        margin: 0 0 var(--space-3);
        transition: color 200ms;
    }
    .featured-card:hover .featured-name { color: var(--color-brand); }
    .featured-badges {
        display: flex;
        gap: var(--space-2);
        margin-bottom: var(--space-4);
        flex-wrap: wrap;
    }
    .badge {
        font-family: var(--font-mono);
        font-size: 12px;
        padding: 4px 10px;
        border-radius: 8px;
        background: var(--color-bg-alt);
        color: var(--color-text-secondary);
        border: 1px solid var(--color-border);
    }
    .badge-brand {
        background: var(--color-brand-lighter);
        color: var(--color-brand-dark);
        border-color: transparent;
    }
    .featured-desc {
        font-family: var(--font-body);
        font-size: var(--text-body-lg);
        color: var(--color-text-secondary);
        line-height: 1.6;
        margin: 0 0 var(--space-3);
    }
    .featured-long-desc {
        font-family: var(--font-body);
        font-size: var(--text-body);
        color: var(--color-text-tertiary);
        line-height: 1.6;
        margin: 0 0 var(--space-5);
    }
    .featured-tags {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
        margin-bottom: var(--space-6);
    }
    .tag-pill {
        font-family: var(--font-mono);
        font-size: 11px;
        padding: 3px 8px;
        border-radius: 6px;
        background: var(--color-bg-alt);
        color: var(--color-text-muted);
        border: 1px solid var(--color-border);
    }
    .featured-links {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3);
        margin-top: auto;
    }
    .link-btn {
        font-family: var(--font-ui);
        font-size: 14px;
        font-weight: 500;
        padding: 10px 20px;
        border-radius: 12px;
        text-decoration: none;
        transition: background 200ms, transform 200ms;
        display: inline-flex;
        align-items: center;
        white-space: nowrap;
    }
    .link-btn:hover { transform: translateY(-1px); }
    .link-secondary {
        background: var(--color-bg-alt);
        color: var(--color-text);
        border: 1px solid var(--color-border);
    }
    .link-secondary:hover { background: var(--color-surface); }
    .link-primary {
        background: var(--btn-bg);
        color: white;
    }
    .link-primary:hover { filter: brightness(0.9); }
    .link-npm {
        background: #CB3837;
        color: white;
    }
    .link-npm:hover { filter: brightness(0.9); }
    .link-sm { font-size: 13px; padding: 8px 16px; }

    /* Stats Row */
    .stats-row {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: var(--space-6);
        margin-bottom: var(--space-4);
    }
    .stat {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-1);
        padding: var(--space-4) var(--space-6);
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 16px;
    }
    .stat-value {
        font-family: var(--font-display);
        font-size: var(--text-h2);
        font-weight: 700;
        color: var(--color-brand);
    }
    .stat-label {
        font-family: var(--font-ui);
        font-size: var(--text-caption);
        color: var(--color-text-secondary);
    }
    .stats-disclaimer {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--color-text-muted);
        text-align: center;
        font-style: italic;
        margin: 0 0 var(--space-10);
    }

    /* Contributions Grid */
    .contrib-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-5);
    }
    .contrib-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        padding: 24px;
        box-shadow: var(--shadow-subtle);
        transition: transform 300ms, box-shadow 300ms;
        display: flex;
        flex-direction: column;
    }
    .contrib-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-elevated);
    }
    .org-label {
        font-family: var(--font-mono);
        font-size: 11px;
        padding: 2px 8px;
        border-radius: 6px;
        background: var(--color-brand-lighter);
        color: var(--color-brand-dark);
        display: inline-block;
        margin-bottom: var(--space-2);
        width: fit-content;
    }
    .contrib-name {
        font-family: var(--font-display);
        font-size: var(--text-body-lg);
        font-weight: 600;
        color: var(--color-text);
        margin: 0 0 var(--space-2);
        transition: color 200ms;
    }
    .contrib-card:hover .contrib-name { color: var(--color-brand); }
    .contrib-desc {
        font-family: var(--font-body);
        font-size: var(--text-body-sm);
        color: var(--color-text-secondary);
        margin: 0 0 var(--space-4);
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .contrib-tech {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        margin-bottom: var(--space-4);
    }
    .tech-pill {
        font-family: var(--font-mono);
        font-size: 11px;
        padding: 2px 8px;
        border-radius: 6px;
        background: var(--color-bg-alt);
        color: var(--color-text-muted);
        border: 1px solid var(--color-border);
    }
    .tech-topic {
        background: var(--color-brand-lighter);
        color: var(--color-brand-dark);
        border-color: transparent;
    }
    .contrib-link {
        font-family: var(--font-ui);
        font-size: 14px;
        font-weight: 500;
        color: var(--color-brand);
        text-decoration: none;
        margin-top: auto;
        transition: color 200ms;
        display: inline-flex;
        align-items: center;
        white-space: nowrap;
    }
    .contrib-link:hover { text-decoration: underline; }

    /* Other Projects Grid */
    .other-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-5);
    }
    .other-card {
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: 16px;
        padding: 24px;
        box-shadow: var(--shadow-subtle);
        transition: transform 300ms, box-shadow 300ms;
        display: flex;
        flex-direction: column;
    }
    .other-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-elevated);
    }
    .other-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: var(--space-3);
        margin-bottom: var(--space-2);
    }
    .other-name {
        font-family: var(--font-display);
        font-size: var(--text-body-lg);
        font-weight: 600;
        color: var(--color-text);
        margin: 0;
    }
    .other-desc {
        font-family: var(--font-body);
        font-size: var(--text-body-sm);
        color: var(--color-text-secondary);
        line-height: 1.5;
        margin: 0 0 var(--space-5);
    }
    .other-links {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
        margin-top: auto;
    }

    /* CTA */
    .cta-section {
        max-width: 720px;
        margin: 0 auto;
        padding: var(--space-16) var(--space-6) var(--space-20);
        text-align: center;
    }
    .cta-title {
        font-family: var(--font-display);
        font-size: var(--text-h2);
        font-weight: 600;
        line-height: 1.2;
        letter-spacing: -0.015em;
        color: var(--color-text);
        margin: 0 0 var(--space-3);
    }
    .cta-desc {
        font-family: var(--font-body);
        font-size: var(--text-body-lg);
        color: var(--color-text-secondary);
        margin: 0 0 var(--space-8);
    }
    .cta-links {
        display: flex;
        gap: var(--space-4);
        justify-content: center;
    }
    .btn-primary {
        font-family: var(--font-ui);
        font-size: 14px;
        font-weight: 500;
        padding: 12px 28px;
        background: var(--btn-bg);
        color: white;
        border-radius: 12px;
        text-decoration: none;
        transition: background 200ms, transform 200ms;
    }
    .btn-primary:hover { filter: brightness(0.9); transform: translateY(-1px); }
    .btn-ghost {
        font-family: var(--font-ui);
        font-size: 14px;
        font-weight: 500;
        padding: 12px 28px;
        background: transparent;
        color: var(--color-text-secondary);
        border: 1px solid var(--color-border);
        border-radius: 12px;
        text-decoration: none;
        transition: border-color 200ms, color 200ms;
    }
    .btn-ghost:hover {
        border-color: var(--color-brand);
        color: var(--color-brand);
    }

    @media (max-width: 1023px) {
        .featured-grid { grid-template-columns: 1fr; }
        .contrib-grid { grid-template-columns: repeat(2, 1fr); }
        .other-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 639px) {
        .contrib-grid { grid-template-columns: 1fr; }
        .other-grid { grid-template-columns: 1fr; }
        .cta-links { flex-direction: column; align-items: center; }
    }
</style>
