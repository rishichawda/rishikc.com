---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/base_layout.astro";
import { buildWebPageEntity, personRef } from "../utils/jsonLd";
import { Image } from "astro:assets";
import profileImage from "../../content/assets/me.jpg";

interface Language { name: string; level: string; }
interface Social { platform: string; url: string; }
interface Position { title: string; period: string; duration: string; location?: string; description?: string; responsibilities?: string[]; }
interface ClubPosition { title: string; period: string; duration: string; location?: string; description?: string; responsibilities?: string[]; }
interface ExtraCurricular { club: string; positions: ClubPosition[]; }
interface Experience { company: string; duration: string; positions: Position[]; website?: string[]; }
interface Education { institution: string; degree: string; period: string; extra_curriculars?: ExtraCurricular[]; }
interface Certification { institution: string; title: string; }
interface ProfileData { name: string; title: string; intro: string; location: string; summary: string; bio: string | string[]; contact: { linkedin: string; }; skills: string[]; languages: Language[]; certifications: Certification[]; experience: Experience[]; education: Education[]; interests: string[]; socials: Social[]; }

const profileEntry = await getCollection("profile");
const profile = profileEntry[0].data as ProfileData;

const servicesEntry = await getCollection("services");
const services = (servicesEntry[0]?.data as any)?.services || [];

const projectsEntry = await getCollection("projects");
// Collection entries are split by top-level JSON keys; find the stats entry
const statsEntry = projectsEntry.find((e: any) => e.id === "open_source_contributions_stats");
const osStats = (statsEntry?.data as any) || {};
const totalContributions = osStats.total_contributions || 0;

const dataEntry = projectsEntry.find((e: any) => e.id === "data");
const ossEntry = projectsEntry.find((e: any) => e.id === "open_source_contributions");
const totalProjects = ((dataEntry?.data as any) || []).length + ((ossEntry?.data as any) || []).length;

// Organize skills into categories for the Skills section
const skillCategories = [
  { name: "Frontend", accent: "var(--color-brand)", skills: ["React", "TypeScript", "Astro", "Next.js", "Tailwind CSS", "Accessibility"] },
  { name: "Backend", accent: "var(--color-accent)", skills: ["Node.js", "Ruby on Rails", "Python", "PostgreSQL", "Go"] },
  { name: "Mobile", accent: "var(--color-brand-light)", skills: ["React Native", "iOS", "Android"] },
  { name: "DevOps & Infra", accent: "var(--color-brand-dark)", skills: ["Chef", "Docker", "Kubernetes", "CI/CD", "AWS", "GCP"] },
  { name: "Creative", accent: "var(--color-text-tertiary)", skills: ["Photography", "Technical Writing", "UI/UX"] },
];

const page_info = {
  title: `About | ${profile.name}`,
  description: profile.summary || `Learn more about ${profile.name}.`,
  keywords: `Rishi Chawda, About Me, Software Engineer, ${profile.skills.join(', ')}`,
};

const siteUrl = new URL(Astro.url.pathname, Astro.site || "https://rishikc.com").toString();
const profileImageUrl = `${siteUrl.replace(/\/$/, "")}/${profileImage.src}`;

const firstJobStartDate = new Date("2018-07-01");
const yearsExperience = new Date().getFullYear() - firstJobStartDate.getFullYear();

const socialIconPaths: Record<string, string> = {
  GitHub: "M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z",
  LinkedIn: "M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z",
  Instagram: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z",
  Twitter: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z",
  Dribbble: "M12 24C5.385 24 0 18.615 0 12S5.385 0 12 0s12 5.385 12 12-5.385 12-12 12zm10.12-10.358c-.35-.11-3.17-.953-6.384-.438 1.34 3.684 1.887 6.684 1.992 7.308 2.3-1.555 3.936-4.02 4.395-6.87zm-6.115 7.808c-.153-.9-.75-4.032-2.19-7.77l-.066.02c-5.79 2.015-7.86 6.025-8.04 6.4 1.73 1.358 3.92 2.166 6.29 2.166 1.42 0 2.77-.29 4-.81zm-11.62-2.58c.232-.4 3.045-5.055 8.332-6.765.135-.045.27-.084.405-.12-.26-.585-.54-1.167-.832-1.74C7.17 11.775 2.206 11.71 1.756 11.7l-.004.312c0 2.633.998 5.037 2.634 6.855zm-2.42-8.955c.46.008 4.683.026 9.477-1.248-1.698-3.018-3.53-5.558-3.8-5.928-2.868 1.35-5.01 3.99-5.676 7.17zM9.6 2.052c.282.38 2.145 2.914 3.822 6 3.645-1.365 5.19-3.44 5.373-3.702-1.81-1.61-4.19-2.586-6.795-2.586-.825 0-1.63.1-2.4.285zm10.335 3.483c-.218.29-1.91 2.493-5.724 4.04.24.49.47.985.68 1.486.08.18.15.36.22.53 3.41-.43 6.8.26 7.14.33-.02-2.42-.88-4.64-2.31-6.38z",
};

const pageSchemaEntities = [
  buildWebPageEntity({
    type: "ProfilePage",
    url: siteUrl,
    name: page_info.title,
    description: page_info.description,
    mainEntity: personRef,
  }),
];
---

<BaseLayout page_info={page_info} activeRoute="/about/" pageSchemaEntities={pageSchemaEntities}>

  <main>
    {/* ─── Page Header ─── */}
    <section class="page-header" data-reveal>
      <span class="overline">GET TO KNOW ME</span>
      <h1 class="page-title">About</h1>
      <p class="page-subtitle">The person behind the code, the camera, and the curiosity.</p>
    </section>

    {/* ─── Profile Section ─── */}
    <section class="profile-section" data-reveal>
      <div class="profile-grid">
        <div class="profile-photo-col" data-reveal-item>
          <Image
            src={profileImage}
            alt={`Profile picture of ${profile.name}`}
            width={280}
            height={280}
            class="profile-photo"
            loading="eager"
            decoding="async"
          />
        </div>
        <div class="profile-text-col">
          <h2 class="profile-name" data-reveal-item>{profile.name}</h2>
          <p class="profile-title" data-reveal-item>{profile.title}</p>
          <p class="profile-location" data-reveal-item>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {profile.location}
          </p>
          <div class="profile-socials" data-reveal-item>
            {profile.socials.map((social: Social) => (
              <a href={social.url} target="_blank" rel="noopener noreferrer" class="social-icon" aria-label={`Visit ${social.platform} profile`}>
                <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
                  <path d={socialIconPaths[social.platform] || ""} fill="currentColor"></path>
                </svg>
                <span class="sr-only">{social.platform}</span>
              </a>
            ))}
          </div>
          <div class="profile-bio" data-reveal-item>
            {Array.isArray(profile.bio) ? profile.bio[0] : profile.bio}
          </div>
        </div>
      </div>
    </section>

    {/* ─── Narrative Section ─── */}
    <section class="narrative-section" data-reveal>
      <div class="narrative-content">
        {Array.isArray(profile.bio) && profile.bio.slice(1).map((paragraph: string, index: number) => (
          <p class:list={["narrative-para", { "drop-cap": index === 0 }]} data-reveal-item>
            {paragraph}
          </p>
        ))}
        <p class="narrative-para" data-reveal-item>
          With over <strong>{yearsExperience} years</strong> of experience in the tech industry, <em>and a couple more as a freelancer</em>, I've had the privilege of working on diverse projects from developing scalable web applications to contributing to DevSecOps tooling at <a href={profile.experience[0]?.website?.[0] || '#'} target="_blank" rel="noopener noreferrer" class="brand-link">{profile.experience[0]?.company || 'my current role'}</a>.
        </p>
      </div>
    </section>

    {/* ─── My Journey ─── */}
    <section class="journey-section" data-reveal>
      <div class="journey-container">
        <span class="overline">MY JOURNEY</span>
        <h2 class="section-heading">Building &amp; Growing</h2>
        <div class="journey-cards" data-reveal-group>
          <div class="journey-card" data-reveal-item>
            <span class="journey-number">{yearsExperience}+</span>
            <span class="journey-label">Years in Tech</span>
            <p class="journey-desc">From freelance roots to principal engineering, building products that scale and teams that thrive.</p>
          </div>
          <div class="journey-card" data-reveal-item>
            <span class="journey-number">{totalProjects}+</span>
            <span class="journey-label">Projects</span>
            <p class="journey-desc">From personal experiments to open source contributions, building solutions across the stack.</p>
          </div>
          <div class="journey-card" data-reveal-item>
            <span class="journey-number">{totalContributions > 1000 ? `${Math.round(totalContributions / 100) / 10}k` : totalContributions}+</span>
            <span class="journey-label">OSS Contributions</span>
            <p class="journey-desc">PRs, issues, and commits across {osStats.total_repositories || 100}+ repositories in the open source ecosystem.</p>
          </div>
        </div>
        <a href="/career/" class="journey-cta" data-magnetic data-reveal-item>
          View Full Career History
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    {/* ─── Beyond Code ─── */}
    <section class="beyond-section" data-reveal>
      <div class="beyond-container" data-reveal-group>
        <div class="beyond-card" data-reveal-item>
          <div class="beyond-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </div>
          <h3 class="beyond-title">Photography</h3>
          <p class="beyond-desc">Capturing life's fleeting moments through the lens, from street scenes to landscapes.</p>
          <a href="/gallery/" class="beyond-link">Explore Gallery <span aria-hidden="true">&rarr;</span></a>
        </div>
        <div class="beyond-card" data-reveal-item>
          <div class="beyond-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h3 class="beyond-title">Writing</h3>
          <p class="beyond-desc">About web performance, architecture, photography, philosophy, and whatever else catches my attention.</p>
          <a href="/articles/" class="beyond-link">Read Articles <span aria-hidden="true">&rarr;</span></a>
        </div>
        <div class="beyond-card" data-reveal-item>
          <div class="beyond-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
          </div>
          <h3 class="beyond-title">Adventures</h3>
          <p class="beyond-desc">Exploring new places and cultures, always ready for the next trail or the next city.</p>
        </div>
      </div>
    </section>

    {/* ─── Connect CTA ─── */}
    <section class="connect-section" data-reveal>
      <div class="connect-inner">
        <h2 class="connect-heading" data-reveal-item>Want to collaborate or just say hello?</h2>
        <p class="connect-text" data-reveal-item>Have a project in mind, a question, or just want to chat about tech or photography? I'd love to hear from you.</p>
        <a href="/contact/" class="btn-primary" data-magnetic data-reveal-item>
          Get in Touch
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ─── Page Header ─── */
  .page-header {
    padding: var(--space-16) var(--space-6) var(--space-12);
    max-width: 720px;
    margin: 0 auto;
  }

  .overline {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-overline);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-3);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: var(--text-display-lg);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .page-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* ─── Profile ─── */
  .profile-section {
    padding: 0 var(--space-6) var(--space-16);
    max-width: var(--max-content);
    margin: 0 auto;
  }

  .profile-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  @media (min-width: 768px) {
    .profile-grid {
      grid-template-columns: 280px 1fr;
    }
  }

  .profile-photo-col {
    display: flex;
    justify-content: center;
  }

  .profile-photo {
    width: 200px;
    height: 200px;
    object-fit: cover;
    border-radius: 24px;
    border: 1px solid var(--color-brand-lighter);
    box-shadow: var(--shadow-floating);
  }

  @media (min-width: 768px) {
    .profile-photo {
      width: 280px;
      height: 280px;
    }
  }

  .profile-name {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--color-text);
    margin-bottom: var(--space-2);
  }

  .profile-title {
    font-family: var(--font-body);
    font-size: var(--text-h3);
    color: var(--color-brand);
    margin-bottom: var(--space-2);
  }

  .profile-location {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-4);
  }

  .profile-socials {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .social-icon {
    color: var(--color-text-secondary);
    transition: color var(--duration-fast) ease;
  }

  .social-icon:hover {
    color: var(--color-brand);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .profile-bio {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text);
    line-height: 1.7;
  }

  /* ─── Narrative ─── */
  .narrative-section {
    padding: var(--space-20) var(--space-6);
  }

  .narrative-content {
    max-width: 680px;
    margin: 0 auto;
  }

  .narrative-para {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text);
    line-height: 1.8;
    margin-bottom: var(--space-6);
  }

  .narrative-para.drop-cap::first-letter {
    font-family: var(--font-display);
    font-size: 3.5em;
    float: left;
    line-height: 0.8;
    padding-right: 8px;
    margin-top: 4px;
    color: var(--color-brand);
    font-weight: 400;
  }

  .narrative-para strong {
    font-weight: 600;
    color: var(--color-text);
  }

  .narrative-para em {
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .brand-link {
    color: var(--color-brand-dark);
    text-decoration: underline;
    text-decoration-color: var(--color-brand-lighter);
    text-underline-offset: 3px;
    transition: text-decoration-color var(--duration-fast) ease;
  }

  .brand-link:hover {
    text-decoration-color: var(--color-brand);
  }

  /* ─── Skills ─── */
  /* ─── My Journey ─── */
  .journey-section {
    padding: var(--space-16) var(--space-6);
  }

  .journey-container {
    max-width: 1080px;
    margin: 0 auto;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin-bottom: var(--space-10);
  }

  .journey-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .journey-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-6);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .journey-number {
    font-family: var(--font-display);
    font-size: var(--text-h1);
    font-weight: 700;
    color: var(--color-brand);
    line-height: 1;
    margin-bottom: var(--space-1);
  }

  .journey-label {
    font-family: var(--font-ui);
    font-size: var(--text-ui-small);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-3);
  }

  .journey-desc {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin: 0;
  }

  .journey-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--text-body);
    font-weight: 500;
    color: var(--color-brand);
    text-decoration: none;
    transition: gap var(--duration-fast) ease;
  }

  .journey-cta:hover {
    gap: var(--space-3);
  }

  @media (max-width: 640px) {
    .journey-cards {
      grid-template-columns: 1fr;
    }
  }

  /* ─── Beyond Code ─── */
  .beyond-section {
    padding: var(--space-20) var(--space-6);
    background: var(--color-bg-alt);
  }

  .beyond-container {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .beyond-container {
      grid-template-columns: repeat(3, 1fr);
