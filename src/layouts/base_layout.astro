---
import { Font } from "astro:assets";
import SEO from "../components/seo.astro";
import Navigation from "../components/navigation.astro";
import SkipLink from "../components/common/skip_link.astro";
import CustomCursor from "../components/common/custom_cursor.astro";
import KeyboardShortcutsModal from "../components/common/keyboard_shortcuts_modal.astro";
import "../styles/global.css";
import "../styles/tailwind.css";
import "../styles/animations.css";
import Footer from "../components/footer.astro";
import { ClientRouter } from "astro:transitions";

let {
	page_info: { title, description, image, keywords, type, datePublished, dateModified, tags, noindex },
	activeRoute,
	pageSchemaEntities,
} = Astro.props;

const seo = {
	title: title || "title",
	description: description || "description",
	image: `siteUrl${image || "image"}`,
	type: type || "WebSite",
	keywords: keywords || "keywords",
	datePublished,
	dateModified,
	tags,
	noindex,
};
---

<!doctype html>
<html lang="en">
	<head>
		<SEO page_info={seo} pageSchemaEntities={pageSchemaEntities} />
		<Font cssVariable="--font-inter" />
		<Font cssVariable="--font-red-hat-display" />
		<Font cssVariable="--font-montserrat" />
		<Font cssVariable="--font-jetbrains-mono" />
		<ClientRouter />
		<script is:inline>
			// FOUC prevention: set data-theme synchronously before first paint
			(function() {
				var isGallery = window.location.pathname.startsWith('/gallery');
				// Restore previous theme when leaving gallery (handles hard navigations)
				if (!isGallery) {
					var galleryPrev = sessionStorage.getItem('gallery-prev-theme');
					if (galleryPrev) {
						localStorage.setItem('theme', galleryPrev);
						sessionStorage.removeItem('gallery-prev-theme');
						sessionStorage.removeItem('gallery-manual-override');
					}
				}
				var saved = localStorage.getItem('theme');
				var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
				document.documentElement.setAttribute('data-theme', theme);
			})();

			// Preserve theme across View Transitions (ClientRouter SPA navigation)
			document.addEventListener('astro:before-swap', function(e) {
				var newPath = e.newDocument?.querySelector('link[rel="canonical"]')?.getAttribute('href') || '';
				var isLeavingGallery = window.location.pathname.startsWith('/gallery') && !newPath.includes('/gallery');
				if (isLeavingGallery) {
					var galleryPrev = sessionStorage.getItem('gallery-prev-theme');
					if (galleryPrev) {
						e.newDocument.documentElement.setAttribute('data-theme', galleryPrev);
						localStorage.setItem('theme', galleryPrev);
						sessionStorage.removeItem('gallery-prev-theme');
						sessionStorage.removeItem('gallery-manual-override');
						return;
					}
				}
				var theme = document.documentElement.getAttribute('data-theme');
				if (theme) {
					e.newDocument.documentElement.setAttribute('data-theme', theme);
				}
			});
		</script>
		<slot name="head" />
	</head>
	<body class="max-w-screen bg-[var(--color-bg)] text-[var(--color-text)] transition-colors duration-300">
		<SkipLink />
		<Navigation activeRoute={activeRoute} />
		<div id="main-content" class="pt-[var(--nav-height)]">
			<slot />
		</div>
		<Footer />
		<CustomCursor />
		<KeyboardShortcutsModal />
	</body>
</html>

<script>
	import { initKeyboardShortcuts } from '../utils/keyboardShortcuts';
	import { initMagneticElements } from '../utils/magneticHover';
	import { initScrollReveals } from '../utils/scrollReveal';
	import { initEasterEggs } from '../utils/easterEggs';
	import { initSpatialTooltips } from '../utils/spatialTooltips';

	function initGlobalFeatures() {
		initKeyboardShortcuts();
		initMagneticElements();
		initScrollReveals();
		initEasterEggs();
		initSpatialTooltips();
	}

	document.addEventListener('astro:page-load', initGlobalFeatures);
</script>
