---
/* Custom cursor — 8px dot morphs to 40px ring with contextual text on hover */
---

<div id="gallery-cursor" class="gallery-cursor" aria-hidden="true">
  <span id="gallery-cursor-text" class="gallery-cursor-text"></span>
</div>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const cursor = document.getElementById("gallery-cursor");
    const cursorText = document.getElementById("gallery-cursor-text");
    if (!cursor || !cursorText) return;

    // Only on non-touch, non-mobile devices
    if (window.matchMedia("(pointer: coarse)").matches) {
      cursor.style.display = "none";
      return;
    }

    let mouseX = 0;
    let mouseY = 0;
    let cursorX = 0;
    let cursorY = 0;
    let isVisible = false;

    function lerp(a, b, t) {
      return a + (b - a) * t;
    }

    function animate() {
      cursorX = lerp(cursorX, mouseX, 0.15);
      cursorY = lerp(cursorY, mouseY, 0.15);
      cursor.style.left = cursorX + "px";
      cursor.style.top = cursorY + "px";
      requestAnimationFrame(animate);
    }
    animate();

    document.addEventListener("mousemove", (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      if (!isVisible) {
        isVisible = true;
        cursor.classList.add("visible");
      }
    });

    document.addEventListener("mouseleave", () => {
      isVisible = false;
      cursor.classList.remove("visible");
    });

    // Expand on hoverable elements
    function addHoverListeners(selector, label) {
      document.querySelectorAll(selector).forEach((el) => {
        el.addEventListener("mouseenter", () => {
          cursor.classList.add("expanded");
          cursorText.textContent = label;
        });
        el.addEventListener("mouseleave", () => {
          cursor.classList.remove("expanded");
          cursorText.textContent = "";
        });
      });
    }

    addHoverListeners(".story-card", "View Story");
    addHoverListeners(".lightbox-trigger", "Zoom");
  });
</script>
