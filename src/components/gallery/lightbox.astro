---
/* Rich lightbox — caption, counter, prev/next navigation, keyboard support */
---

<div id="gallery-lightbox" class="gallery-lightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
  <!-- Top bar: counter + close -->
  <div class="absolute top-0 left-0 right-0 z-[202] flex items-center justify-between px-5 py-4">
    <span id="lightbox-counter" class="meta-label text-gallery-text/60 text-xs select-none"></span>
    <button
      type="button"
      class="gallery-lightbox-close"
      aria-label="Close image viewer"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Prev / Next arrows -->
  <button
    type="button"
    id="lightbox-prev"
    class="gallery-lightbox-nav gallery-lightbox-nav--prev"
    aria-label="Previous image"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>
  <button
    type="button"
    id="lightbox-next"
    class="gallery-lightbox-nav gallery-lightbox-nav--next"
    aria-label="Next image"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 6 15 12 9 18"></polyline>
    </svg>
  </button>

  <!-- Image -->
  <img id="lightbox-image" src="" alt="" />

  <!-- Bottom bar: caption + metadata -->
  <div id="lightbox-caption-bar" class="absolute bottom-0 left-0 right-0 z-[202] px-6 py-5 bg-gradient-to-t from-black/80 via-black/50 to-transparent pointer-events-none">
    <div class="max-w-3xl mx-auto">
      <p id="lightbox-caption" class="text-gallery-text/80 text-sm sm:text-base font-light italic text-center mb-2"></p>
      <div id="lightbox-meta" class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1 text-gallery-text/50 text-[0.65rem] tracking-wider uppercase font-mono"></div>
    </div>
  </div>
</div>

<script is:inline>
  document.addEventListener("astro:page-load", () => {
    const lightbox = document.getElementById("gallery-lightbox");
    const lightboxImg = document.getElementById("lightbox-image");
    const captionEl = document.getElementById("lightbox-caption");
    const captionBar = document.getElementById("lightbox-caption-bar");
    const counterEl = document.getElementById("lightbox-counter");
    const closeBtn = lightbox?.querySelector(".gallery-lightbox-close");
    const prevBtn = document.getElementById("lightbox-prev");
    const nextBtn = document.getElementById("lightbox-next");

    if (!lightbox || !lightboxImg) return;

    let triggers = [];
    let currentIndex = 0;

    function collectTriggers() {
      triggers = Array.from(document.querySelectorAll(".lightbox-trigger"));
    }

    function updateCounter() {
      if (counterEl && triggers.length > 1) {
        counterEl.textContent = (currentIndex + 1) + " / " + triggers.length;
      } else if (counterEl) {
        counterEl.textContent = "";
      }
    }

    function showImage(index) {
      if (index < 0 || index >= triggers.length) return;
      currentIndex = index;
      const trigger = triggers[index];
      const img = trigger.querySelector("img");
      if (!img) return;

      // Reset any swipe transform
      lightboxImg.style.transform = "";
      lightboxImg.style.opacity = "";
      lightboxImg.style.transition = "";

      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt || caption || `Gallery image ${currentIndex + 1} of ${triggers.length}`;

      var caption = trigger.getAttribute("data-caption") || "";
      var camera = trigger.getAttribute("data-camera") || "";
      var lens = trigger.getAttribute("data-lens") || "";
      var settings = trigger.getAttribute("data-settings") || "";
      var location = trigger.getAttribute("data-location") || "";

      var metaEl = document.getElementById("lightbox-meta");

      if (captionEl) captionEl.textContent = caption;

      // Build metadata pills
      if (metaEl) {
        metaEl.innerHTML = "";
        var items = [camera, lens, settings, location].filter(Boolean);
        items.forEach(function(label, i) {
          if (i > 0) {
            var sep = document.createElement("span");
            sep.textContent = "·";
            sep.style.opacity = "0.4";
            metaEl.appendChild(sep);
          }
          var span = document.createElement("span");
          span.textContent = label;
          metaEl.appendChild(span);
        });
      }

      var hasContent = caption || camera || lens || settings || location;
      if (captionBar) captionBar.style.display = hasContent ? "" : "none";

      updateCounter();

      // Show/hide nav arrows
      if (prevBtn) prevBtn.style.display = triggers.length > 1 ? "" : "none";
      if (nextBtn) nextBtn.style.display = triggers.length > 1 ? "" : "none";
    }

    function setBackgroundInert(inert) {
      var selectors = ["header", "main", "#main-content", "footer"];
      selectors.forEach(function(sel) {
        var el = document.querySelector(sel);
        if (el && el !== lightbox && !lightbox.contains(el)) {
          if (inert) {
            el.setAttribute("inert", "");
          } else {
            el.removeAttribute("inert");
          }
        }
      });
    }

    function openLightbox(index) {
      collectTriggers();
      showImage(index);
      lightbox.classList.add("active");
      document.body.style.overflow = "hidden";
      setBackgroundInert(true);
      hasInteracted = false;
      showSwipeHint();
      // Move focus to the close button after the lightbox is visible
      requestAnimationFrame(function() {
        if (closeBtn) closeBtn.focus();
      });
    }

    function closeLightbox() {
      lightbox.classList.remove("active");
      document.body.style.overflow = "";
      setBackgroundInert(false);
      lightboxImg.style.transform = "";
      lightboxImg.style.opacity = "";
      lightboxImg.style.transition = "";
      lightboxImg.src = "";
      // Return focus to the trigger element that opened the lightbox
      var returnTarget = triggers[currentIndex];
      if (returnTarget && typeof returnTarget.focus === "function") {
        returnTarget.focus();
      }
    }

    function navigate(delta) {
      let next = currentIndex + delta;
      if (next >= triggers.length) next = 0;
      if (next < 0) next = triggers.length - 1;
      showImage(next);
    }

    // Attach click handlers
    collectTriggers();
    triggers.forEach((trigger, i) => {
      trigger.addEventListener("click", () => openLightbox(i));
    });

    closeBtn?.addEventListener("click", closeLightbox);
    prevBtn?.addEventListener("click", () => navigate(-1));
    nextBtn?.addEventListener("click", () => navigate(1));

    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener("keydown", (e) => {
      if (!lightbox.classList.contains("active")) return;
      if (e.key === "Escape") closeLightbox();
      if (e.key === "ArrowLeft") navigate(-1);
      if (e.key === "ArrowRight") navigate(1);
    });

    // ─── Focus Trap ───
    lightbox.addEventListener("keydown", function(e) {
      if (e.key !== "Tab" || !lightbox.classList.contains("active")) return;

      var focusable = Array.from(
        lightbox.querySelectorAll('button:not([disabled]):not([style*="display: none"]):not([style*="display:none"])')
      ).filter(function(el) {
        return el.offsetParent !== null; // visible only
      });

      if (focusable.length === 0) return;

      var first = focusable[0];
      var last = focusable[focusable.length - 1];

      if (e.shiftKey) {
        // Shift+Tab: if focus is on the first element, wrap to the last
        if (document.activeElement === first) {
          e.preventDefault();
          last.focus();
        }
      } else {
        // Tab: if focus is on the last element, wrap to the first
        if (document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    // ─── Touch Swipe Gestures ───
    var touchStartX = 0;
    var touchStartY = 0;
    var touchStartTime = 0;
    var isSwiping = false;
    var swipeDirection = null; // 'horizontal' or 'vertical'
    var hasInteracted = false;
    var SWIPE_THRESHOLD = 50;
    var SWIPE_MAX_TIME = 400;
    var DISMISS_THRESHOLD = 120;

    lightbox.addEventListener("touchstart", function(e) {
      if (!lightbox.classList.contains("active")) return;
      var touch = e.touches[0];
      touchStartX = touch.clientX;
      touchStartY = touch.clientY;
      touchStartTime = Date.now();
      isSwiping = true;
      swipeDirection = null;
      lightboxImg.style.transition = "none";
    }, { passive: true });

    lightbox.addEventListener("touchmove", function(e) {
      if (!isSwiping || !lightbox.classList.contains("active")) return;
      var touch = e.touches[0];
      var dx = touch.clientX - touchStartX;
      var dy = touch.clientY - touchStartY;

      // Determine swipe direction on first significant movement
      if (!swipeDirection) {
        if (Math.abs(dx) > 10 || Math.abs(dy) > 10) {
          swipeDirection = Math.abs(dx) > Math.abs(dy) ? "horizontal" : "vertical";
        } else {
          return;
        }
      }

      if (swipeDirection === "horizontal") {
        // Horizontal: follow finger for nav preview
        var resistance = 0.8;
        lightboxImg.style.transform = "translateX(" + (dx * resistance) + "px)";
        lightboxImg.style.opacity = String(Math.max(0.3, 1 - Math.abs(dx) / 400));
        e.preventDefault();
      } else if (swipeDirection === "vertical" && dy > 0) {
        // Vertical downward: follow finger for dismiss preview
        var resistance = 0.6;
        lightboxImg.style.transform = "translateY(" + (dy * resistance) + "px) scale(" + Math.max(0.85, 1 - dy / 800) + ")";
        lightboxImg.style.opacity = String(Math.max(0.3, 1 - dy / 400));
        e.preventDefault();
      }
    }, { passive: false });

    lightbox.addEventListener("touchend", function(e) {
      if (!isSwiping || !lightbox.classList.contains("active")) return;
      isSwiping = false;
      hasInteracted = true;

      var touch = e.changedTouches[0];
      var dx = touch.clientX - touchStartX;
      var dy = touch.clientY - touchStartY;
      var dt = Date.now() - touchStartTime;
      var isQuick = dt < SWIPE_MAX_TIME;

      lightboxImg.style.transition = "transform 300ms ease, opacity 300ms ease";

      if (swipeDirection === "horizontal") {
        if (Math.abs(dx) > SWIPE_THRESHOLD && isQuick) {
          // Quick horizontal swipe: navigate
          if (dx > 0) {
            navigate(-1); // swipe right = previous
          } else {
            navigate(1); // swipe left = next
          }
        } else if (Math.abs(dx) > DISMISS_THRESHOLD) {
          // Long slow horizontal drag past threshold: also navigate
          if (dx > 0) {
            navigate(-1);
          } else {
            navigate(1);
          }
        } else {
          // Snap back
          lightboxImg.style.transform = "";
          lightboxImg.style.opacity = "";
        }
      } else if (swipeDirection === "vertical") {
        if (dy > DISMISS_THRESHOLD || (dy > SWIPE_THRESHOLD && isQuick)) {
          // Swipe down: close lightbox with animation
          lightboxImg.style.transform = "translateY(100vh) scale(0.8)";
          lightboxImg.style.opacity = "0";
          setTimeout(closeLightbox, 300);
        } else {
          // Snap back
          lightboxImg.style.transform = "";
          lightboxImg.style.opacity = "";
        }
      } else {
        lightboxImg.style.transform = "";
        lightboxImg.style.opacity = "";
      }
    }, { passive: true });

    // ─── Swipe Hint ───
    function showSwipeHint() {
      if (hasInteracted || triggers.length <= 1) return;
      var hintShown = sessionStorage.getItem("lightbox-hint-shown");
      if (hintShown) return;

      sessionStorage.setItem("lightbox-hint-shown", "true");

      var hint = document.createElement("div");
      hint.className = "lightbox-swipe-hint";
      hint.setAttribute("aria-hidden", "true");
      hint.innerHTML = '<span class="lightbox-hint-icon">←</span> Swipe to navigate <span class="lightbox-hint-icon">→</span>';
      lightbox.appendChild(hint);

      requestAnimationFrame(function() {
        hint.classList.add("visible");
      });

      setTimeout(function() {
        hint.classList.remove("visible");
        setTimeout(function() { hint.remove(); }, 400);
      }, 2500);
    }
  });
</script>
