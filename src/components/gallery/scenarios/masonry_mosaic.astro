---
/**
 * Scenario 6: Masonry Mosaic
 *
 * Non-uniform grid for large media collections. Images pop in with
 * tactile-pop animation. Supports category filtering and random
 * sizing variation for visual interest.
 */
import { Image } from "astro:assets";

interface ImageRef {
  src: ImageMetadata;
  alt?: string;
  caption?: string;
  camera?: string;
  lens?: string;
  settings?: string;
  location?: string;
  tags?: string[];
}

interface Section {
  type: string;
  image?: ImageMetadata;
  images?: ImageRef[];
  content?: string;
  alt?: string;
  caption?: string;
  attribution?: string;
  camera?: string;
  lens?: string;
  settings?: string;
  location?: string;
}

interface Props {
  title: string;
  prologue: string;
  cover_image: ImageMetadata;
  cover_image_alt?: string;
  sections: Section[];
  storyId: string;
}

const { title, prologue, cover_image, cover_image_alt, sections, storyId } = Astro.props;

// Gather all images from all sections for the mosaic
const allImages: ImageRef[] = [];
sections.forEach((section) => {
  if (section.type === "full-bleed" && section.image) {
    allImages.push({
      src: section.image,
      alt: section.alt,
      caption: section.caption,
      camera: section.camera,
      lens: section.lens,
      settings: section.settings,
      location: section.location,
    });
  }
  if (section.images) {
    section.images.forEach((img) => allImages.push(img));
  }
});

// Collect unique tags for filter buttons
const allTags = new Set<string>();
allImages.forEach((img) => {
  if (img.tags) img.tags.forEach((t) => allTags.add(t));
});

// Collect text and quote sections for displaying below
const textSections = sections.filter(
  (s) => s.type === "text" || s.type === "quote"
);

// Create size classes for masonry variation
const sizeClasses = [
  "col-span-1 row-span-1",
  "col-span-1 row-span-2",
  "col-span-2 row-span-1",
  "col-span-2 row-span-2",
];
---

<article class="masonry-mosaic bg-gallery-bg text-gallery-text" aria-label={title}>
  <!-- Header -->
  <header class="px-6 sm:px-10 py-16 sm:py-24 max-w-4xl mx-auto text-center">
    <h1 class="font-display text-3xl sm:text-5xl font-bold leading-[1.1] tracking-tight text-gallery-text gallery-reveal">
      {title}
    </h1>
    <p class="mt-6 text-gallery-text/60 text-lg sm:text-xl leading-[1.7] font-light gallery-reveal" style="transition-delay: 150ms;">
      {prologue}
    </p>
  </header>

  <!-- Filter bar (if tags exist) -->
  {allTags.size > 0 && (
    <nav class="mosaic-filters sticky top-0 z-20 bg-gallery-bg/90 backdrop-blur-sm border-b border-gallery-text/10 px-6 sm:px-10 py-3" aria-label="Image filters">
      <div class="flex items-center gap-3 overflow-x-auto max-w-7xl mx-auto scrollbar-hidden">
        <button type="button" class="mosaic-filter-btn active whitespace-nowrap text-sm font-medium px-4 py-1.5 rounded-full border border-gallery-text/20 text-gallery-text transition-colors" data-filter="all" aria-pressed="true">
          All
        </button>
        {[...allTags].map((tag) => (
          <button type="button" class="mosaic-filter-btn whitespace-nowrap text-sm font-medium px-4 py-1.5 rounded-full border border-gallery-text/20 text-gallery-text/60 transition-colors" data-filter={tag} aria-pressed="false">
            {tag}
          </button>
        ))}
      </div>
    </nav>
  )}

  <!-- Masonry Grid -->
  <div class="mosaic-grid-wrapper max-w-7xl mx-auto px-4 sm:px-8 py-8 sm:py-12">
    <div class="mosaic-grid" data-masonry-grid role="list">
      {allImages.map((img, i) => {
        // Deterministic size based on index for visual interest
        const sizeIdx = i % 7 === 0 ? 3 : i % 5 === 0 ? 2 : i % 3 === 0 ? 1 : 0;
        const sizeClass = sizeClasses[sizeIdx];
        const tags = img.tags ? img.tags.join(",") : "";

        return (
          <figure
            class:list={["mosaic-item gallery-reveal", sizeClass]}
            data-tags={tags}
            role="listitem"
          >
            <button
              type="button"
              data-cursor="image" class="lightbox-trigger group block w-full h-full cursor-pointer border-0 bg-transparent p-0 relative overflow-hidden rounded-lg"
              data-caption={img.caption || ""}
              data-camera={img.camera || ""}
              data-lens={img.lens || ""}
              data-settings={img.settings || ""}
              data-location={img.location || ""}
              aria-label={`View full image: ${img.alt || `Photo ${i + 1}`}`}
            >
              <Image
                src={img.src}
                alt={img.alt || `Photo ${i + 1}`}
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                widths={[320, 640, 960]}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                {img.caption && (
                  <span class="text-white text-sm font-light">{img.caption}</span>
                )}
              </div>
            </button>
          </figure>
        );
      })}
    </div>
  </div>

  <!-- Text & Quote sections below the mosaic -->
  {textSections.length > 0 && (
    <div class="max-w-3xl mx-auto px-6 sm:px-8 pb-16">
      {textSections.map((section) => (
        <>
          {section.type === "text" && section.content && (
            <p class="text-gallery-text/60 text-lg leading-[1.8] font-light gallery-reveal py-6">
              {section.content}
            </p>
          )}
          {section.type === "quote" && section.content && (
            <blockquote class="gallery-reveal py-8 border-l-2 border-gallery-vivid/50 pl-6">
              <p class="font-display text-xl sm:text-2xl text-gallery-text/80 font-light italic leading-relaxed">
                {section.content}
              </p>
              {section.attribution && (
                <footer class="mt-3 text-sm text-gallery-text/40 font-light">
                  — {section.attribution}
                </footer>
              )}
            </blockquote>
          )}
        </>
      ))}
    </div>
  )}
</article>

<style>
  .mosaic-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    grid-auto-rows: 200px;
    gap: 0.5rem;
  }

  @media (min-width: 640px) {
    .mosaic-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-auto-rows: 220px;
      gap: 0.75rem;
    }
  }

  @media (min-width: 1024px) {
    .mosaic-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-auto-rows: 240px;
      gap: 1rem;
    }
  }

  .mosaic-item {
    overflow: hidden;
    border-radius: 0.5rem;
  }

  .mosaic-item.hidden-by-filter {
    display: none;
  }

  .mosaic-filter-btn.active {
    background-color: var(--color-gallery-vivid, #DC3E26);
    border-color: var(--color-gallery-vivid, #DC3E26);
    color: #fff;
  }

  .scrollbar-hidden {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hidden::-webkit-scrollbar {
    display: none;
  }
</style>

<script is:inline>
  document.addEventListener("astro:page-load", function () {
    var mosaic = document.querySelector(".masonry-mosaic");
    if (!mosaic) return;

    // Filter logic
    var filterBtns = mosaic.querySelectorAll(".mosaic-filter-btn");
    var items = mosaic.querySelectorAll(".mosaic-item");

    filterBtns.forEach(function (btn) {
      btn.addEventListener("click", function () {
        var filter = btn.getAttribute("data-filter");

        filterBtns.forEach(function (b) {
          b.classList.remove("active");
          b.setAttribute("aria-pressed", "false");
        });
        btn.classList.add("active");
        btn.setAttribute("aria-pressed", "true");

        items.forEach(function (item) {
          if (filter === "all") {
            item.classList.remove("hidden-by-filter");
            return;
          }
          var tags = (item.getAttribute("data-tags") || "").split(",");
          if (tags.indexOf(filter) !== -1) {
            item.classList.remove("hidden-by-filter");
          } else {
            item.classList.add("hidden-by-filter");
          }
        });
      });
    });

    // Reveal animation
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            entry.target.classList.add("revealed");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.05, rootMargin: "0px 0px -30px 0px" }
    );

    mosaic.querySelectorAll(".gallery-reveal").forEach(function (el) {
      observer.observe(el);
    });

    // Immediately reveal elements to prevent invisible content on page load
    requestAnimationFrame(function() {
      var vh = window.innerHeight || 800;
      mosaic.querySelectorAll(".gallery-reveal").forEach(function(el) {
        var rect = el.getBoundingClientRect();
        var delay = rect.top > vh ? Math.min(800, ((rect.top - vh) / vh) * 100) : 0;
        el.style.transitionDelay = Math.round(delay) + "ms";
        el.classList.add("visible");
        el.classList.add("revealed");
        observer.unobserve(el);
      });
    });
  });
</script>
