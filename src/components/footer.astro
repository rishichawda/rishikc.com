---

<footer class="site-footer" role="contentinfo">
  <div class="footer-container">
    <!-- Divider -->
    <div class="footer-divider"></div>

    <div class="footer-content">
      <!-- Social links -->
      <div class="footer-social">
        {socialLinks.map((link) => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="social-link"
            aria-label={`Visit Rishi's ${link.label} profile (opens in new tab)`}
          >
            <span class="sr-only">{link.label}</span>
            <svg viewBox="0 0 24 24" class="social-icon" aria-hidden="true">
              <path d={link.icon} fill="currentColor"></path>
            </svg>
          </a>
        ))}
      </div>

      <!-- Copyright -->
      <p class="footer-copyright">
        © {currentYear} Rishi Chawda
      </p>

      <!-- Footer navigation -->
      <nav class="footer-nav" aria-label="Footer navigation">
        {footerLinks.map((link, index) => (
          <>
            {index > 0 && <span class="footer-sep" aria-hidden="true">·</span>}
            <a href={link.path} class="footer-link">{link.label}</a>
          </>
        ))}
      </nav>
    </div>

    <!-- Scroll footer surprise (easter egg slot) -->
    <p class="footer-surprise" data-footer-surprise aria-hidden="true"></p>
  </div>
</footer>

<style>
  .site-footer {
    padding: var(--space-12) 0 var(--space-8);
  }

  .footer-container {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .footer-divider {
    height: 1px;
    background: var(--color-border);
    margin-bottom: var(--space-8);
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .footer-social {
    display: flex;
    gap: var(--space-4);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    color: var(--color-text-tertiary);
    transition: color var(--duration-fast) ease,
                background var(--duration-fast) ease,
                transform var(--duration-fast) ease;
  }

  .social-link:hover {
    color: var(--color-text);
  }

  .social-icon {
    width: 24px;
    height: 24px;
  }

  .footer-copyright {
    font-family: var(--font-ui);
    font-size: var(--text-ui-small);
    color: var(--color-text-muted);
  }

  .footer-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .footer-link {
    font-family: var(--font-ui);
    font-size: var(--text-ui-small);
    color: var(--color-text-tertiary);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .footer-link:hover {
    color: var(--color-text);
  }

  .footer-sep {
    color: var(--color-text-muted);
    font-size: var(--text-ui-small);
  }

  @media (max-width: 767px) {
    .footer-nav {
      gap: var(--space-2);
    }
    .footer-sep {
      display: none;
    }
    .footer-link {
      padding: var(--space-1) var(--space-2);
    }
  }

  .footer-surprise {
    text-align: center;
    margin-top: var(--space-6);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-muted);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity var(--duration-slow) ease,
                transform var(--duration-slow) ease;
  }

  .footer-surprise.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  function initFooterSurprise() {
    const surprise = document.querySelector<HTMLElement>('[data-footer-surprise]');
    if (!surprise) return;

    const messages = [
      "You've reached the bottom. Time for a coffee? ☕",
      "Thanks for scrolling all the way down. That means a lot.",
      "The best code, like the best coffee, is made with care.",
      "If you're reading this, we should probably be friends.",
    ];

    surprise.textContent = messages[Math.floor(Math.random() * messages.length)];

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            surprise.classList.add('visible');
            surprise.setAttribute('aria-hidden', 'false');
          }
        });
      },
      { threshold: 1.0 }
    );
    observer.observe(surprise);
  }

  document.addEventListener('astro:page-load', initFooterSurprise);
</script>
