const footerLinks = [
  { label: "Articles", path: "/articles/" },
  { label: "Projects", path: "/projects/" },
  { label: "Gallery", path: "/gallery/" },
  { label: "Career", path: "/career/" },
  { label: "About", path: "/about/" },
  { label: "Contact", path: "/contact/" },
  { label: "Privacy Policy", path: "/privacy/" },
