---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import SeriesIndicator from "./series_indicator.astro";

interface Props {
  currentArticle: CollectionEntry<"articles">;
  allArticles: CollectionEntry<"articles">[];
}

const { currentArticle, allArticles } = Astro.props;

function calculateSimilarity(article1: CollectionEntry<"articles">, article2: CollectionEntry<"articles">): number {
  if (article1.id === article2.id) return 0;

  let score = 0;
  
  const commonTags = article1.data.tags.filter(tag => article2.data.tags.includes(tag));
  score += commonTags.length * 2;

  const keywords1 = article1.data.keywords.split(",").map(k => k.trim());
  const keywords2 = article2.data.keywords.split(",").map(k => k.trim());
  const commonKeywords = keywords1.filter(k => keywords2.includes(k));
  score += commonKeywords.length;

  if (article1.data.category && article2.data.category && article1.data.category === article2.data.category) {
    score += 2;
  }

  return score;
}

// Get related articles
const relatedArticles = allArticles
  .map(article => ({
    article,
    similarity: calculateSimilarity(currentArticle, article)
  }))
  .sort((a, b) => b.similarity - a.similarity)
  .slice(0, 6)
  .map(({ article }) => article);

function formatDate(date: Date): string {
  return new Date(date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<section class="related-section">
  <!-- Section Header -->
  <div class="related-header">
    <h2 class="related-heading">Continue Reading</h2>
    <p class="related-subtext">More articles you might enjoy</p>
  </div>

  <!-- Articles Grid -->
  <div class="related-grid">
    {
      relatedArticles.map((article) => (
        <article class="related-card-wrap">
          <a
            href={article.data.path}
            class="related-card"
            data-cursor="card"
          >
            <div class="related-image">
              <Image
                src={article.data.hero_image}
                alt={article.data.hero_image_alt || article.data.title}
                class="related-img"
                transition:name={`${article.data.path}-image`}
                width={400}
                height={250}
              />
            </div>
            <div class="related-content">
              <div class="related-meta">
                <time>{formatDate(article.data.date)}</time>
                <SeriesIndicator article={article} compact={true} />
              </div>
              <h3 class="related-title" transition:name={`${article.data.path}-title`}>
                {article.data.title}
              </h3>
              <p class="related-desc">{article.data.description}</p>
              <div class="related-tags">
                {article.data.tags.slice(0, 3).map((tag: string) => (
                  <span class="related-tag">{tag}</span>
                ))}
              </div>
            </div>
          </a>
        </article>
      ))
    }
  </div>

  <!-- View All Articles CTA -->
  <div class="related-cta-wrap">
    <a href="/articles/" class="related-cta">
      Explore All Articles
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5l7 7-7 7"/></svg>
    </a>
  </div>
</section>

<style>
  .related-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-16) var(--space-6) var(--space-20);
  }

  .related-header {
    text-align: center;
    margin-bottom: var(--space-10);
  }

  .related-heading {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .related-subtext {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
  }

  .related-grid {
    columns: 1;
    column-gap: var(--space-6);
  }

  @media (min-width: 640px) {
    .related-grid { columns: 2; }
  }
  @media (min-width: 1024px) {
    .related-grid { columns: 3; }
  }

  .related-card-wrap {
    break-inside: avoid;
    margin-bottom: var(--space-6);
  }

  .related-card {
    display: flex;
    flex-direction: column;
    height: auto;
    text-decoration: none;
    color: inherit;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-raised);
    transition: transform var(--duration-normal) ease,
                box-shadow var(--duration-normal) ease;
  }

  .related-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-elevated);
  }

  .related-image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .related-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-normal) ease;
  }

  .related-card:hover .related-img {
    transform: scale(1.03);
  }

  .related-content {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: var(--space-5);
  }

  .related-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-3);
  }

  .related-title {
    font-family: var(--font-display);
    font-size: var(--text-body-lg);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: var(--space-2);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--duration-fast) ease;
  }

  .related-card:hover .related-title {
    color: var(--color-brand);
  }

  .related-desc {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: var(--space-4);
    flex: 1;
  }

  .related-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .related-tag {
    display: inline-block;
    padding: 2px var(--space-3);
    font-family: var(--font-ui);
    font-size: var(--text-ui-small);
    color: var(--color-brand-dark);
    background: var(--color-brand-lighter);
    border-radius: var(--radius-full);
  }

  .related-cta-wrap {
    text-align: center;
    margin-top: var(--space-10);
  }

  .related-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: var(--btn-bg);
    color: #fff;
    font-family: var(--font-ui);
    font-size: var(--text-body);
    font-weight: 500;
    padding: var(--space-3) var(--space-8);
    border-radius: var(--radius-lg);
    text-decoration: none;
    box-shadow: var(--shadow-raised);
    transition: background var(--duration-fast) ease,
                box-shadow var(--duration-fast) ease,
                gap var(--duration-fast) ease;
  }

  .related-cta:hover {
    background: var(--btn-bg-hover);
    box-shadow: var(--shadow-elevated);
    gap: var(--space-3);
  }
</style>