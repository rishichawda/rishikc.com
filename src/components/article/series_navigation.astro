---
import type { SeriesInfo } from "../../utils/seriesUtils";

interface Props {
  seriesInfo: SeriesInfo;
  seriesTitle: string;
}

const { seriesInfo, seriesTitle } = Astro.props;
---

<div class="bg-gradient-to-br from-brand-50/10 to-brand-70/30 backdrop-blur-sm rounded-3xl border border-brand-200/40 p-8 shadow-lg hover:shadow-xl transition-all duration-500 mb-12">
  <!-- Series Header -->
  <div class="flex items-start gap-4 mb-6">
    <div class="flex-shrink-0 w-12 h-12 bg-btn rounded-2xl flex items-center justify-center shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
      </svg>
    </div>
    
    <div class="flex-1">
      <div class="flex items-center gap-3 mb-2">
        <h3 class="text-xl font-bold text-[var(--color-text)] font-display">
          {seriesTitle}
        </h3>
        {seriesInfo.isOngoing && (
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-amber-100 text-amber-800 border border-amber-200">
            <div class="w-1.5 h-1.5 bg-amber-500 rounded-full mr-1.5 animate-pulse"></div>
            Ongoing Series
          </span>
        )}
      </div>
      
      <p class="text-sm text-[var(--color-text-secondary)] font-heading">
        Part {seriesInfo.currentIndex} of {seriesInfo.totalParts}
        {seriesInfo.isOngoing && !seriesInfo.isLastPart ? "+" : ""} in this series
      </p>
    </div>
  </div>

  <!-- Progress Bar -->
  <div class="mb-6">
    <div class="flex items-center justify-between mb-2">
      <span class="text-xs font-medium text-[var(--color-text-tertiary)] font-heading">Series Progress</span>
      <span class="text-xs font-medium text-brand-600 font-heading">
        {Math.round((seriesInfo.currentIndex / seriesInfo.totalParts) * 100)}%
      </span>
    </div>
    <div class="w-full bg-[var(--color-border-strong)] rounded-full h-2">
      <div 
        class="bg-gradient-to-r from-brand-500 to-brand-600 h-2 rounded-full transition-all duration-1000 ease-out"
        style={`width: ${(seriesInfo.currentIndex / seriesInfo.totalParts) * 100}%`}
        role="progressbar"
        aria-valuenow={seriesInfo.currentIndex}
        aria-valuemin={1}
        aria-valuemax={seriesInfo.totalParts}
        aria-label={`Series progress: Part ${seriesInfo.currentIndex} of ${seriesInfo.totalParts}`}
      ></div>
    </div>
  </div>

  <!-- Series Parts List -->
  <div class="space-y-3 mb-6">
    <h4 class="text-sm font-semibold text-[var(--color-text-secondary)] font-heading mb-3">All Parts in This Series</h4>
    <div class="space-y-2">
      {seriesInfo.allParts.map((part, index) => (
        <div 
          class={`flex items-center gap-3 p-3 rounded-xl transition-all duration-300 ${
            part.isCurrent 
              ? 'bg-gradient-to-r from-brand-100/90 to-brand-50/60 border border-brand-200/60 shadow-sm' 
              : 'hover:bg-[var(--color-bg-alt)]/80 border border-transparent'
          }`}
        >
          <div class={`flex-shrink-0 w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold transition-all duration-300 ${
            part.isCurrent
              ? 'bg-btn text-white shadow-md'
              : index < seriesInfo.currentIndex - 1
                ? 'bg-green-100 text-green-700 border border-green-200'
                : 'bg-[var(--color-bg-alt)] text-[var(--color-text-tertiary)] border border-[var(--color-border)]'
          }`}>
            {part.isCurrent ? (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            ) : index < seriesInfo.currentIndex - 1 ? (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            ) : (
              index + 1
            )}
          </div>
          
          {part.isCurrent ? (
            <span class="flex-1 text-sm font-semibold text-brand-800 font-heading leading-tight">
              {part.title}
              <span class="ml-2 text-xs text-brand-800 font-normal">(Current)</span>
            </span>
          ) : (
            <a 
              href={part.path}
              class="flex-1 text-sm font-medium text-[var(--color-text-secondary)] hover:text-brand-700 font-heading leading-tight transition-colors duration-200 hover:underline"
            >
              {part.title}
            </a>
          )}
        </div>
      ))}
    </div>
  </div>

  <!-- Navigation -->
  <div class="flex items-center justify-between pt-4 border-t border-brand-100/50">
    {seriesInfo.previousPart ? (
      <a 
        href={seriesInfo.previousPart.path}
        class="max-w-[120px] sm:max-w-[250px] group flex items-center gap-2 px-4 py-2.5 bg-[var(--color-surface)]/80 hover:bg-[var(--color-surface)] border border-brand-200/50 hover:border-brand-300/70 rounded-xl text-brand-700 hover:text-brand-800 transition-all duration-300 shadow-sm hover:shadow-md font-heading text-sm font-medium"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="hidden sm:inline">Previous:</span>
        <span class="truncate max-w-[120px] sm:max-w-[200px]" title={seriesInfo.previousPart.title}>
          {seriesInfo.previousPart.title}
        </span>
      </a>
    ) : (
      <div class="hidden flex items-center gap-2 px-4 py-2.5 text-[var(--color-text-muted)] text-sm font-heading">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="hidden sm:inline">First Part</span>
      </div>
    )}

    <a 
      href="/articles/series/"
      class="flex items-center gap-2 px-4 py-2.5 text-brand-600 hover:text-brand-800 text-sm font-heading font-medium transition-colors duration-200 hover:underline underline-offset-2"
    >
      View All Series
    </a>

    {seriesInfo.nextPart ? (
      <a 
        href={seriesInfo.nextPart.path}
        class="max-w-[120px] sm:max-w-[250px] group flex items-center gap-2 px-4 py-2.5 bg-btn hover:bg-btn-hover rounded-xl text-white transition-all duration-300 shadow-lg hover:shadow-xl font-heading text-sm font-medium"
      >
        <span class="hidden sm:inline">Next:</span>
        <span class="truncate max-w-[120px] sm:max-w-[200px]" title={seriesInfo.nextPart.title}>
          {seriesInfo.nextPart.title}
        </span>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    ) : (
      <div class="hidden flex items-center gap-2 px-4 py-2.5 text-[var(--color-text-muted)] text-sm font-heading">
        <span class="hidden sm:inline">
          {seriesInfo.isOngoing ? "More Coming Soon" : "Final Part"}
        </span>
        {seriesInfo.isOngoing ? (
          <div class="w-4 h-4 border-2 border-[var(--color-border-strong)] border-t-[var(--color-text-tertiary)] rounded-full animate-spin"></div>
        ) : (
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        )}
      </div>
    )}
  </div>
</div>

<style>
  @media (prefers-reduced-motion: reduce) {
    /* Disable Tailwind animate-pulse on the ongoing series indicator */
    .animate-pulse {
      animation: none !important;
    }

    /* Disable Tailwind animate-spin on the loading spinner */
    .animate-spin {
      animation: none !important;
    }

    /* Remove all transitions used throughout the component */
    .transition-all,
    .transition-colors,
    .transition-transform {
      transition: none !important;
    }
  }
</style>
