---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const allArticles = await getCollection("articles");
const sortedArticles = allArticles
  .sort(
    (a: CollectionEntry<"articles">, b: CollectionEntry<"articles">) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  );

const featured = sortedArticles[0];
const recent = sortedArticles.slice(1, 3);

const allBits = await getCollection("bits");
const latestBits = allBits
  .sort(
    (a: CollectionEntry<"bits">, b: CollectionEntry<"bits">) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 2);

function formatDate(date: string | Date) {
  return new Date(date).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<section class="section-writing" data-reveal>
  <div class="section-container">
    <div class="section-header-left">
      <span class="overline">LATEST THOUGHTS</span>
      <!-- <h2 class="section-title">Latest Writing</h2> -->
      <p class="section-subtitle">
        Exploring the intersection of technology, creativity, and human experience
      </p>
    </div>

    <div class="bento-grid" data-reveal-group>
      {/* Featured article — large card, spans 2 rows */}
      {featured && (
        <a
          href={featured.data.path}
          class="bento-featured"
          data-reveal-item
          data-cursor="card"
        >
          <div class="featured-image">
            <Image
              src={featured.data.hero_image}
              alt={featured.data.hero_image_alt || featured.data.title}
              width={800}
              quality="mid"
              class="featured-img"
              transition:name={`article-hero-${featured.id}`}
            />
          </div>
          <div class="featured-content">
            <div class="article-meta">
              <time datetime={new Date(featured.data.date).toISOString().split('T')[0]}>{formatDate(featured.data.date)}</time>
            </div>
            <h3 class="featured-title">{featured.data.title}</h3>
            {featured.data.subtitle && (
              <p class="featured-subtitle">{featured.data.subtitle}</p>
            )}
            {featured.data.tags && (
              <div class="article-tags">
                {featured.data.tags.slice(0, 3).map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      )}

      {/* Right column: recent articles + bits */}
      <div class="bento-sidebar">
        {/* Recent articles */}
        {recent.map((article) => (
          <a
            href={article.data.path}
            class="recent-card"
            data-reveal-item
            data-cursor="card"
          >
            <div class="recent-image">
              <Image
                src={article.data.hero_image}
                alt={article.data.hero_image_alt || article.data.title}
                width={300}
                quality="low"
                class="recent-img"
              />
            </div>
            <div class="recent-content">
              <div class="article-meta">
                <time datetime={new Date(article.data.date).toISOString().split('T')[0]}>{formatDate(article.data.date)}</time>
              </div>
              <h3 class="recent-title">{article.data.title}</h3>
              <p class="recent-desc">{article.data.description}</p>
            </div>
          </a>
        ))}

        {/* Bits preview embedded in bento */}
        {latestBits.length > 0 && (
          <div class="bits-bento" data-reveal-item>
            <div class="bits-bento-header">
              <span class="bits-label">Bits &amp; Thoughts</span>
              <a href="/bits/" class="bits-all-link">
                View all
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div class="bits-mini-grid">
              {latestBits.map((bit) => (
                <a href={bit.data.path} class="bit-mini" data-cursor="card">
                  <h4 class="bit-mini-title">{bit.data.title}</h4>
                  <p class="bit-mini-desc">{bit.data.description}</p>
                  <span class="bit-mini-date">{formatDate(bit.data.date)}</span>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    <div class="section-link-wrap">
      <a href="/articles/" class="section-link">
        View All Articles
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .section-writing {
    padding: var(--space-12) 0;
  }

  .section-container {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .section-header-left {
    margin-bottom: var(--space-8);
  }

  .overline {
    display: block;
    font-family: var(--font-ui);
    font-size: var(--text-body);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand-dark);
    margin-bottom: var(--space-3);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .section-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-text-secondary);
    max-width: 540px;
    line-height: 1.6;
  }

  /* ─── Bento Grid ─── */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }

  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-columns: 3fr 2fr;
      align-items: start;
    }
    .bento-featured {
      max-height: 520px;
      display: flex;
      flex-direction: column;
    }
    .bento-featured .featured-image {
      flex-shrink: 0;
      max-height: 280px;
    }
    .bento-featured .featured-content {
      flex: 1;
      min-height: 0;
      overflow: hidden;
    }
  }

  /* ─── Featured Card ─── */
  .bento-featured {
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-raised);
    transition: transform var(--duration-normal) ease,
                box-shadow var(--duration-normal) ease;
  }

  .bento-featured:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-elevated);
  }

  .featured-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    width: 100%;
  }

  .featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-normal) ease;
  }

  .bento-featured:hover .featured-img {
    transform: scale(1.03);
  }

  .featured-content {
    padding: var(--space-5) var(--space-6);
  }

  .article-meta {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-2);
  }

  .featured-title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-2);
    transition: color var(--duration-fast) ease;
  }

  .bento-featured:hover .featured-title {
    color: var(--color-brand);
  }

  .featured-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: var(--space-3);
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tag {
    display: inline-block;
    padding: 2px var(--space-3);
    font-family: var(--font-ui);
    font-size: var(--text-ui-small);
    color: var(--color-brand-dark);
    background: var(--color-brand-lighter);
    border-radius: var(--radius-full);
  }

  /* ─── Sidebar (right column) ─── */
  .bento-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* ─── Recent Cards ─── */
  .recent-card {
    display: flex;
    gap: var(--space-4);
    text-decoration: none;
    color: inherit;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-raised);
    transition: transform var(--duration-normal) ease,
                box-shadow var(--duration-normal) ease;
  }

  .recent-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-elevated);
  }

  .recent-image {
    flex-shrink: 0;
    width: 120px;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .recent-image {
      width: 150px;
    }
  }

  .recent-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-normal) ease;
  }

  .recent-card:hover .recent-img {
    transform: scale(1.03);
  }

  .recent-content {
    padding: var(--space-3) var(--space-3) var(--space-3) 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  .recent-title {
    font-family: var(--font-display);
    font-size: var(--text-body);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: var(--space-1);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    transition: color var(--duration-fast) ease;
  }

  .recent-card:hover .recent-title {
    color: var(--color-brand);
  }

  .recent-desc {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    color: var(--color-text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ─── Bits Bento Panel ─── */
  .bits-bento {
    background: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    translate: 0 var(--space-8);
  }

  .bits-bento-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-3);
  }

  .bits-label {
    font-family: var(--font-ui);
    font-size: var(--text-ui-small);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
  }

  .bits-all-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-family: var(--font-ui);
    font-size: var(--text-caption);
    font-weight: 500;
    color: var(--color-brand-dark);
    text-decoration: none;
    transition: gap var(--duration-fast) ease;
  }

  .bits-all-link:hover {
    gap: 6px;
  }

  .bits-mini-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }

  .bit-mini {
    display: flex;
    flex-direction: column;
    padding: var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: transform var(--duration-fast) ease,
                box-shadow var(--duration-fast) ease;
  }

  .bit-mini:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-raised);
  }

  .bit-mini-title {
    font-family: var(--font-display);
    font-size: var(--text-body-sm);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: var(--space-1);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .bit-mini:hover .bit-mini-title {
    color: var(--color-brand);
  }

  .bit-mini-desc {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--color-text-muted);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: auto;
    flex: 1;
  }

  .bit-mini-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-tertiary);
    margin-top: var(--space-2);
  }

  /* ─── Section Link ─── */
  .section-link-wrap {
    text-align: right;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--text-body-sm);
    font-weight: 500;
    color: var(--color-brand-dark);
    text-decoration: none;
    transition: gap var(--duration-fast) ease;
  }

  .section-link:hover {
    gap: var(--space-3);
  }
</style>
