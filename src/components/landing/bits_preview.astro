---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";

const allBits = await getCollection("bits");
const bits = allBits
  .sort(
    (a: CollectionEntry<"bits">, b: CollectionEntry<"bits">) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 4)
  .map((bit: CollectionEntry<"bits">) => ({
    title: bit.data.title,
    description: bit.data.description,
    link: bit.data.path,
    date: new Date(bit.data.date).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    }),
    tags: bit.data.tags || [],
  }));
---

<section class="section-bits" data-reveal>
  <div class="section-container">
    <div class="section-header-left">
      <span class="overline">QUICK READS</span>
      <h2 class="section-title">Bits &amp; Thoughts</h2>
    </div>

    <div class="bits-carousel" id="bits-display" aria-live="polite">
      {bits.map((bit, index) => (
        <div
          class:list={["bit-slide", { active: index === 0 }]}
          data-bit-index={index}
        >
          <div class="bit-card">
            <p class="bit-date">{bit.date}</p>
            <h3 class="bit-title">{bit.title}</h3>
            <p class="bit-desc">{bit.description}</p>
            {bit.tags.length > 0 && (
              <div class="bit-tags">
                {bit.tags.map((tag: string) => (
                  <span class="bit-tag">{tag}</span>
                ))}
              </div>
            )}
            <a href={bit.link} class="bit-link">
              Read more
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="bits-nav">
      <div class="bits-dots" id="bits-dots">
        {bits.map((_, index) => (
          <button
            class:list={["dot", { active: index === 0 }]}
            data-dot-index={index}
            aria-label={`Go to bit ${index + 1}`}
          />
        ))}
      </div>
    </div>

    <div class="section-link-wrap">
      <a href="/bits/" class="section-link">
        More Bits
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    const display = document.getElementById("bits-display");
    const dotsContainer = document.getElementById("bits-dots");
    if (!display || !dotsContainer) return;

    const slides = Array.from(display.querySelectorAll('[data-bit-index]'));
    const dots = Array.from(dotsContainer.querySelectorAll('[data-dot-index]'));
    let current = 0;
    let timer: number | undefined;
    const INTERVAL = 5000;

    function show(index: number) {
      slides.forEach((el, i) => el.classList.toggle('active', i === index));
      dots.forEach((d, i) => d.classList.toggle('active', i === index));
      current = index;
    }

    function next() { show((current + 1) % slides.length); }

    function startTimer() {
      stopTimer();
      timer = window.setInterval(next, INTERVAL);
    }

    function stopTimer() {
      if (timer) { clearInterval(timer); timer = undefined; }
    }

    // Pause on hover
    display.addEventListener('mouseenter', stopTimer);
    display.addEventListener('mouseleave', startTimer);

    // Dot clicks
    dotsContainer.addEventListener('click', (e: Event) => {
      const target = e.target as HTMLElement;
      const idx = target.getAttribute('data-dot-index');
      if (idx !== null) { show(parseInt(idx)); startTimer(); }
    });

    // Cleanup for SPA nav
    document.addEventListener('astro:before-preparation', () => {
      stopTimer();
      display.removeEventListener('mouseenter', stopTimer);
      display.removeEventListener('mouseleave', startTimer);
    }, { once: true });

    startTimer();
  });
</script>

<style>
  .section-bits {
    padding: var(--space-10) 0;
    background: var(--color-bg-alt);
  }

  .section-container {
    max-width: var(--max-content);
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  .section-header-left {
    margin-bottom: var(--space-8);
  }

  .overline {
    display: block;
    font-family: var(--font-ui);
    font-size: var(--text-overline);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-brand);
    margin-bottom: var(--space-3);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-h2);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--color-text);
  }

  /* ─── Carousel ─── */
  .bits-carousel {
    position: relative;
    min-height: 220px;
  }

  .bit-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 300ms ease;
    pointer-events: none;
  }

  .bit-slide.active {
    position: relative;
    opacity: 1;
    pointer-events: auto;
  }

  .bit-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8) var(--space-10);
    max-width: 720px;
    margin: 0 auto;
  }

  .bit-date {
    font-family: var(--font-mono);
    font-size: var(--text-caption);
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-3);
  }

  .bit-title {
    font-family: var(--font-display);
    font-size: var(--text-h3);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .bit-desc {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: var(--space-4);
  }

  .bit-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-4);
  }

  .bit-tag {
    display: inline-block;
    padding: 2px var(--space-3);
    font-family: var(--font-ui);
    font-size: var(--text-ui-small);
    color: var(--color-brand-dark);
    background: var(--color-brand-lighter);
    border-radius: var(--radius-full);
  }

  .bit-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--text-body-sm);
    font-weight: 500;
    color: var(--color-brand-dark);
    text-decoration: none;
    transition: gap var(--duration-fast) ease;
  }

  .bit-link:hover { gap: var(--space-3); }

  /* ─── Dots ─── */
  .bits-nav {
    display: flex;
    justify-content: center;
    margin-top: var(--space-6);
  }

  .bits-dots {
    display: flex;
    gap: var(--space-2);
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: var(--radius-full);
    border: none;
    background: var(--color-border);
    cursor: pointer;
    transition: all var(--duration-fast) ease;
    padding: 0;
  }

  .dot.active {
    width: 32px;
    background: var(--color-brand);
  }

  /* ─── Section Link ─── */
  .section-link-wrap {
    text-align: right;
    margin-top: var(--space-6);
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-ui);
    font-size: var(--text-body-sm);
    font-weight: 500;
    color: var(--color-brand-dark);
    text-decoration: none;
    transition: gap var(--duration-fast) ease;
  }

  .section-link:hover { gap: var(--space-3); }
</style>
