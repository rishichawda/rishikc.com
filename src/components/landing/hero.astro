---
// Hero section — editorial first impression
// Full viewport, brand gradient, staggered entrance animations
---

<section class="hero-section" data-hero>
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-gradient"></div>
    <div class="hero-noise"></div>
  </div>

  <div class="hero-content">
    <div class="hero-text" data-animate="stagger">
      <h1 class="hero-tagline">
        <span class="hero-word" style="--i:0">Engineer.</span>
        <span class="hero-word" style="--i:1">Photographer.</span>
        <br class="hidden sm:block" />
        <span class="hero-word" style="--i:2">Seeker of Adventures.</span>
      </h1>

      <p class="hero-intro">
        I build software, write about technology, and capture the world through my lens.
      </p>

      <div class="hero-ctas">
        <a
          href="#services"
          class="hero-btn hero-btn-primary"
          data-magnetic
          data-magnetic-strength="6"
        >
          Explore My Work
        </a>
        <a
          href="/contact/"
          class="hero-btn hero-btn-secondary"
          data-magnetic
          data-magnetic-strength="6"
          transition:name="hero-cta-button"
        >
          Get in Touch
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator-wrap" aria-hidden="true">
      <div class="scroll-indicator">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </div>
      <span class="scroll-label">Scroll to explore</span>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    /* Offset the nav height padding from base_layout since hero goes full bleed */
    margin-top: calc(-1 * var(--nav-height));
    padding-top: var(--nav-height);
  }

  /* ─── Background ─── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #98a5db 0%, #8592c8 40%, #7485c1 70%, #6878ba 100%);
  }

  :global([data-theme="dark"]) .hero-gradient {
    background: linear-gradient(135deg, #4A548A 0%, #3D4575 40%, #333B65 70%, #2A3155 100%);
  }

  .hero-noise {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='256' height='256' filter='url(%23n)' opacity='0.5'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 128px 128px;
  }

  /* ─── Content ─── */
  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-8) var(--space-6);
    max-width: var(--max-content);
    margin: 0 auto;
    min-height: calc(100vh - var(--nav-height));
  }

  .hero-text {
    max-width: 800px;
  }

  .hero-tagline {
    font-family: var(--font-display);
    font-size: var(--text-display-xl);
    font-weight: 700;
    line-height: 1.1;
    color: #fff;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-6);
  }

  .hero-word {
    display: inline-block;
    opacity: 0;
    animation: hero-word-in 0.7s cubic-bezier(0, 0, 0.2, 1) forwards;
    animation-delay: calc(200ms + var(--i, 0) * 150ms);
  }

  @keyframes hero-word-in {
    from {
      opacity: 0;
      filter: blur(8px);
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      filter: blur(0);
      transform: translateY(0);
    }
  }

  .hero-intro {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: rgba(255, 255, 255, 0.85);
    max-width: 540px;
    margin: 0 auto var(--space-10);
    line-height: 1.6;
    opacity: 0;
    animation: hero-fade-in 0.5s ease-out 0.4s forwards;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
    opacity: 0;
    animation: hero-fade-up 0.5s ease-out 0.5s forwards;
  }

  @keyframes hero-fade-in {
    to { opacity: 1; }
  }

  @keyframes hero-fade-up {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ─── Buttons ─── */
  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-8);
    border-radius: var(--radius-lg);
    font-family: var(--font-ui);
    font-size: var(--text-body-sm);
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: transform var(--duration-fast) ease,
                box-shadow var(--duration-fast) ease,
                background var(--duration-fast) ease;
  }

  .hero-btn:hover {
    transform: translateY(-1px);
  }

  .hero-btn:active {
    transform: translateY(1px);
  }

  .hero-btn-primary {
    background: #fff;
    color: #3D4B73;
    box-shadow: var(--shadow-raised);
  }

  .hero-btn-primary:hover {
    box-shadow: var(--shadow-elevated);
    background: #f8f8f8;
  }

  .hero-btn-secondary {
    background: transparent;
    color: #fff;
    border: 1.5px solid rgba(255, 255, 255, 0.4);
  }

  .hero-btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.6);
  }

  /* ─── Scroll Indicator ─── */
  .scroll-indicator-wrap {
    position: absolute;
    bottom: var(--space-8);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    opacity: 0;
    animation: hero-fade-in 0.5s ease-out 0.8s forwards;
  }

  .scroll-indicator-wrap .scroll-indicator {
    color: rgba(255, 255, 255, 0.6);
    animation: scroll-bounce 2s ease-in-out infinite;
  }

  .scroll-label {
    font-family: var(--font-ui);
    font-size: var(--text-caption);
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .hero-section {
      min-height: 90vh;
    }
  }

  /* Reduced motion: show everything immediately */
  @media (prefers-reduced-motion: reduce) {
    .hero-word,
    .hero-intro,
    .hero-ctas,
    .scroll-indicator-wrap {
      opacity: 1;
      animation: none;
      filter: none;
      transform: none;
    }
  }
</style>
